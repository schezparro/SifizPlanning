          <EntitySet Name="_LastUpdatedTime" EntityType="Self._LastUpdatedTime" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [_LastUpdatedTime].[CollectionName] AS [CollectionName], 
    [_LastUpdatedTime].[CollectionId] AS [CollectionId], 
    [_LastUpdatedTime].[JobName] AS [JobName], 
    [_LastUpdatedTime].[JobId] AS [JobId], 
    [_LastUpdatedTime].[EnabledState] AS [EnabledState], 
    [_LastUpdatedTime].[WarehouseLastUpdated] AS [WarehouseLastUpdated], 
    [_LastUpdatedTime].[SnapshotLastUpdated] AS [SnapshotLastUpdated], 
    [_LastUpdatedTime].[AnalysisLastUpdated] AS [AnalysisLastUpdated], 
    [_LastUpdatedTime].[Warning] AS [Warning]
    FROM [dbo].[_LastUpdatedTime] AS [_LastUpdatedTime]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="_WitFields" EntityType="Self._WitFields" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [_WitFields].[SK] AS [SK], 
    [_WitFields].[ReferenceName] AS [ReferenceName], 
    [_WitFields].[DisplayName] AS [DisplayName], 
    [_WitFields].[DataType] AS [DataType], 
    [_WitFields].[ReportingType] AS [ReportingType], 
    [_WitFields].[ReportingFormula] AS [ReportingFormula], 
    [_WitFields].[ReportingReferenceName] AS [ReportingReferenceName], 
    [_WitFields].[ReportingDisplayName] AS [ReportingDisplayName], 
    [_WitFields].[DataTypeTo] AS [DataTypeTo], 
    [_WitFields].[ReportingTypeTo] AS [ReportingTypeTo], 
    [_WitFields].[ReportingFormulaTo] AS [ReportingFormulaTo], 
    [_WitFields].[ReportingReferenceNameTo] AS [ReportingReferenceNameTo], 
    [_WitFields].[ReportingDisplayNameTo] AS [ReportingDisplayNameTo], 
    [_WitFields].[TeamProjectCollectionBK] AS [TeamProjectCollectionBK], 
    [_WitFields].[FieldId] AS [FieldId], 
    [_WitFields].[WarehouseState] AS [WarehouseState], 
    [_WitFields].[BackfillWatermark] AS [BackfillWatermark]
    FROM [dbo].[_WitFields] AS [_WitFields]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="FactCurrentWorkItem" EntityType="Self.FactCurrentWorkItem" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [FactCurrentWorkItem].[CurrentWorkItemBK] AS [CurrentWorkItemBK], 
    [FactCurrentWorkItem].[WorkItemSK] AS [WorkItemSK], 
    [FactCurrentWorkItem].[TeamProjectSK] AS [TeamProjectSK], 
    [FactCurrentWorkItem].[LastUpdatedDateTime] AS [LastUpdatedDateTime], 
    [FactCurrentWorkItem].[Microsoft_VSTS_Common_BusinessValue] AS [Microsoft_VSTS_Common_BusinessValue], 
    [FactCurrentWorkItem].[Microsoft_VSTS_Scheduling_OriginalEstimate] AS [Microsoft_VSTS_Scheduling_OriginalEstimate], 
    [FactCurrentWorkItem].[Microsoft_VSTS_Scheduling_CompletedWork] AS [Microsoft_VSTS_Scheduling_CompletedWork], 
    [FactCurrentWorkItem].[Microsoft_VSTS_Scheduling_StoryPoints] AS [Microsoft_VSTS_Scheduling_StoryPoints], 
    [FactCurrentWorkItem].[Microsoft_VSTS_Scheduling_Effort] AS [Microsoft_VSTS_Scheduling_Effort], 
    [FactCurrentWorkItem].[Microsoft_VSTS_Scheduling_RemainingWork] AS [Microsoft_VSTS_Scheduling_RemainingWork]
