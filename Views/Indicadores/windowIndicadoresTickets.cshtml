    <div style="width: 100%; margin-bottom: 20px;">
        <div style="text-align: center; margin-bottom: 10px;">
            <label for="select-cliente-proyecto">TICKETS POR CLIENTES Y ESTADOS: </label>
        </div>
        <div style="display: flex; justify-content: space-around; align-items: center; width: 100%;">
            <!-- Card para la tabla -->
            <div class="card">
                <div class="card-header">
                    Tickets por clientes y estados
                </div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th style="background-color: #008aff; color: black;">Cliente</th>
                                <!-- Crear una columna por cada estado identificado -->
                                <th ng-repeat="estado in Object.keys(estadosUnicos)" style="background-color: #008aff; color: black;">{{estado}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Recorrer la lista de clientes -->
                            <tr ng-repeat="(cliente, estados) in clientes1">
                                <td>{{cliente}}</td>
                                <!-- Mostrar la cantidad de tickets por cada estado -->
                                <td ng-repeat="estado in Object.keys(estadosUnicos)">{{estados[estado] || 0}}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

