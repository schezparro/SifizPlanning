<div style="display: flex; justify-content: center; width: 100%;">
    <div class="panel panel-default" style="width: 700px;">
        <div class="panel-body">
            <div class="center-block">
                <div style="column-count: 3">
                    <div>
                        <div class="div-info-ticket">
                            <label for="fecha-inicio-etapa">FECHA INICIO</label>
                            <div class='input-group date'>
                                <input id="fecha-inicio-indicadores-tickets" ng-model="fechaInicio" class="form-control" ng-required="true" autocomplete="off" />
                            </div>
                        </div>

                        <div class="div-info-ticket">
                            <label for="fecha-fin-etapa">FECHA FIN</label>
                            <div class='input-group date'>
                                <input id="fecha-fin-indicadores-tickets" ng-model="fechaFin" class="form-control" ng-required="true" autocomplete="off" />
                            </div>
                        </div>
                    </div>
                    <div>
                        <button id="buscar-btn" class="btn btn-primary" ng-click="buscarOtrosDatos()">Buscar datos</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div>
    <br /><br />
</div>

<div style="margin: 10px; overflow-y: auto;" ng-show="mostrarGraficos">

    <div style="display: flex; flex-direction: column; align-items: center; max-height: calc(100vh - 200px); overflow-y: auto;">
        <div style="width: 100%; margin-bottom: 20px;">
            <div style="text-align: center; margin-bottom: 10px;">
                <label for="select-cliente-proyecto">NUEVOS TICKETS</label>
            </div>
            <div style="display: flex; justify-content: space-around; align-items: center; width: 100%;">
                <div class="card">
                    <div class="card-header">
                        Tickets en Gestión
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th style="background-color: #add8e6; color: black;">Semana</th>
                                    <th style="background-color: #add8e6; color: black;">Descripción</th>
                                    <th style="background-color: #add8e6; color: black;">Cantidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="ticket in infoTickets">
                                    <td>{{ticket.Semana}}</td>
                                    <td>{{ticket.Descripcion}}</td>
                                    <td>{{ticket.Cantidad}}</td>
                                </tr>
                                <tr>
                                    <td colspan="2" style="text-align: center; background-color: #add8e6; color: black; font-weight: bold;">Total</td>
                                    <td style="text-align: center; background-color: #add8e6; color: black; font-size: 20px;">{{totalCantidades | number:0}}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card" style="width: 400px; height: 400px;">
                    <div class="card-body">
                        <div class="chart">
                            <canvas id="tendenciaChart" width="400" height="400"></canvas>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div style="width: 100%; border-top: 2px solid #E0E0E0; ">
            <br />
        </div>

