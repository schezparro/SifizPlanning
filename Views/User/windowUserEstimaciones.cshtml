<label style="display: inline-block">
    Mostrar Todas:
    <input style="vertical-align: -2px;" type="checkbox" ng-click="cargarEstimaciones()" ng-model="mostrarTodasEstimaciones" ng-init="mostrarTodasEstimaciones=false" />
</label>
<input type="text" ng-keyup="cargarEstimaciones()" ng-model="filtroEstimaciones" class="form-control right filtro" placeholder="Filtrar..." />
<div class="clear"></div>
<div id="tabla-user-estimacion">
    <table id="tabla-estimacion-ticket" class="table table-striped">
        <thead>
            <tr>
                <th width="5">Número Ticket</th>
                <th width="10">Cliente</th>
                <th width="10">Prioridad</th>
                <th width="35">Detalle</th>
                <th width="35">Fecha Límite</th>
                <th width="10">Estado Estimación</th>
                <th width="20">Adjuntos</th>
                <th width="5"></th>
            </tr>
        </thead>

        <tbody>
            <tr ng-repeat="estimacion in estimaciones" ng-dblclick="mostrarWindowEstimacion(estimacion.id)">
                <td>{{estimacion.ticket | rellenarIzq : 0}}</td>
                <td>{{estimacion.cliente}}</td>
                <td>{{estimacion.prioridad}}</td>
                <td>{{estimacion.detalle | strLimit: 25}}</td>
                <td>{{estimacion.fechaLimite | strDateToStr}}</td>
                <td>{{estimacion.estado}}</td>
                <td>
                    <a class="btn btn-success btn-xs" ng-repeat="adj in estimacion.adjuntos" target="_blank" href="Web{{adj.url}}">
                        <span class="glyphicon glyphicon-download"></span> Adjunto {{$index+1}}
                    </a>
                </td>
            </tr>
        </tbody>

        <tfoot>
            <tr>
                <th colspan="6">

                    <nav>
                        <ul class="pagination">
                            <li ng-click="atrazarPagina()">
                                <a href="#" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                            <li ng-repeat="pagina in listaPaginas" ng-click="cambiarPagina(pagina)"><a href="#">{{pagina}}</a></li>
                            <li ng-click="avanzarPagina()">
                                <a href="#" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </th>
            </tr>
        </tfoot>

    </table>
</div>

<!-- Modal de Estimacion del Ticket -->
<div class="modal fade" id="modal-estimacion-dev-ticket" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-final-tarea-label">
                    <span class="glyphicon glyphicon-time" aria-hidden="true"></span>
                    <span id="title-filter">Estimar Ticket</span>
                </h4>
            </div>
            <form method="post" id="frm-modal-estimar-ticket" ng-submit="estimarDesarrolloTicket()">
                <div class="modal-body" style="max-height: 768px; max-width: 1024px; overflow-y: auto">
                    <button type="button" class="btn btn-success btn-xs" ng-click="adicionarEntregable()">Añadir Entregable</button>
                    <button type="button" class="btn btn-success btn-xs" ng-click="adicionarItemsEspeciales()">Añadir Items Especiales</button>
                    <table id="tabla-estimacion-entregable-ticket" class="table">
                        <tr>
                            <th>
                                <text style="font-weight:bold">Total estimaciones:  {{tiempoTotal}}  </text>
                            </th>
                        </tr>
                        <tbody>
                            <tr ng-repeat="detalle in detallesEstimacion" ng-dblclick="editarEntregable(detalle.id)">
                                <td>
                                    <table class="table table-striped table-responsive table-hover">
                                        <thead>
                                            <tr><text style="font-weight:bold">Entregable  {{$index + 1}}:  </text>{{detalle.nombre}} </tr>
                                            <tr>
                                                <th>N°</th>
                                                <th>TAREA PROPUESTA</th>
                                                <th>TIPO RECURSO</th>
                                                <th>TIEMPO(H)</th>
                                                <th>TIEMPO(DES)</th>
                                                <th>Tiempo(PRU)</th>
                                                <th>Tiempo(QA)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="d in detalle.detalles">
                                                <td>TAR{{$index + 1}}</td>
                                                <td>{{d.detalle | strLimit: 25}}</td>
                                                <td>{{d.nivel}}</td>
                                                <td>{{d.tiempoDesarrollo + d.tiempoPrueba}}</td>
                                                <td>{{d.tiempoDesarrollo}}</td>
                                                <td>{{d.tiempoPrueba}}</td>
                                                <td>{{d.tiempoQA}}</td>
                                            </tr>
                                        </tbody>

                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <text style="font-weight:bold">Items Especiales</text>
                                    <table class="table table-striped">

                                        <thead>
                                            <tr>
                                                <th>N°</th>
                                                <th>Descripcion</th>
                                                <th>Tipo Recurso</th>
                                                <th>Tiempo Estimado</th>
                                                <th></th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            <tr class="table-tr" ng-repeat="item in items" data-id="{{ item.id }}" ng-dblclick="editarItem(item)">
                                                <td>T_ESP{{$index + 1}}</td>
                                                <td>{{ item.descripcion }}</td>
                                                <td>{{ item.recurso }}</td>
                                                <td>{{ item.tiempoEstimacion }}</td>
                                                <td><button type="button" class="btn btn-danger btn-xs" ng-click="eliminarItemEspecial(item.id)">Eliminar</button></td>
                                            </tr>
                                        </tbody>

                                    </table>
                                </td>
                            </tr>
                        </tbody>

                    </table>

                    <div class="row">
                        <div class="col-md-8">
                            <label style="display: inline-block">
                                <input ng-model="requerimientoNuevo" ng-click="changeRequerimientoNuevo()" type="checkbox" />
                                Es estimación requerimiento nuevo/es estimación de pegado
                            </label>
                        </div>

                        <div id="div-tiempo-incial" class="col-md-4">
                            <label style="display: inline-block">
                                <input ng-model="tiempoInicial" style="width:50%" type="number" />
                                Tiempo Inicial
                            </label>
                        </div>

                        <div id="div-tiempo-pegado" class="col-md-4">
                            <label style="display: inline-block">
                                <input ng-model="tiempoPegado" style="width:50%" type="number" />
                                Tiempo Pegado
                            </label>
                        </div>
                    </div>

                    <div style="display:none">
                        <label>Entregables Adicionales:</label>
                        <textarea class="form-control" ng-model="entregablesAdicionales"></textarea>
                    </div>

                    <div>
                        <label>Información Complementaria:</label>
                        <textarea class="form-control" ng-model="informacionComplementaria"></textarea>
                    </div>
                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-info left" ng-click="verInformacionTicket()">Ver Información del Ticket</button>
                    <button id="editarEstimacionTicket" type="button" class="btn btn-success" ng-click="editarEstimacion()" ng-show="edicionEstimacion">Editar</button>
                    <button type="submit" class="btn btn-primary">Finalizar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Actividades del Ticket -->
