<div id="modal-seleccionar-asistentes" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">CONVOCADO</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body" style="max-height: 400px; overflow-y: auto;">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="seleccionarTodos" ng-model="todosSeleccionados" ng-change="seleccionarTodosAsistentes()">
                    <label class="form-check-label" for="seleccionarTodos">Todos</label>
                </div>
                <table class="table table-striped table-condensed">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>PERSONAL SIFIZSOFT E INTESOFT</th>
                            <th>CONVOCADO</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="asistente in asistentesCapacitacion">
                            <td>{{$index + 1}}</td>
                            <td>{{asistente.nombre}}</td>
                            <td><input type="checkbox" ng-model="asistente.seleccionado"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-dismiss="modal">Aceptar</button>
            </div>
        </div>
    </div>
</div>

<div id="modal-seleccionar-asistentes-edicion" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">CONVOCADOS</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body" style="max-height: 400px; overflow-y: auto;">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="seleccionarTodos" ng-model="todosSeleccionadosEdicion" ng-change="seleccionarTodosAsistentesEdicion()">
                    <label class="form-check-label" for="seleccionarTodos">Todos</label>
                </div>
                <table class="table table-striped table-condensed">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>PERSONAL SIFIZSOFT E INTESOFT</th>
                            <th>CONVOCADO</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="asistente in datosAsistenciaEdicion">
                            <td>{{$index + 1}}</td>
                            <td>{{asistente.nombre}}</td>
                            <td><input type="checkbox" ng-model="asistente.asignado"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-dismiss="modal">Aceptar</button>
            </div>
        </div>
    </div>
</div>

