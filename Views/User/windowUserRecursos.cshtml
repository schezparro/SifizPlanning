<!--
<label style="display: inline-block">
    Mostrar Todas:
    <input style="vertical-align: -2px;" type="checkbox" ng-click="cargarRecursos()" ng-model="mostrarTodosRecursos" ng-init="mostrarTodosRecursos=false" />
</label>
 -->
@{
    bool esUserAllow = Roles.IsUserInRole("ADMIN") || Roles.IsUserInRole("OPERACIONES") || Roles.IsUserInRole("RRHH");
}

@if (Roles.IsUserInRole("ADMIN") || Roles.IsUserInRole("OPERACIONES") || Roles.IsUserInRole("RRHH"))
{
    <button class="btn btn-primary" ng-click="windowAgregarRecursos()">Agregar</button>
    <button class="btn btn-primary" ng-click="windowAgregarPlan()">Tema Reunión/Capacitación</button>
}
<input type="text" ng-keyup="cargarRecursos()" ng-model="filtroRecursos" class="form-control right filtro" placeholder="Filtrar..." />
<div class="clear"></div>
<label style="display: inline-block">
    Temas a capacitar:
    <input style="vertical-align: -2px;" type="checkbox" ng-click="cargarRecursos()" ng-model="esPlan" ng-init="esPlan=false" />
</label>
<div id="tabla-user-recursos">
    <table id="tabla-recursos-usuario" class="table table-striped table-condensed">
        <thead>
            <tr>
                <th>Título</th>
                <th>Detalle</th>
                <th>Fecha y Hora</th>
                <th>Modulo</th>
                <th ng-show="!esPlan">Url</th>
                <th>Link Meet</th>
                <th ng-show="!esPlan && esUserAllow">Registro Asistencia</th>
                <th ng-show="esPlan && esUserAllow">Asistencia</th>
                <th>Duración</th>
                <th ng-show="!esPlan">Certificado</th>
            </tr>
        </thead>

        <tbody>
            <tr ng-repeat="recurso in recursos | filter: filtroRecursos" ng-dblclick="mostrarDetalleRecurso(recurso.secuencial)">
                <td>{{recurso.titulo | limitTo:100}}</td>
                <td>{{recurso.detalle | limitTo:100}}</td>
                <td>{{recurso.fecha | strDateToStrTime}}</td>
                <td>{{ recurso.modulo === 'N//A' ? 'Otros' : recurso.modulo }}</td>
                <td ng-show="!esPlan">
                    <div ng-if="!recurso.editandoUrl" style="display: inline-flex; align-items: center;">
                        <a class="btn btn-success btn-xs" target="_blank" href="{{recurso.adjunto}}" ng-show="recurso.adjunto != ''">
                            <span class="glyphicon glyphicon-link"></span> Url
                        </a>
                        <button class="btn btn-warning btn-xs" ng-click="editarUrl(recurso)" style="margin-left: 5px;" ng-if="esUserAllow">
                            <span class="glyphicon glyphicon-pencil"></span>
                        </button>
                    </div>
                    <div ng-if="recurso.editandoUrl && esUserAllow" style="display: inline-flex; align-items: center;">
                        <input type="text" class="form-control" ng-model="recurso.adjunto" style="flex-grow: 1; margin-right: 5px;" />
                        <button class="btn btn-success btn-xs" ng-click="guardarUrl(recurso)" style="margin-right: 5px;">
                            <span class="glyphicon glyphicon-ok"></span>
                        </button>
                        <button class="btn btn-danger btn-xs" ng-click="cancelarEdicionUrl(recurso)">
                            <span class="glyphicon glyphicon-remove"></span>
                        </button>
                    </div>
                </td>
                <td>
                    <a href="{{recurso.url}}" target="_blank">{{recurso.url}}</a>
                </td>
                <td ng-show="!esPlan && esUserAllow">
                    <a class="btn btn-primary btn-xs" ng-click="mostrarRegistroAsistencia(recurso)">
                        <span class="glyphicon glyphicon-calendar"></span> Registro Asistencia
                    </a>
                </td>
                <td ng-show="esPlan && esUserAllow">
                    <a class="btn btn-primary btn-xs" ng-click="mostrarRegistroConvocados(recurso)">
                        <span class="glyphicon glyphicon-calendar"></span> Convocados/Asignados
                    </a>
                </td>

                <td>{{recurso.tiempo | toHoursAndMinutes}}</td>
                <td ng-show="!esPlan">
                    <button class="btn btn-sm btn-link" ng-show="recurso.darCertificado" ng-click="generarCertificado(recurso)">Descargar</button>
                    <div ng-show="!recurso.darCertificado">NO TIENE</div>
                </td>
            </tr>
        </tbody>

        <tfoot>
            <tr>
                <th colspan="6">
                    <nav>
                        <ul class="pagination">
                            <li ng-click="atrazarPagina()">
                                <a href="#" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                            <li ng-repeat="pagina in listaPaginas" ng-click="cambiarPagina(pagina)"><a href="#">{{pagina}}</a></li>
                            <li ng-click="avanzarPagina()">
                                <a href="#" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </th>
            </tr>
        </tfoot>

    </table>
</div>


<div id="modal-agregar-recursos" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form ng-submit="GuardarNuevoRecurso()" name="nuevoRecurso">
                <div class="modal-header">
                    <h5 class="modal-title">REUNION/CAPACITACION</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">

                    <div class="form-group">
                        <label for="inputTitulo">TÍTULO:</label>
                        <input type="text" class="form-control" ng-model="newTitulo" ng-required="true" placeholder="Título">
                    </div>

                    <div class="form-group">
                        <label for="inputDetalle">DETALLE:</label>
                        <textarea type="text" class="form-control" ng-model="newDetalle" ng-required="true" rows="3"></textarea>
                    </div>


                    <div class="form-group">
                        <label for="inputModulo">MÓDULO:</label>
                        <select id="select-modulo-recursos" ng-model="moduloSeleccionado" class="form-control" required="required">
                            <option value="">Seleccione...</option>
                            <option value="{{tipo.id}}" ng-repeat="tipo in tipoModulo">
                                {{ tipo.nombre === 'N//A' ? 'Otros' : tipo.nombre }}
                            </option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="inputArchivo">URL:</label>
                        <input type="text" class="form-control" ng-model="url" ng-required="true" placeholder="Url">
                        <span style="color: red;" ng-show="urlNoValida">La URL no es válida.</span>
                    </div>

                    <div class="form-group">
                        <label for="inputDetalle">LINK MEET:</label>
                        <input type="text" class="form-control" ng-model="link" ng-required="true"></>
                    </div>

                    <div class="form-group">
                        <button type="button" id="abrir-modal-registro-asistencia" ng-click="abrirRegistroAsistencia()" class="btn btn-primary">Convocados/Asignados</button>
                    </div>

                    <div class="form-group">
                        <label for="inputFechaHora">FECHA Y HORA DE INICIO:</label>
                        <input type="datetime-local" class="form-control" id="inputFechaHora" ng-model="fechaHora" ng-required="true">
                    </div>

                    <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
                        <label>DURACION:</label>
                        <input type="number" class="form-control" ng-model="horas" ng-required="true" style="width:10%; text-align:center;" min="0">
                        horas
                        :
                        <input type="number" class="form-control" ng-model="minutos" ng-required="true" style="width: 10%; text-align: center;" min="0" max="60">
                        minutos
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" id="enviar-modal-recursos-btn" class="btn btn-primary">Guardar</button>
                    <button class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="modal-agregar-plan" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form ng-submit="GuardarNuevoPlan()" name="nuevoPlan">
                <div class="modal-header">
                    <h5 class="modal-title">TEMA A CAPACITAR</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="inputTitulo">TÍTULO:</label>
                        <input type="text" class="form-control" ng-model="newTituloPlan" ng-required="true" placeholder="Título">
                    </div>
                    <div class="form-group">
                        <label for="inputDetalle">DETALLE:</label>
                        <textarea type="text" class="form-control" ng-model="newDetallePlan" ng-required="true" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="inputModulo">MÓDULO:</label>
                        <select id="select-modulo-plan" ng-model="moduloSeleccionadoPlan" class="form-control" required="required">
                            <option value="">Seleccione...</option>
                            <option value="{{tipo.id}}" ng-repeat="tipo in tipoModulo">
                                {{ tipo.nombre === 'N//A' ? 'Otros' : tipo.nombre }}
                            </option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="fecha-hora-capacitacion">FECHA Y HORA</label>
                        <div class='input-group date'>
                            <input id="fecha-hora-capacitacion"
                                   type="datetime-local"
                                   ng-model="fechaHoraCapacitacion"
                                   class="form-control"
                                   ng-required="true"
                                   min="{{currentDate | date:'yyyy-MM-ddTHH:mm'}}"
                                   step="60" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="inputLink">LINK MEET:</label>
                        <input type="text" class="form-control" ng-model="linkPlan" ng-required="true"></>
                    </div>
                    <div class="form-group">
                        <label for="inputModulo">CAPACITADOR:</label>
                        <select id="select-capacitador-plan" ng-model="capacitadorSeleccionadoPlan" class="form-control" required="required">
                            <option value="">Seleccione...</option>
                            <option value="{{capacitador.id}}" ng-repeat="capacitador in capacitadores">{{capacitador.nombre}}</option>
                        </select>
                    </div>
                    <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
                        TIEMPO:
                        <input type="number" class="form-control" ng-model="horasPlan" ng-required="true" style="width:10%; text-align:center;" min="0">
                        horas
                        :
                        <input type="number" class="form-control" ng-model="minutosPlan" ng-required="true" style="width: 10%; text-align: center;" min="0" max="60">
                        minutos
                    </div>
                    <div class="form-group">
                        <button type="button" class="btn btn-primary" ng-click="abrirModalSeleccionarAsistentes()">Convocados</button>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <button class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

