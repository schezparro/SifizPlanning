                            <option value="{{capacitador.id}}" ng-repeat="capacitador in capacitadores">{{capacitador.nombre}}</option>
                        </select>
                    </div>
                    <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
                        TIEMPO:
                        <input type="number" class="form-control" ng-model="editHorasPlan" ng-required="true" style="width:10%; text-align:center;" min="0">
                        horas
                        :
                        <input type="number" class="form-control" ng-model="editMinutosPlan" ng-required="true" style="width: 10%; text-align: center;" min="0" max="60">
                        minutos
                    </div>
                    <div class="form-group">
                        <button type="button" class="btn btn-primary" ng-click="abrirModalSeleccionarAsistentesEdicion()">Convocados</button>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <button class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Informe -->
<div class="modal fade" id="modal-asistencia-recurso" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="padding: 10px, 10px">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 ng-show="!esPlan" class="modal-title"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Registro de asistencia </h4>
                <h4 ng-show="esPlan" class="modal-title"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Convocados/asignados </h4>
            </div>

            <div class="modal-body" style="max-height: calc(100vh - 210px); overflow-y: auto;">
                <div id="div-user-informe-proyecto">
                    <table id="tabla-registro-asistencia" class="table table-striped table-condensed">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>PERSONAL SIFIZSOFT E INTESOFT</th>
                                <th ng-show="!esPlan">ASISTENCIA</th>
                                <th ng-show="!esPlan">PUNTUACIÓN</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Roles.IsUserInRole("ADMIN") || Roles.IsUserInRole("RRHH"))
                            {
                                <tr ng-repeat="item in getDatosAsistenciaFiltrados() track by $index">
                                    <td>{{$index + 1}}</td> <!-- Autoincremental -->
                                    <td>{{item.nombre}}</td> <!-- Nombre del colaborador -->
                                    <td ng-show="!esPlan"><input type="checkbox" ng-model="item.asistencia"></td> <!-- Checkbox para asistencia -->
                                    <td ng-show="!esPlan"><input type="number" ng-model="item.puntuacion" min="0" max="5"></td> <!-- Input para puntuación -->
                                    <td ng-show="!esPlan"><input type="hidden" value="{{item.id}}"></td> <!-- Campo oculto con el ID -->
                                </tr>
                            }
                            else
                            {
                                <tr ng-repeat="item in getDatosAsistenciaFiltrados() track by $index">
                                    <td>{{$index + 1}}</td> <!-- Autoincremental -->
                                    <td>{{item.nombre}}</td> <!-- Nombre del colaborador -->
                                    <td ng-show="!esPlan"><input type="checkbox" ng-disabled="true" ng-model="item.asistencia"></td> <!-- Checkbox para asistencia -->
                                    <td ng-show="!esPlan"><input type="number" ng-disabled="true" ng-model="item.puntuacion" min="0" max="5"></td> <!-- Input para puntuación -->
                                    <td ng-show="!esPlan"><input type="hidden" value="{{item.id}}"></td> <!-- Campo oculto con el ID -->
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                @if (Roles.IsUserInRole("ADMIN") || Roles.IsUserInRole("RRHH"))
                {
                    <button ng-show="!esPlan" type="button" id="guardar-registro" ng-click="registrarAsistencia()" class="btn btn-primary">Guardar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                }
                else
                {
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                }
            </div>
        </div>
    </div>
</div>


