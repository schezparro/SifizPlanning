<div>
    <div class="form-inline">
        <input type="text" class="form-control" ng-model="filterPublicaciones" placeholder="Filtrar..." />

        @*<button class="right btn btn-danger btn-sm"><span class="glyphicon glyphicon-remove"></span> Limpiar Selección</button>
            <div class="right">&nbsp;</div>*@
        <button class="right btn btn-primary btn-sm" ng-click="seleccionarPublicarEnUno()"><span class="glyphicon glyphicon-ok"></span> Publicados en 1</button>

        <div class="clear"></div>
    </div>
    <div>
        <table id="tabla-publicaciones" class="table">
            <thead>
                <tr>
                    <th>No. Ticket</th>
                    <th>Cliente</th>
                    <th>Colaborador Asignado</th>
                    <th>Estado Ticket</th>
                    <th>Categoría</th>
                    <th>Prioridad</th>
                    <th>Asunto</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr class="fila-publicacion" ng-repeat="ticket in $parent.ticketsPorPublicar | filter: filterPublicaciones" data-id="{{ticket.idTicket}}">
                    <td>{{ticket.idTicket}}</td>
                    <td>{{ticket.cliente}}</td>
                    <td>{{ticket.asignado}}</td>
                    <td>{{ticket.estadoTicket}}</td>
                    <td>{{ticket.categoria}}</td>
                    <td>{{ticket.prioridad}}</td>
                    <td>{{ticket.asunto}}</td>
                    <td>
                        <button type="button" class="btn btn-xs btn-success" ng-click="seleccionarParaPublicar(ticket.idTicket)"><span class="glyphicon glyphicon-ok"></span> publicado</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="modal fade" id="modal-enviar-publicacion" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="myModalLabel">Parámetros de Publicación</h4>
                </div>
                <form ng-submit="publicacionRealizada()">
                    <div class="modal-body">
                        <div style="display: flex;">
                            <div style="flex: 1; padding-right: 10px;">
                                <div>
                                    <label for="titulo">Título:</label>
                                    <input type="text" class="form-control" ng-model="titulo" required>
                                </div>

                                <div>
                                    <label>Publicar Cliente:</label>
                                    <input type="checkbox" ng-model="publicarCliente"><br>
                                </div>

                                <div ng-show="publicarCliente">
                                    <label>Actualizar Distribuidos:</label>
                                    <input type="checkbox" ng-model="actualizarDistribuidos"><br>
                                </div>

                                <div>
                                    <label>Publicar Servidor:</label>
                                    <input type="checkbox" ng-model="publicarServidor"><br>
                                </div>

                                <div ng-show="publicarServidor">
                                    <label>Servicios a actualizar:</label>
                                    <textarea type="text" class="form-control" ng-model="serviciosAActualizar"></textarea>
                                </div>

                                <div>
                                    <label>Actualizar Base de Datos:</label>
                                    <input type="checkbox" ng-model="actualizarDB"><br>
                                </div>

                                <div ng-show="actualizarDB">
                                    ADJUNTO:
                                    <div id="panel-adjunto-publicacion"></div>
                                </div>
                            </div>

                            <div style="flex: 1; padding-left: 10px;">
                                <div>
                                    <label>Tipo de publicación:</label>
                                    <select class="form-control" ng-model="tipoPublicacion" ng-required="1">
                                        <option value="Cliente/Servidor">Cliente/Servidor</option>
                                        <option value="Cliente">Cliente</option>
                                        <option value="Servidor">Servidor</option>
                                        <option value="Servidor">Sitio Web</option>
                                    </select>
                                </div>

                                <div>
                                    <label>Objetivo de publicación:</label>
                                    <select class="form-control" ng-model="objetivoPublicacion" ng-required="1">
                                        <option value="pruebas">Pruebas</option>
                                        <option value="producción">Producción</option>
                                    </select>
                                </div>

                                <div>
                                    <label>FTP:</label>
                                    <input class="form-control" ng-model="ftpPublicacion" ng-required="1" />
                                </div>

                                <div>
                                    <label>Usuario:</label>
                                    <input class="form-control" ng-model="usuarioFtp" ng-required="1" />
                                </div>
                                <div>
                                    <label>Clave:</label>
                                    <input class="form-control" ng-model="claveFtp" ng-required="1" />
                                </div>

                                <div>
                                    <label>Path:</label>
                                    <input class="form-control" ng-model="pathPublicacion" ng-required="1" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal"><span class="glyphicon glyphicon-remove"></span> Cerrar</button>
                        <button type="submit" class="btn btn-primary"><span class="glyphicon glyphicon-envelope"></span> Enviar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
