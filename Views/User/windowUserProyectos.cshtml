                            <label class="label-data-proyecto">Versión Base de Datos: </label><span>  {{versionBD}}</span><br />
                            <label class="label-data-proyecto">Tiene código fuente: </label><span>  {{tieneSolucionProxies}}</span><br />
                            <label class="label-data-proyecto">Lider del Proyecto: </label><span>  {{lider}}</span><br />
                            <label class="label-data-proyecto">Gestor del Servicio: </label><span>  {{gestor}}</span><br />
                            <label class="label-data-proyecto">Fecha salida a producción: </label><span>  {{fechaProduccion}}</span><br />

                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Etapas -->
<div class="modal fade" id="modal-etapas-proyecto" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" style="overflow:hidden">
            <div class="modal-header" style="padding: 10px, 10px">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Gestión de etapas de proyecto </h4>
            </div>

            <div class="modal-body">
                <div style="padding: 10px, 10px">
                    <button class="btn btn-primary" ng-click="windowAgregarEtapasProyecto(proyectoId)">Nueva Etapa</button>
                    <input type="text" ng-keyup="cargarEtapas()" ng-model="filtroEtapas" class="form-control right filtro" placeholder="Filtrar..." />
                    <div class="clear"></div>
                </div>

                <div id="div-user-etapas-proyectos">
                    <table id="tabla-user-etapas-proyectos" class="table table-striped table-condensed table-sm">
                        <thead>
                            <tr>
                                <th>Descripción</th>
                                <th>Duración</th>
                                <th>Fecha Inicio</th>
                                <th>Fecha Fin</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr ng-repeat="etapa in etapas" ng-dblclick="editarEtapasProyectos(etapa)">
                                <td>{{etapa.descripcion | strLimit: 75}}</td>
                                <td>{{etapa.duracion}}</td>
                                <td>{{etapa.fechaInicio}}</td>
                                <td>{{etapa.fechaFin}}</td>
                                <td>
                                    <button type="button" class="btn btn-xs btn-success" ng-click="abrirModalAgregarSubTarea(etapa)"><span class="glyphicon glyphicon-ok"></span> Agregar Subetapa</button>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-xs btn-danger" ng-click="EliminarEtapaProyecto(etapa.id)"><span class="glyphicon glyphicon-ok"></span> Eliminar </button>
                                </td>
                            </tr>
                        </tbody>

                        <tfoot>
                            <tr>
                                <th colspan="10">

                                    <nav>
                                        <ul class="pagination">
                                            <li ng-click="atrazarPaginaEtapas()">
                                                <a href="#" aria-label="Previous">
                                                    <span aria-hidden="true">&laquo;</span>
                                                </a>
                                            </li>
                                            <li ng-repeat="pagina in listaPaginasE" ng-click="cambiarPaginaEtapas(pagina)"><a href="#">{{pagina}}</a></li>
                                            <li ng-click="avanzarPaginaEtapas()">
                                                <a href="#" aria-label="Next">
                                                    <span aria-hidden="true">&raquo;</span>
                                                </a>
                                            </li>
                                        </ul>
                                    </nav>

                                </th>
                            </tr>
                        </tfoot>

                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
</div>

