<!-- Modal Informe -->
<div class="modal fade" id="modal-informe-proyecto" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="padding: 10px, 10px">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Gestión de etapas de proyecto </h4>
            </div>

            <div class="modal-body" style="max-height: calc(100vh - 210px); overflow-y: auto;">

                <div id="div-user-informe-proyecto">
                    <table id="tabla-user-informe-proyecto" class="table table-striped">
                        <thead>
                            <tr>
                                <th><input type="checkbox" ng-model="selectAll" ng-click="toggleAll()"></th>
                                <th>Descripción</th>
                                <th>Duración</th>
                                <th>Fecha Inicio</th>
                                <th>Fecha Fin</th>
                                <th>Recurso</th>
                                <th>% Cumplimiento</th>
                                <th>Detalle</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr ng-repeat="item in datosInforme" ng-style="item.tipo === 'etapa' ? {'background-color': '#d0e0f0'} : item.tipo === 'subetapa' ? {'padding-left': '30px'} : {}" ng-class="{'etapa-row': item.tipo === 'etapa', 'subetapa-row': item.tipo === 'subetapa'}"
                                ng-dblclick="abrirModalEditarItem(item)">
                                <td ng-if="item.tipo === 'etapa'">
                                    <input type="checkbox" ng-model="item.selected" ng-checked="item.selected" ng-click="toggleEtapas(item)">
                                </td>
                                <td ng-if="item.tipo === 'etapa'">{{item.descripcion | strLimit: 75}}</td>
                                <td ng-if="item.tipo === 'etapa'">{{item.duracion}}</td>
                                <td ng-if="item.tipo === 'etapa'">{{item.fechaInicio}}</td>
                                <td ng-if="item.tipo === 'etapa'">{{item.fechaFin}}</td>
                                <td ng-if="item.tipo === 'etapa'"></td>
                                <td ng-if="item.tipo === 'etapa'">{{item.porciento}}</td>
                                <td ng-if="item.tipo === 'etapa'">{{item.detalle | strLimit: 75}}</td>
                                <td ng-if="item.tipo === 'etapa'">
                                    <span ng-style="getSemaforoStyle(item)" style="display: inline-block;"></span>
                                </td>

                                <td ng-if="item.tipo === 'subetapa'">
                                    <input type="checkbox" ng-model="item.selected" ng-checked="item.selected" ng-click="toggleSubEtapas(item)">
                                </td>
                                <td ng-if="item.tipo === 'subetapa'">{{item.descripcion | strLimit: 75}}</td>
                                <td ng-if="item.tipo === 'subetapa'">{{item.duracion}}</td>
                                <td ng-if="item.tipo === 'subetapa'">{{item.fechaInicio}}</td>
                                <td ng-if="item.tipo === 'subetapa'">{{item.fechaFin}}</td>
                                <td ng-if="item.tipo === 'subetapa'">{{item.recurso}}</td>
                                <td ng-if="item.tipo === 'subetapa'">{{item.porciento}}</td>
                                <td ng-if="item.tipo === 'subetapa'">{{item.detalle | strLimit: 75}}</td>
                                <td ng-if="item.tipo === 'subetapa'">
                                    <span ng-style="getSemaforoStyle(item)" style="display: inline-block;"></span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="previsualizar-informe-btn" ng-click="PrevisualizarInforme()" class="btn btn-primary">Previsualizar Informe</button>
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal editar fila reporte, etapa -->
<div id="modal-editar-etapas-proyecto" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form ng-submit="GuardarValor('etapa')">
                <div class="modal-header" style="padding: 10px, 10px">
                    <label>EDITANDO ETAPA</label>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <!-- Sección de Etapa -->
                    <div>
                        <input hidden ng-model="proyectoIdInfo" />

                        <label for="select-etapas-cliente-proyecto">ETAPA:</label>
                        <select id="select-etapas-cliente-proyecto-info" ng-model="etapasProInfo" class="form-control" required="required">
                            <option value="">Seleccione...</option>
                            <option value="{{etapa.id}}" ng-repeat="etapa in etapasCat">{{etapa.nombre}}</option>
                        </select>

                        <div style="column-count: 2">
                            <div class="div-info-ticket">
                                <label for="fecha-inicio-etapa">FECHA INICIO:</label>
                                <div class='input-group date'>
                                    <input id="fecha-inicio-etapa-info" ng-model="fechaIniEtaInfo" class="form-control" ng-required="true" autocomplete="off" />
                                </div>
                            </div>

                            <div class="div-info-ticket">
                                <label for="fecha-fin-etapa">FECHA FIN:</label>
                                <div class='input-group date'>
                                    <input id="fecha-fin-etapa-info" ng-model="fechaFinEtaInfo" class="form-control" ng-required="true" autocomplete="off" />
                                </div>
                            </div>
                        </div>

                        <div class="div-info-ticket">
                            <label for="porcentaje-etapa">PORCENTAJE:</label>
                            <input id="porcentaje-etapa-info" type="number" ng-model="porcentajeEtaInfo" class="form-control" ng-required="true" min="0" max="100" step="1" />
                        </div>

                        <div class="div-info-ticket">
                            <label for="detalle-etapa">DETALLE:</label>
                            <textarea id="detalle-etapa-info" ng-model="detalleEtaInfo" class="form-control" ng-required="true" rows="3"></textarea>
                        </div>
                    </div>
                    <!-- Fin de la sección de Etapa -->
                </div>
                <div class="modal-footer">
                    <button type="submit" id="enviar-modal-etapas-info-btn" class="btn btn-primary">Guardar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal editar fila reporte, subetapa -->
<div id="modal-agregar-subetapas-proyecto" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form ng-submit="GuardarValor('subetapa')">
                <div class="modal-header" style="padding: 10px, 10px">
                    <label>EDITANDO SUBETAPA</label>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <div>
                        <input hidden ng-model="proyectoIdInfo" />
                        <input hidden ng-model="etapaId" />
                        <label for="textarea-descripcion">DESCRIPCION:</label>
                        <textarea type="text" class="form-control" ng-model="descripcionSubEInfo" ng-required="true"></textarea>

                        <label for="select-recursos-sub-etapas">RECURSO:</label>
                        <select id="select-recursos-sub-etapas-info" ng-model="recursosSubEInfo" class="form-control" required="required">
                            <option value="">Seleccione...</option>
                            <option value="{{recurso.id}}" ng-repeat="recurso in recursosSubEtapas">{{recurso.nombre}}</option>
                        </select>

                        <div style="column-count: 2">
                            <div class="div-info-ticket">
                                <label for="fecha-inicio-subetapa-info">FECHA INICIO:</label>
                                <div class='input-group date'>
                                    <input id="fecha-inicio-subetapa-info" ng-model="fechaIniSubEInfo" class="form-control" ng-required="true" autocomplete="off" ng-change="updateMinDateSubEtapa()" />
                                </div>
                            </div>

                            <div class="div-info-ticket">
                                <label for="fecha-fin-subetapa-info">FECHA FIN:</label>
                                <div class='input-group date'>
                                    <input id="fecha-fin-subetapa-info" ng-model="fechaFinSubEInfo" class="form-control" ng-required="true" autocomplete="off" ng-change="updateMinDateSubEtapa()" />
                                </div>
                            </div>
                        </div>

                        <div class="div-info-ticket">
                            <label for="porcentaje-subetapa">PORCENTAJE:</label>
                            <input id="porcentaje-subetapa-info" type="number" ng-model="porcentajeSubEInfo" class="form-control" ng-required="true" min="0" max="100" step="1" />
                        </div>

                        <div class="div-info-ticket">
                            <label for="detalle-subetapa">DETALLE:</label>
                            <textarea id="detalle-subetapa-info" ng-model="detalleSubEInfo" class="form-control" ng-required="true" rows="3"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" id="enviar-modal-subetapas-btn" class="btn btn-primary">Guardar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="cronogramaModal" tabindex="-1" role="dialog" aria-labelledby="cronogramaModalLabel">
    <div class="modal-dialog" role="document" style="width: 80%; max-width: 90%; margin: auto;">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="cronogramaModalLabel">Cronograma del Proyecto</h4>
            </div>
            <div class="modal-body" style="max-height: calc(100vh - 210px); overflow-y: auto;">
                <input hidden ng-model="proyectoIdInfo" />
                <table id="tabla-cronograma-proyecto" class="table table-striped" style="width: 100%;">
                    <thead>
                        <tr>
                            <th>Descripción</th>
                            <th>Duración</th>
                            <th>Fecha Inicio</th>
                            <th>Fecha Fin</th>
                            <th>Recurso</th>
                            <th>% Cumplimiento</th>
                            <th>Detalle</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="item in datosCronograma" ng-style="item.tipo === 'etapa' ? {'background-color': '#d0e0f0', 'font-weight': 'bold'} : {}" ng-class="{'etapa-row': item.tipo === 'etapa', 'subetapa-row': item.tipo === 'subetapa'}">
                            <td ng-if="item.tipo === 'etapa'">{{item.descripcion | strLimit: 75}}</td>
                            <td ng-if="item.tipo === 'etapa'">{{item.duracion}}</td>
                            <td ng-if="item.tipo === 'etapa'">{{item.fechaInicio}}</td>
                            <td ng-if="item.tipo === 'etapa'">{{item.fechaFin}}</td>
                            <td ng-if="item.tipo === 'etapa'"></td>
                            <td ng-if="item.tipo === 'etapa'">{{item.porciento}}</td>
                            <td ng-if="item.tipo === 'etapa'">{{item.detalle}}</td>
                            <td ng-if="item.tipo === 'etapa'">
                                <span ng-style="getSemaforoStyle(item)" style="display: inline-block;"></span>
                            </td>

                            <td ng-if="item.tipo === 'subetapa'" ng-style="{'padding-left': '30px'}">{{item.descripcion | strLimit: 75}}</td>
                            <td ng-if="item.tipo === 'subetapa'">{{item.duracion}}</td>
                            <td ng-if="item.tipo === 'subetapa'">{{item.fechaInicio}}</td>
                            <td ng-if="item.tipo === 'subetapa'">{{item.fechaFin}}</td>
                            <td ng-if="item.tipo === 'subetapa'">{{item.recurso}}</td>
                            <td ng-if="item.tipo === 'subetapa'">{{item.porciento}}</td>
                            <td ng-if="item.tipo === 'subetapa'">{{item.detalle}}</td>
                            <td ng-if="item.tipo === 'subetapa'">
                                <span ng-style="getSemaforoStyle(item)" style="display: inline-block;"></span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">

                <button type="button" id="enviar-informe-btn" class="btn btn-success">Enviar por correo</button>
                <button type="button" class="btn btn-primary" ng-click="generarInforme()">Exportar</button>
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Tiempos Proyecto -->
<div class="modal fade" id="modal-tiempos-proyecto" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true" >
    <div class="modal-dialog modal-lg" modal-fullscreen" role="document" style="width: 100%; height: 100%; margin: 0; padding: 0; max-width: none;" role="document">
        <div class="modal-content" style="overflow:hidden">
            <div class="modal-header" style="padding: 10px, 10px">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"><span class="glyphicon glyphicon-time" aria-hidden="true"></span> Gestión de tiempos del proyecto </h4>
            </div>

            <div class="modal-body">             
                <div class="panel-body" style="max-height: 490px; overflow-y: auto;">
                    <input hidden ng-model="projId" />
                    <input type="text" ng-model-options='{ debounce: 1000 }' ng-change="cargarTiemposProyecto()" ng-model="filtroTiempos" class="form-control right filtro" placeholder="Filtrar..." />
                    <table id="tabla-tiempos-proyecto" class="table table-striped table-hover table-condensed" style=" width: 100% ">
                        <thead>
                            <tr>
                                <th width="150px">Servicio</th>
                                <th width="100px">Horas Servicio</th>
                                <th width="150px">R/P</th>
                                <th width="100px">Horas Consumidas</th>
                                <th >Detalle</th>
                                <th width="150px">Colaborador</th>
                                <th width="150px">Fecha</th>
                            </tr>
                        </thead>
                        <tfoot>
                            <tr>
                                <th colspan="9">
                                    <div class="padding-lr-10">
                                        <div class="left">
                                            <nav>
                                                <ul class="pagination">
                                                    <li ng-click="atrazarPagina()">
                                                        <a href="#" aria-label="Previous">
                                                            <span aria-hidden="true">&laquo;</span>
                                                        </a>
                                                    </li>
                                                    <li ng-repeat="pagina in listaPaginasTiempos" ng-click="cambiarPagina(pagina)"><a href="#">{{pagina}}</a></li>
                                                    <li ng-click="avanzarPagina()">
                                                        <a href="#" aria-label="Next">
                                                            <span aria-hidden="true">&raquo;</span>
                                                        </a>
                                                    </li>
                                                </ul>
                                            </nav>
                                        </div>

                                        <div class="left form-inline gestion-lista-ticket" ng-init="cantidadMostrarPorPagina = 10" style="padding: 22px 0px 0px 0px">
                                            <label>Cantidad Por Página:</label>
                                            <select class="form-control" ng-model="cantidadMostrarPorPagina" ng-change="actualizarCantidadMostrar()">
                                                <option value="10">10</option>
                                                <option value="20">20</option>
                                                <option value="50">50</option>
                                                <option value="100">100</option>
                                            </select>
                                        </div>

                                        <div class="right gestion-lista-ticket" style="padding: 22px 0px 0px 0px">
                                            <div>
                                                <label>Total de Páginas: </label>{{cantPaginasTiempos}}
                                            </div>
                                        </div>
                                        <div class="right gestion-lista-ticket" style="padding: 22px 0px 0px 0px">
                                            <div>
                                                <label>Total de Ofertas: </label>{{totalTiempos}}
                                            </div>
                                        </div>

                                        <div class="clear"></div>
                                    </div>
                                </th>
                            </tr>
                        </tfoot>
                        <tbody>
                            <tr>                               
                                <td>
                                    <select id="catalogo-servicio" ng-class="'form-control'" ng-model="nuevoTiempo.catalogoServicio" ng-options="servicio.id as (servicio.descripcion | limitTo: 30) for servicio in servicios">
                                        <option value="">Seleccione...</option>
                                    </select>
                                </td>
                                <td>
                                    <input id="hora-servicio" ng-class="'form-control'" type="number" ng-model="nuevoTiempo.horasServicio">
                                </td>
                                <td>
                                    <select id="RP" ng-class="'form-control'" ng-model="nuevoTiempo.Rp">
                                        <option value="">Seleccione...</option>
                                        <option value="R">R</option>
                                        <option value="P">P</option>
                                    </select>
                                </td>
                                <td>
                                    <input id="horas-consumidas" ng-class="'form-control'" type="number" ng-model="nuevoTiempo.horasConsumidas">
                                </td>
                                <td>
                                    <input id="detalle-nuevo-tiempo" ng-class="'form-control'" type="text" ng-model="nuevoTiempo.detalle">
                                </td>
                                <td>
                                    <select id="colaborador-nuevo-tiempo" ng-class="'form-control'" ng-model="nuevoTiempo.colaborador" ng-options="colaborador.id as (colaborador.nombre | limitTo: 30) for colaborador in colaboradores">
                                        <option value="">Seleccione...</option>
                                    </select>
                                </td>
                                <td>
                                    <input id="fecha-registro" ng-class="'form-control'" ng-model="nuevoTiempo.fechaRegistro">
                                </td>

                                <td>
                                    <Button class="form-control btn btn-primary" ng-click="agregarTiempos()">Añadir</Button>
                                </td>
                            </tr>
                            <tr ng-repeat="tiempo in tmpProyecto">
                                <td hidden>
                                    <input type="text" ng-model="tiempo.id">
                                </td>
                                <td>
                                    <span ng-hide="tiempo.editable">{{ tiempo.servicio.descripcion}}</span>
                                    <select id="catalogo-servicio-tiempo" ng-class="'form-control'" ng-show="tiempo.editable" ng-model="tiempo.servicio.id" ng-options="servicio.id as (servicio.descripcion | limitTo: 30) for servicio in servicios"></select>
                                </td>
                                <td>
                                    <span ng-hide="tiempo.editable">{{ tiempo.horasServicio}}</span>
                                    <input id="hora-servicio-tiempo" ng-class="'form-control'" type="number" ng-show="tiempo.editable" ng-model="tiempo.horasServicio">
                                </td>
                                <td>
                                    <span ng-hide="tiempo.editable">{{ tiempo.rp}}</span>
                                    <select id="RP-tiempo" ng-class="'form-control'" ng-show="tiempo.editable" ng-model="tiempo.rp">
                                        <option value="">Seleccione...</option>
                                        <option value="R">R</option>
                                        <option value="P">P</option>
                                    </select>
                                </td>
                                <td>
                                    <span ng-hide="tiempo.editable">{{ tiempo.horasConsumidas}}</span>
                                    <input id="horas-consumidas-tiempo" ng-class="'form-control'" type="number" ng-show="tiempo.editable" ng-model="tiempo.horasConsumidas">
                                </td>
                                <td>
                                    <span ng-hide="tiempo.editable">{{ tiempo.detalle}}</span>
                                    <input id="detalle-tiempo" ng-class="'form-control'" type="text" ng-show="tiempo.editable" ng-model="tiempo.detalle">
                                </td>
                                <td>
                                    <span ng-hide="tiempo.editable">{{ tiempo.colaborador.nombre}}</span>
                                    <select id="colaborador-tiempo" ng-class="'form-control'" ng-show="tiempo.editable" ng-model="tiempo.colaborador.id" ng-options="colaborador.id as (colaborador.nombre | limitTo: 30) for colaborador in colaboradores"></select>
                                </td>
                                <td>
                                    <span ng-hide="tiempo.editable">{{ tiempo.fechaRegistro | strDateToStr}}</span>
                                    <input id="fecha-registro-{{$index}}" ng-class="'form-control'" ng-model="tiempo.fechaRegistro" ng-show="tiempo.editable">
                                </td>
                                <td>
                                    <span style="margin-right: 10px;" ng-click="editarTiemposProyecto(tiempo, $index)" ng-hide="tiempo.editable">
                                        <i class="glyphicon glyphicon-pencil"></i>
                                    </span>
                                    <span style="margin-right: 10px;" ng-click="guardarCambiosTiempo(tiempo)" ng-show="tiempo.editable">
                                        <i class="glyphicon glyphicon-floppy-disk"></i>
                                    </span>
                                    <span style="margin-right: 10px;" ng-click="eliminarTiemposProyecto(tiempo.id)" ng-hide="oferta.editable">
                                        <i class="glyphicon glyphicon-trash"></i>
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
       </div>
   </div>
</div>


