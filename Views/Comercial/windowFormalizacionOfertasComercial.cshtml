                                </label>

                                <div ng-show="formalizacionEditar.formalizado">
                                    <label for="seguimientoFormalizacionEditar">Seguimiento</label>
                                    <textarea id="seguimientoFormalizacionEditar" class="form-control" ng-model="formalizacionEditar.seguimientoFormalizacion" rows="2"></textarea>
