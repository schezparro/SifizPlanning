<button class="btn btn-primary" ng-click="formalizarOferta()">Formalizar Oferta</button>
<input type="text" ng-keyup="cargarFormalizacionOfertas()" ng-model="filtroFormalizarOfertas" class="form-control right filtro" placeholder="Filtrar..." />
<div class="clear"></div>

<div id="tabla-user-formalizar">
    <table id="tabla-formalizar-comercial" class="table table-striped table-condensed nowrap">
        <thead>
            <tr>
                <th rowspan="2">No. Contrato</th>
                <th rowspan="2">Estado</th>
                <th rowspan="2">Valor</th>
                <th rowspan="2">F.Aprobación</th>
                <th rowspan="2">Formalizada</th>
                <th rowspan="2">Seguimiento</th>
                <th colspan="3" class="text-center">Anticipo</th> <!-- Agrupación para las columnas relacionadas con el anticipo -->
                <th colspan="2" class="text-center">Entrega</th> <!-- Agrupación para las columnas relacionadas con la entrega -->
                <th colspan="2" class="text-center">Programada</th> <!-- Agrupación para las columnas relacionadas con la entrega -->
                <th rowspan="2">Acciones</th>
            </tr>
            <tr>
                <th>Valor</th>
                <th>F.Orden</th>
                <th>No.Orden</th>
                <th>Valor</th>
                <th>No.Orden</th>
                <th>Valor</th>
                <th>No.Orden</th>
            </tr>
        </thead>

        <tbody>
            <tr ng-repeat="formalizacion in formalizacionLista | filter: filtroFormalizarOfertas" ng-dblclick="verFormalizacion(formalizacion.secuencial)">
                <td>{{formalizacion.noContrato}}</td>
                <td>{{formalizacion.estadoDescripcion}}</td>
                <td>{{formalizacion.valor}}</td>
                <td>{{formalizacion.fechaAprobacionOferta | strDateToStr}}</td>
                <td>
                    <input type="checkbox" ng-checked="formalizacion.formalizacionContrato" disabled>
                </td>
                <td>{{formalizacion.seguimientoContrato}}</td>
                <td>{{formalizacion.valorAnticipo}}</td>
                <td>{{formalizacion.fechaFacturacionAnticipo | strDateToStr}}</td>
                <td>{{formalizacion.ordenFacturacionAnticipo}}</td>
                <td>{{formalizacion.valorEntrega}}</td>
                <td>{{formalizacion.ordenFacturacionEntrega}}</td>
                <td>{{formalizacion.valorFacturacionProgramada}}</td>
                <td>{{formalizacion.ordenFacturacionProgramada}}</td>
                <td>
                    <button type="button" class="btn btn-xs btn-success" ng-click="verFormalizacion(formalizacion.secuencial)">
                        <span class="glyphicon glyphicon-edit"></span>
                    </button>
                    <button type="button" class="btn btn-xs btn-danger" ng-click="borrarFormalizacion(formalizacion.secuencial)" title="Eliminar Formalización">
                        <span class="glyphicon glyphicon-trash"></span>
                    </button>
                </td>
            </tr>
        </tbody>

        <tfoot>
            <tr>
                <th colspan="9">
                    <nav>
                        <ul class="pagination">
                            <li ng-click="atrazarPagina()">
                                <a href="#" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                            <li ng-repeat="pag in listaPaginas" ng-click="cambiarPagina(pag)">
                                <a href="#">{{pag}}</a>
                            </li>
                            <li ng-click="avanzarPagina()">
                                <a href="#" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </th>
            </tr>
        </tfoot>
    </table>
</div>


<!-- Modal para Nueva Formalizacion -->
<div id="modal-nueva-formalizacion" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-l">
        <div class="modal-content">
            <form ng-submit="guardarFormalizacion()">
                <div class="modal-header">
                    <label>FORMALIZAR OFERTA</label>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group" style="display: flex; align-items: center;">
                                <label style="margin-right: 10px;">No. Contrato:</label>
                                <input type="text" readonly class="form-control" width="20px" ng-model="formalizacion.noContrato" style="width: auto;">
                            </div>
                        </div>
                    </div>


                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Oferta:</label>
                                <select class="form-control" ng-model="formalizacion.secuencialOferta" required>
                                    <option value="">Seleccione una oferta</option>
                                    <option ng-repeat="tipo in ofertas" value="{{tipo.secuencial}}">{{tipo.detalle}}</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Valor:</label>
                                <input type="number" class="form-control" ng-model="formalizacion.valor">
                            </div>
                            <div class="form-group">
                                <label>Valor Entrega:</label>
                                <input type="number" class="form-control" ng-model="formalizacion.valorEntrega">
                            </div>
                            <div class="form-group">
                                <label>No.Orden Facturación Entrega:</label>
                                <input type="number" class="form-control" ng-model="formalizacion.ordenFacturacionEntrega">
                            </div>
                            <div class="form-group">
                                <label>Valor Facturación Programada:</label>
                                <input type="number" class="form-control" ng-model="formalizacion.valorFacturacionProgramada">
                            </div>
                            <div class="form-group">
                                <label>No.Orden Facturación Programada:</label>
                                <input type="number" class="form-control" ng-model="formalizacion.ordenFacturacionProgramada">
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Estado:</label>
                                <select class="form-control" ng-model="formalizacion.estadoOferta">
                                    <option value="">Estado de la oferta</option>
                                    <option ng-repeat="tipo in estadosOferta" value="{{tipo.secuencial}}">{{tipo.descripcion}}</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>F.Aprobación Oferta:</label>
                                <input type="date" class="form-control" ng-model="formalizacion.fechaAprobacionOferta">
                            </div>
                            <div class="form-group">
                                <label>Valor Anticipo:</label>
                                <input type="number" class="form-control" ng-model="formalizacion.valorAnticipo">
                            </div>
                            <div class="form-group">
                                <label>F.Facturación Anticipo:</label>
                                <input type="date" class="form-control" ng-model="formalizacion.fechaFacturacionAnticipo">
                            </div>
                            <div class="form-group">
                                <label>No.Orden Facturación Anticipo:</label>
                                <input type="number" class="form-control" ng-model="formalizacion.ordenFacturacionAnticipo">
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="form-group">
                                <label>
                                    <input type="checkbox" ng-model="formalizacion.formalizado" ng-change="toggleTicketFields()"> Formalizar contrato
                                </label>

                                <div ng-show="formalizacion.formalizado">
                                    <label for="seguimientoFormalizacion">Seguimiento</label>
                                    <textarea id="seguimientoFormalizacion" class="form-control" ng-model="formalizacion.seguimientoFormalizacion" rows="2"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal para editar Oferta -->
