    float: left;
}
.pull-right {
    float: right;
}
.text-right {
    text-align: right;
}
.table > tbody > tr > td .btn {
    margin: 0 2px;
}
.pagination > li > a, .pagination > li > span {
    color: #007bff;
    background: #fff;
    border: 1px solid #dee2e6;
    min-width: 32px;
    text-align: center;
    font-weight: bold;
}
.pagination > .active-pag > a, .pagination > .active-pag > span {
    background: #007bff !important;
    color: #fff !important;
    border-color: #007bff !important;
}
.pagination > li > a:focus, .pagination > li > a:hover {
    background: #e9ecef;
}
.d-inline-block { display: inline-block; }
/* Responsive styles eliminadas para compatibilidad con Razor */
</style>