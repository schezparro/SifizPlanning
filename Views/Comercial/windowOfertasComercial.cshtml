<button class="btn btn-primary" ng-click="abrirNuevaOferta()">Agregar Oferta</button>
<input type="text" ng-keyup="cargarOfertas()" ng-model="filtroOfertas" class="form-control right filtro" placeholder="Filtrar..." />
<div class="clear"></div>

<div id="tabla-user-ofertas">
    <table id="tabla-ofertas-comercial" class="table table-striped table-condensed nowrap">
        <thead>
            <tr>
                <th>Código de Oferta</th>
                <th>Fecha Recepción Estimación</th>
                <th>Fecha Generación Oferta</th>
                <th>Fecha Envío revisión</th>
                <th>Fecha Aprobación Gerencia</th>
                <th>Fecha Envío cliente</th>
                <th>Fecha Vencimiento</th>
                <th>Tipo</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            <tr ng-repeat="oferta in ofertasLista | filter: filtroOfertas" ng-dblclick="editarOferta(oferta.secuencial)">
                <td>{{oferta.codigo}}</td>
                <td>{{oferta.fechaEstimacion | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.fechaGeneracion | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.fechaRevision | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.fechaAprobacionGerencia | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.fechaEnvioOferta | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.fechaVencimiento | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.tipo}}</td>
                <td>
                    <button type="button" class="btn btn-xs btn-success" ng-click="verOferta(oferta.codigo)"><span class="glyphicon glyphicon-edit"></span></button>
                    <!-- Botón de borrar en la tabla -->
                    <button type="button" class="btn btn-xs btn-danger"
                            ng-click="borrarOferta(oferta.codigo)"
                            title="Eliminar Oferta">
                        <span class="glyphicon glyphicon-trash"></span>
                    </button>
                </td>
            </tr>
        </tbody>

        <tfoot>
            <tr>
                <th colspan="6">
                    <nav>
                        <ul class="pagination">
                            <li ng-click="atrazarPagina()">
                                <a href="#" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                            <li ng-repeat="pag in listaPaginas" ng-click="cambiarPagina(pag)"><a href="#">{{pag}}</a></li>
                            <li ng-click="avanzarPagina()">
                                <a href="#" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </th>
            </tr>
        </tfoot>
    </table>
</div>

<!-- Modal para Nueva Oferta -->
<div id="modal-nueva-oferta" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-l">
        <div class="modal-content">
            <form ng-submit="guardarOferta()">
                <div class="modal-header">
                    <label>NUEVA OFERTA</label>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Código de Oferta:</label>
                                <input type="text" class="form-control" ng-model="ofertaSeleccionada.codigo" readonly>
                            </div>
                            <div class="form-group">
                                <label>Fecha Recepción Estimación:</label>
                                <input type="date" class="form-control" ng-model="ofertaSeleccionada.fechaEstimacion" required>
                            </div>
                            <div class="form-group">
                                <label>Fecha Envío Revisión:</label>
                                <input type="date" class="form-control" ng-model="ofertaSeleccionada.fechaRevision" required>
                            </div>
                            <div class="form-group">
                                <label>Fecha Envío Oferta Cliente:</label>
                                <input type="date" class="form-control" ng-model="ofertaSeleccionada.fechaEnvioOferta" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Requerimiento:</label>
                                <select class="form-control" ng-model="ofertaSeleccionada.OfertaRequerimiento" required>
                                    <option value="">Seleccione un tipo</option>
                                    <option ng-repeat="tipo in ofertaRequerimientos" value="{{tipo.secuencial}}">{{tipo.detalle}}</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Fecha Generación Oferta:</label>
                                <input type="date" class="form-control" ng-model="ofertaSeleccionada.fechaGeneracion" required>
                            </div>
                            <div class="form-group">
                                <label>Fecha Aprobación Oferta Gerencia:</label>
                                <input type="date" class="form-control" ng-model="ofertaSeleccionada.fechaAprobacionGerencia" required>
                            </div>
                            <div class="form-group">
                                <label>Fecha Vencimiento Oferta:</label>
                                <input type="date" class="form-control" ng-model="ofertaSeleccionada.fechaVencimiento" required>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

