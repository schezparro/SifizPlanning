<button class="btn btn-primary" ng-click="abrirNuevaOferta()">Agregar Oferta</button>
<input type="text" ng-keyup="cargarOfertas()" ng-model="filtroOfertas" class="form-control right filtro" placeholder="Filtrar..." />
<div class="clear"></div>

<div id="tabla-user-ofertas">
    <table id="tabla-ofertas-comercial" class="table table-striped table-condensed nowrap">
        <thead>
            <tr>
                <th>Código de Oferta</th>
                <th>Fecha Generación Oferta</th>
                <th>Fecha Aprobación Oferta</th>
                <th>Fecha Envío Oferta Cliente</th>
                <th>Tipo</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            <tr ng-repeat="oferta in ofertasLista | filter: filtroOfertas" ng-dblclick="editarOferta(oferta.codigo)">
                <td>{{oferta.codigo}}</td>
                <td>{{oferta.fechaGeneracion | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.fechaAprobacion | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.fechaEnvio | date:'dd/MM/yyyy'}}</td>
                <td>{{oferta.tipo}}</td>
                <td>
                    <button type="button" class="btn btn-xs btn-success" ng-click="editarOferta(oferta.codigo)"><span class="glyphicon glyphicon-edit"></span></button>
                    <!-- Botón de borrar en la tabla -->
                    <button type="button" class="btn btn-xs btn-danger"
                            ng-click="borrarOferta(oferta.codigo)"
                            title="Eliminar Oferta">
                        <span class="glyphicon glyphicon-trash"></span>
                    </button>
                </td>
            </tr>
        </tbody>

        <tfoot>
            <tr>
                <th colspan="6">
                    <nav>
                        <ul class="pagination">
                            <li ng-click="atrazarPagina()">
                                <a href="#" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                            <li ng-repeat="pag in listaPaginas" ng-click="cambiarPagina(pag)"><a href="#">{{pag}}</a></li>
                            <li ng-click="avanzarPagina()">
                                <a href="#" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </th>
            </tr>
        </tfoot>
    </table>
</div>

<!-- Modal para Nueva Oferta -->
<div id="modal-nueva-oferta" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-l">
        <div class="modal-content">
            <form ng-submit="guardarOferta()">
                <div class="modal-header">
                    <label>NUEVA OFERTA</label>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <div>
                        <label>Código de Oferta:</label>
                        <input type="text" class="form-control" ng-model="ofertaSeleccionada.codigo" readonly>
                    </div>
                    <br>
                    <div>
                        <label>Fecha Generación Oferta:</label>
                        <input type="date" class="form-control" ng-model="ofertaSeleccionada.fechaGeneracion" required>
                    </div>
                    <br>
                    <div>
                        <label>Cliente:</label>
                        <select class="form-control" ng-model="ofertaSeleccionada.cliente" required>
                            <option value="">Seleccione un cliente</option>
                            <option ng-repeat="cliente in clientes" value="{{cliente.id}}">{{cliente.nombre}}</option>
                        </select>
                    </div>
                    <br>
                    <div>
                        <label>Tipo de Oferta:</label>
                        <select class="form-control" ng-model="ofertaSeleccionada.tipoOferta" required>
                            <option value="">Seleccione un tipo</option>
                            <option ng-repeat="tipo in tiposOferta" value="{{tipo.id}}">{{tipo.descripcion}}</option>
                        </select>
                    </div>
                    <br>
                    <div>
                        <label>Observaciones:</label>
                        <textarea class="form-control" ng-model="ofertaSeleccionada.observaciones"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>