<div id="div-garantia-tickets">
    <table id="tabla-garantia-tickets" class="table table-striped table-hover" style=" width: 100% ">
        <thead>
            <tr>
                <th class="ordenar-columna-tickets" ng-click="ordenarColumna(1)">
                    <div class="left">
                        No. Ticket
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-tickets" ng-click="ordenarColumna(2)">
                    <div class="left">
                        Cliente
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-tickets" ng-click="ordenarColumna(3)">
                    <div class="left">
                        Asunto
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-tickets" ng-click="ordenarColumna(4)">
                    <div class="left">
                        Asignado A
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-tickets" ng-click="ordenarColumna(5)">
                    <div class="left">
                        Fecha Cierre
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-tickets" ng-click="ordenarColumna(6)">
                    <div class="left">
                        Fecha Vencimiento
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-tickets" ng-click="ordenarColumna(7)">
                    <div class="left">
                        Días Restantes
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
            </tr>
            <tr>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control" ng-model="noTicket" ng-change="filterData(1)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control" ng-model="cliente" ng-change="filterData(2)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control" ng-model="asunto" ng-change="filterData(3)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control" ng-model="asignado" ng-change="filterData(4)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control" ng-model="fecha" ng-change="filterData(5)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control" ng-model="fechaVencimiento" ng-change="filterData(6)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control" ng-model="diasRestantes" ng-change="filterData(7)" /></th>
            </tr>
        </thead>
        <tfoot>
            <tr>
                <th colspan="8">
                    <div>
                        <div class="left gestion-lista-ticket">
                            <div class="margin-top-3">
                                <label>Mostrar Todos:</label>
                                <input type="checkbox" ng-click="mostrarTodosLosTickets()" ng-model="mostrarTodos" />
                            </div>
                        </div>
                        <div class="clear"></div>
                    </div>

                    <div class="padding-lr-10">
                        <div class="clear"></div>
                        <div class="left">
                            <nav>
                                <ul class="pagination">
                                    <li ng-click="atrazarPagina()">
                                        <a href="#" aria-label="Previous">
                                            <span aria-hidden="true">&laquo;</span>
                                        </a>
                                    </li>
                                    <li ng-repeat="pagina in listaPaginas" ng-click="cambiarPagina(pagina)"><a href="#">{{pagina}}</a></li>
                                    <li ng-click="avanzarPagina()">
                                        <a href="#" aria-label="Next">
                                            <span aria-hidden="true">&raquo;</span>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>

                        <div class="left form-inline gestion-lista-ticket" ng-init="cantidadMostrarPorPagina = 10" style="padding: 10px 0px 0px 0px">
                            <label>Cantidad Por Página:</label>
                            <select class="form-control" ng-model="cantidadMostrarPorPagina" ng-change="actualizarCantidadMostrar()">
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>

                        <div class="right gestion-lista-ticket" style="padding: 10px 0px 0px 0px">
                            <div>
                                <label>Total de Páginas: </label>{{cantPaginas}}
                            </div>
                        </div>
                        <div class="right gestion-lista-ticket" style="padding: 10px 0px 0px 0px">
                            <div>
                                <label>Total de Tickets: </label>{{totalTickets}}
                            </div>
                        </div>

                        <div class="clear"></div>
                    </div>
                </th>
            </tr>
        </tfoot>
        <tbody>
            <tr ng-repeat="ticket in datosTickets" ng-dblclick="mostrarDetalleTickets(ticket.codigo)">
                <td>{{ticket.numero}}</td>
                <td>{{ticket.cliente}}</td>
                <td>{{ticket.asunto}}</td>
                <td>{{ticket.asignado}}</td>
                <td>{{ticket.fecha != null ? (ticket.fecha | strDateToStr) : ticket.fecha }}</td>
                <td>{{ticket.fechaVencimiento != null ? (ticket.fechaVencimiento | strDateToStr) : ticket.fechaVencimiento }}</td>
                <td ng-if="ticket.diasRestantes >= 15">
                    <span class="badge" style="background-color:seagreen">&nbsp;</span> &nbsp; {{ticket.diasRestantes}}
                </td>
                <td ng-if="ticket.diasRestantes >= 0 && ticket.diasRestantes < 15">
                    <span class="badge" style="background-color:goldenrod">&nbsp;</span> &nbsp; {{ticket.diasRestantes}}
                </td>
                <td ng-if="ticket.diasRestantes < 0">
                    <span class="badge" style="background-color:darkred">&nbsp;</span> &nbsp; {{ticket.diasRestantes}}
                </td>
            </tr>
        </tbody>
    </table>
</div>