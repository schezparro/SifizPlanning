<div id="div-consulta-contratos">
    <table id="tabla-consulta-contratos" class="table table-striped table-hover table-condensed" style="width: 100%; white-space: nowrap;">
        <thead>
            <tr>
                <th class="ordenar-columna-contratos" ng-click="ordenarColumna(1)">
                    <div class="left">
                        Código
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-contratos" ng-click="ordenarColumna(2)">
                    <div class="left">
                        Cliente
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-contratos" ng-click="ordenarColumna(3)">
                    <div class="left">
                        Descripción
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-contratos" ng-click="ordenarColumna(4)">
                    <div class="left">
                        F.Inicio
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-contratos" ng-click="ordenarColumna(5)">
                    <div class="left">
                        F.Venc
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-contratos" ng-click="ordenarColumna(6)">
                    <div class="left">
                        Estado
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-contratos" ng-click="ordenarColumna(7)">
                    <div class="left">
                        Días
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-contratos" ng-click="ordenarColumna(8)">
                    <div class="left">
                        Responsable
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
            </tr>
            <tr>
                <th><input type="text" class="form-control" ng-model="codigo" ng-keyup="filterData(1)" /></th>
                <th><input type="text" class="form-control" ng-model="cliente" ng-keyup="filterData(2)" /></th>
                <th><input type="text" class="form-control" ng-model="descripcion" ng-keyup="filterData(3)" /></th>
                <th><input type="text" class="form-control" ng-model="fechaInicio" ng-keyup="filterData(4)" /></th>
                <th><input type="text" class="form-control" ng-model="fechaVencimiento" ng-keyup="filterData(5)" /></th>
                <th>
                    <select id="select-estado-contrato" style="min-width: 150px" class="form-control">
                        <option>Seleccione...</option>
                        <option>VIGENTE</option>
                        <option>POR VENCER</option>
                        <option>VENCIDO</option>
                        <option>CERRADO</option>
                        <option ng-repeat="estado in estadosContrato">{{estado.nombre}}</option>
                    </select>
                </th>
                <th><input type="text" class="form-control" ng-model="diasRestantes" ng-keyup="filterData(6)" /></th>
                <th>
                    <select id="select-responsable" class="form-control">
                        <option>Seleccione...</option>
                        <option>NO ASIGNADO</option>
                        <option ng-repeat="responsable in colaboradores">{{responsable.nombre}}</option>
                    </select>
                </th>
            </tr>

        </thead>
        <tfoot>
            <tr>
                <th colspan="8">
                    <div>
                        <div class="left gestion-lista-ticket">
                            <div class="margin-top-3">
                                <label>Mostrar Todos:</label>
                                <input type="checkbox" ng-click="mostrarTodosLosContratos()" ng-model="mostrarTodos" />
                            </div>
                        </div>
                        <div class="left gestion-lista-ticket form-inline">
                            <div ng-init="filtroTipo='TODOS'">
                                <label>Según Tipo: </label>
                                <select id="select-tipo-contrato" class="form-control sm" ng-model="filtroTipo" ng-change="mostrarPorTipo()">
                                    <option>TODOS</option>
                                    <option ng-repeat="tipo in tiposMotivoTrabajo">{{tipo.codigo}}</option>
                                </select>
                            </div>
                        </div>

                        <div class="clear"></div>
                    </div>

                    <div class="padding-lr-10">
                        <div class="clear"></div>
                        <div class="left">
                            <nav>
                                <ul class="pagination">
                                    <li ng-click="atrazarPagina()">
                                        <a href="#" aria-label="Previous">
                                            <span aria-hidden="true">&laquo;</span>
                                        </a>
                                    </li>
                                    <li ng-repeat="pagina in listaPaginas" ng-click="cambiarPagina(pagina)"><a href="#">{{pagina}}</a></li>
                                    <li ng-click="avanzarPagina()">
                                        <a href="#" aria-label="Next">
                                            <span aria-hidden="true">&raquo;</span>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>

                        <div class="left form-inline gestion-lista-ticket" ng-init="cantidadMostrarPorPagina = 10" style="padding: 10px 0px 0px 0px">
                            <label>Cantidad Por Página:</label>
                            <select class="form-control" ng-model="cantidadMostrarPorPagina" ng-change="actualizarCantidadMostrar()">
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>

                        <div class="right gestion-lista-ticket" style="padding: 10px 0px 0px 0px">
                            <div>
                                <label>Total de Páginas: </label>{{cantPaginas}}
                            </div>
                        </div>
                        <div class="right gestion-lista-ticket" style="padding: 10px 0px 0px 0px">
                            <div>
                                <label>Total de Contratos: </label>{{totalContratos}}
                            </div>
                        </div>

                        <div class="clear"></div>
                    </div>
                </th>
            </tr>
        </tfoot>
        <tbody>
            <tr ng-repeat="contrato in datosContratos" ng-dblclick="mostrarDetalleContrato(contrato.codigo)">
                <td>{{contrato.codigo}}</td>
                <td>{{contrato.cliente | limitTo: 20}}</td>
                <td>{{contrato.descripcion | limitTo: 40}}</td>
                <td>{{contrato.fechaInicio != null ? (contrato.fechaInicio | strDateToStr) : contrato.fechaInicio }}</td>
                <td>{{contrato.fechaVencimiento != null ? (contrato.fechaVencimiento | strDateToStr) : contrato.fechaVencimiento }}</td>
                <td ng-if="contrato.semaforoActa === 'WHITE'">
                    <span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>{{contrato.estado}}
                </td>
                <td ng-if="contrato.semaforoActa === 'AMARILLO'">
                    <span class="badge" style="background-color:goldenrod">&nbsp;</span> &nbsp; {{contrato.estado}}
                </td>
                <td ng-if="contrato.semaforoActa === 'ROJO'">
                    <span class="badge" style="background-color:darkred">&nbsp;</span> &nbsp; {{contrato.estado}}
                </td>
                <td ng-if="contrato.semaforoActa === 'NARANJA'">
                    <span class="badge" style="background-color:orangered">&nbsp;</span> &nbsp; {{contrato.estado}}
                </td>
                <td ng-if="contrato.semaforoActa === 'VERDE'">
                    <span class="badge" style="background-color:seagreen">&nbsp;</span> &nbsp; {{contrato.estado}}
                </td>
                <td ng-if="contrato.diasRestantes > 30">
                    <span class="badge" style="background-color:seagreen">&nbsp;</span> &nbsp; {{contrato.diasRestantes}}
                </td>
                <td ng-if="contrato.diasRestantes >= 0 && contrato.diasRestantes <=30">
                    <span class="badge" style="background-color:goldenrod">&nbsp;</span> &nbsp; {{contrato.diasRestantes}}
                </td>
                <td ng-if="contrato.diasRestantes < 0">
                    <span class="badge" style="background-color:darkred">&nbsp;</span> &nbsp; {{contrato.diasRestantes}}
                </td>
                <td>{{contrato.responsable}}</td>

                @*<td>{{contrato.formaPago != null ? (contrato.formaPago | soloLetras) : contrato.formaPago}}</td>*@
            </tr>
        </tbody>
    </table>

    <!-- Windows Modal Consulta de Contratos -->
    <div class="modal fade" id="modal-consulta-contratos" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="modal-gestion-ticket-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Consulta de Contrato</h4>
                </div>
                <form method="post" id="frm-edit-contrato" ng-submit="guardarInformacionContrato()">
                    <div class="modal-body">
                        <div class="panel panel-default panel-superior">
                            <div class="panel-body" id="panel-info-ticket-general">
                                <div class="left info-ticket">
                                    <label class="label-data-ticket">Tipo: </label><span style="margin-left: 5px;">{{tipoContrato != "PENDIENTES" ? tipoContrato : "SOPORTE Y MANTENIMIENTO" }}</span><br />
                                    <label class="label-data-ticket">Código: </label><span style="margin-left: 5px;">{{codigoContrato}}</span><br />
                                    <label class="label-data-ticket">Cliente: </label><span style="margin-left: 5px;">{{clienteContrato}}</span><br />
                                    <label class="label-data-ticket">Fecha de Inicio: </label><span style="margin-left: 5px;">{{fechaInicioContrato != null ? (fechaInicioContrato | strDateToStr) : fechaInicioContrato}}</span><br />
                                    <label class="label-data-ticket">Fecha de Vencimiento: </label><span style="margin-left: 5px;">{{fechaVencimientoContrato != null ? (fechaVencimientoContrato | strDateToStr) : fechaVencimientoContrato}}</span><br />
                                    <label class="label-data-ticket">Dias Restantes: </label>
                                    <span ng-if="diasRestantesContrato > 30" class="badge" style="background-color:seagreen">{{diasRestantesContrato}}</span>
                                    <span ng-if="diasRestantesContrato >= 0 && diasRestantesContrato <=30" class="badge" style="background-color:goldenrod">{{diasRestantesContrato}}</span>
                                    <span ng-if="diasRestantesContrato < 0" class="badge" style="background-color:darkred">NO APLICA</span>
                                </div>

                                <div class="left info-ticket">
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Nombre: </label><span style="margin-left: 5px;">{{nombreContrato}}</span><br />
                                    </div>

                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Estado: </label>
                                        <select class="form-control" id="prioridad-estado" ng-required="true" ng-model="idEstadoContrato">
                                            <option ng-repeat="estado in estadosContrato" value="{{estado.id}}">{{estado.nombre}}</option>
                                        </select>
                                    </div>
                                    <div class="div-info-ticket">
                                        <span ng-show="idEstadoContrato==7 && (estadoContrato =='VIGENTE' || estadoContrato =='VENCIDO' || estadoContrato =='POR VENCER' )" style="margin-left: 100px">{{estadoContrato}} </span>
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Forma de Pago: </label><span style="margin-left: 5px;">{{formaPagoContrato != null ? (formaPagoContrato | soloLetras) : formaPagoContrato}}</span><br />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Porcentage de Avance: </label><span style="margin-left: 5px;">{{avanceContrato}} %</span><br />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Tiene Cronograma: </label>
                                        <input style="margin-left: 5px;" type="checkbox" ng-model="cronogramaContrato" />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Fase: </label>
                                        <select class="form-control" id="prioridad-ticket" ng-required="true" ng-model="faseContrato">
                                            <option value="">Sin Asignar</option>
                                            <option ng-repeat="fase in fasesContrato" value="{{fase.id}}">{{fase.nombre}}</option>
                                        </select>
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Estimación: </label>
                                        <input ng-disabled="!isRossi" type="number" min="0" ng-model="estimacion" class="form-control inline" style="width: 20%" />
                                    </div>
                                </div>

                                <div class="left info-ticket">
                                    <div class="div-info-ticket">
                                        <a href="{{linkOpenKm}}" target="_blank" class="label-data-ticket">LinkOpenKM:</a>
                                        <input class="form-control" style="margin-left: 5px; width: 70%; display: inline;" type="text" ng-model="linkOpenKm" />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Días Garantía: </label>
                                        <input id="diasGarantia" name="diasGarantia" type="number" min="1" ng-model="diasGarantia" class="form-control inline" style="width: 20%" />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Fecha Acta: </label>
                                        <input id="fechaActa" name="fechaActa" ng-model="fechaActa" class="form-control inline" style="width: 40%" autocomplete="off" />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Fecha Producción: </label>
                                        <input id="fechaProduccion" name="fechaProduccion" ng-model="fechaProduccion" class="form-control inline" style="width: 40%" autocomplete="off" />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Técnico Responsable: </label>
                                        <select class="form-control" id="colaborador-contrato" ng-required="true" ng-model="colaborador">
                                            <option value="0">Seleccione...</option>
                                            <option ng-repeat="colab in colaboradores" value="{{colab.id}}">{{colab.nombre}}</option>
                                        </select>
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Pagado Totalmente:</label>
                                        <input style="margin-left: 5px;" type="checkbox" ng-model="pagado" />
                                    </div>
                                </div>

                                <div class="left info-ticket">
                                    <div class="div-info-ticket" ng-hide="horasMes == null">
                                        <label class="label-data-ticket">Horas Mensuales: </label><span style="margin-left: 5px;">{{horasMes}}</span><br />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Acepta Normativos: </label>
                                        <input style="margin-left: 5px;" type="checkbox" ng-model="aceptaNormativos" />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Tipo de Plazo: </label><span style="margin-left: 5px;">{{tipoPlazo}}</span><br />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Plazo en días: </label><span style="margin-left: 5px;">{{plazo}}</span><br />
                                    </div>
                                    <div class="div-info-ticket">
                                        <label class="label-data-ticket">Descripción: </label><span style="margin-left: 5px;">{{descripcionContrato}}</span><br />
                                    </div>
                                    <div class="div-info-ticket" ng-hide="tipoContrato != 'PENDIENTES'">
                                        <button type="button" class="btn btn-warning btn-xs" ng-click="validarContratos()"><span class="glyphicon glyphicon-alert"></span> Validar Mantenimiento</button>
                                    </div>
                                    <div id="panel-adjuntos-ticket" class="div-info-ticket">
                                        <div ng-repeat="adj in adjuntos" class="left">
                                            <a href="Web{{adj}}" target="_blank" class="btn btn-default btn-xs"><span class="glyphicon glyphicon-paperclip"></span> Adjunto {{$index+1}}</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="panel-funcionalidades-ticket" class="panel panel-default left">
                            <div class="panel-heading">
                                Adendas
                            </div>
                            <div class="panel-body" style="height: 228px; overflow-y: auto;">
                                <table class="table table-hover table-striped table-condensed" style="width: 100%">
                                    <thead>
                                        <tr>
                                            <th>Código</th>
                                            <th>Fecha Vencimiento</th>
                                            <th>LinkOpenKM</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr ng-repeat="adenda in adendasContrato" ng-dblclick="editarAdenda($index)">
                                            <td>
                                                {{adenda.Codigo}}
                                            </td>
                                            <td>
                                                {{adenda.FechaVencimiento}}
                                            </td>
                                            <td>
                                                <a href="{{adenda.LinkOpenKM}}" target="_blank" class="label-data-ticket">{{adenda.LinkOpenKM}}</a>
                                            </td>
                                            <td>
                                                <a class="glyphicon glyphicon-minus" ng-click="eliminarAdenda($index)"></a>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <input class="form-control" type="text" id="newAttributeCode" ng-model="adendaCodigoContrato" name="newAttributeCode" />
                                            </td>
                                            <td>
                                                <input id="adenda-fechaVencimiento-Contrato" ng-model="adendafechaVencimientoContrato" class="form-control" autocomplete="off" />
                                            </td>
                                            <td>
                                                <input id="adenda-link" ng-model="adendaLinkOpenKM" class="form-control" />
                                            </td>
                                            <td>
                                                <a class="glyphicon glyphicon-plus" ng-click="adicionarAdenda()"></a>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div id="panel-colaboradores-ticket" class="panel panel-default left">
                            <div class="panel-heading">
                                <span class="text-heading">Entregables</span>
                                <input type="text" class="form-control un-medio right" ng-model="filtroEntregable" placeholder="Filtrar..." />
                                <div class="clear"></div>
                            </div>

                            <div class="panel-body" style="height: 228px; overflow-y: auto;">
                                <table class="table table-hover table-striped table-condensed table-responsive-md" style="width: 100%">
                                    <tr ng-repeat="entregable in entregablesContrato | filter: filtroEntregable">
                                        <td>{{entregable.Nombre}}</td>
                                        <td>
                                            <span ng-hide="mostrarInput">{{entregable.Avance}}%</span>
                                            <input ng-show="mostrarInput" type="number" ng-style="{'width': '65px'}" min="0" max="100" ng-model="entregable.Avance" class="form-control" />
                                        </td>
                                        <td>
                                            <span ng-hide="mostrarInput">{{entregable.Colaborador}}</span>
                                            <select id="select-colaborador-entregable{{$index}}" ng-style="{'width': '115px'}" ng-show="mostrarInput" class="form-control" @*ng-model="colaboradorEntregable$index"*@>
                                                <option value="0">Seleccione...</option>
                                                <option ng-repeat="colab in colaboradores" value="{{colab.id}}">{{colab.nombre}}</option>
                                            </select>
                                        </td>
                                        <td>
                                            <div style="text-align: center">
                                                <span ng-hide="mostrarInput">{{entregable.DiasGarantia}} dias</span>
                                            </div>
                                            <input ng-show="mostrarInput" type="number" ng-style="{'width': '65px'}" min="0" ng-model="entregable.DiasGarantia" class="form-control" />
                                        </td>
                                        <td>
                                            <button aria-hidden="true" ng-show="mostrarInput" ng-click="mostrarInput=false; editarAvance($index)" type="button" class="btn btn-primary btn-xs" aria-label="Left Align">
                                                <span aria-hidden="true" class="glyphicon glyphicon-ok"></span>
                                            </button>
                                            <button aria-hidden="true" ng-hide="mostrarInput" ng-click="mostrarInput=true; editarSelectAvance($index)" type="button" class="btn btn-primary btn-xs" aria-label="Left Align">
                                                <span aria-hidden="true" class="glyphicon glyphicon-pencil"></span>
                                            </button>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div id="panel-asignaciones-ticket" class="left">
                            <div class="clear"></div>
                            <div class="panel panel-default left" style="width:100%!important; height:70%!important">
                                <div class="panel-heading"> Seguimiento </div>

                                <div class="panel-body">
                                    <div class="left">
                                        <button type="button" class="btn btn-primary btn-xs" ng-click="adicionarSeguimiento()"><span class="glyphicon glyphicon-plus"></span> Adicionar</button>
                                    </div>
                                    <div class="clear"></div>
                                    <div id="tabla-asignaciones-ticket">
                                        <table id="tabla-seguimiento-contratos" class="table table-striped table-condensed">
                                            <thead>
                                                <tr>
                                                    <th>Fecha</th>
                                                    <th>Pendiente</th>
                                                    <th>En Proceso</th>
                                                    <th>Realizado</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tfoot>
                                                <tr>
                                                    <th colspan="8">
                                                        <nav>
                                                            <div class="left">
                                                                <ul class="pagination paginationSeguimiento">
                                                                    <li ng-click="atrazarPaginaSeguimientos()">
                                                                        <a href="#" aria-label="Previous">
                                                                            <span aria-hidden="true">&laquo;</span>
                                                                        </a>
                                                                    </li>
                                                                    <li ng-repeat="paginaSeguimientos in listaPaginasSeguimientos" ng-click="cambiarPaginaSeguimientos(paginaSeguimientos)"><a href="#">{{paginaSeguimientos}}</a></li>
                                                                    <li ng-click="avanzarPaginaSeguimientos()">
                                                                        <a href="#" aria-label="Next">
                                                                            <span aria-hidden="true">&raquo;</span>
                                                                        </a>
                                                                    </li>
                                                                </ul>
                                                            </div>
                                                        </nav>
                                                    </th>

                                                </tr>
                                            </tfoot>

                                            <tbody>
                                                <tr ng-repeat="seguimiento in seguimientosContrato">
                                                    <td ng-dblclick="editarSeguimiento($index)">{{seguimiento.FechaSeguimiento}}</td>
                                                    <td ng-dblclick="editarSeguimiento($index)">{{seguimiento.Pendiente | trim20}}</td>
                                                    <td ng-dblclick="editarSeguimiento($index)">{{seguimiento.PorRealizar | trim20}}</td>
                                                    <td ng-dblclick="editarSeguimiento($index)">{{seguimiento.Realizado | trim20}}</td>
                                                    <td ng-click="eliminarSeguimiento($index)"><span class="glyphicon glyphicon-remove"></span></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="clear"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary left"><span class="glyphicon glyphicon-save"></span> Grabar</button>
                        <button type="button" class="btn btn-danger" data-dismiss="modal"><span class="glyphicon glyphicon-remove" onClick="window.location.reload"></span> Cerrar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- Windows Modal Seguimiento-->
    <div class="modal fade" id="modal-new-task-ticket" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="myModalLabel">
                        <span class="glyphicon glyphicon-tasks" aria-hidden="true"></span>
                        <span id="title-modal-new-task-ticket">Seguimiento</span>
                    </h4>
                </div>
                <form method="post" ng-submit="guardarSeguimientos()">
                    <div class="modal-body">

                        <div class="fila">
                            <div class="left half half-padding-right">
                                <label>Fecha:</label>
                                <input id="fecha-seguimiento" ng-model="fechaSeguimiento" class="form-control" ng-required="true" autocomplete="off" />
                            </div>
                            <div style="float: right" class="right">
                                <label ng-show="usuario!=''">Añadido por:</label>
                                <h5>{{usuario}}</h5>
                            </div>
                        </div>

                        <div class="clear"></div>

                        <div class="fila">
                            <label>Pendiente:</label>
                            <textarea ng-model="pendiente" class="form-control"></textarea>
                        </div>

                        <div class="clear"></div>

                        <div class="fila">
                            <label>En Proceso:</label>
                            <textarea ng-model="porRealizar" class="form-control"></textarea>
                        </div>

                        <div class="clear"></div>

                        <div class="fila">
                            <label>Realizado:</label>
                            <textarea ng-model="realizado" class="form-control"></textarea>
                        </div>

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                        <button type="submit" class="btn btn-primary">Grabar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- Windows Modal Adendas-->
    <div class="modal fade" id="modal-new-adenda" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog" style="width: 25%">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="myModalLabel">
                        <span class="glyphicon glyphicon-tasks" aria-hidden="true"></span>
                        <span id="title-modal-new-task-ticket">Editar Adenda</span>
                    </h4>
                </div>
                <form method="post" ng-submit="guardarEdicionAdenda()">
                    <div class="modal-body">

                        <div class="fila">
                            <label>Código:</label>
                            <input ng-model="editarCodigoAdenda" class="form-control" style="width: 58%">
                        </div>

                        <div class="clear"></div>

                        <div class="fila">
                            <div class="left half half-padding-right">
                                <label>Fecha Vencimiento:</label>
                                <input id="fecha-adenda-editar" style="width: 120%" ng-model="editarFechaAdenda" class="form-control" ng-required="true" autocomplete="off" />
                            </div>
                        </div>

                        <div class="clear"></div>

                        <div class="fila">
                            <label>LinkOpenKM:</label>
                            <input ng-model="editarLinkAdenda" class="form-control">
                        </div>

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                        <button type="submit" class="btn btn-primary">Grabar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- Windows Modal Contratos por Cliente-->
    <div class="modal fade" id="modal-contratos-cliente" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog" style="width: 50%">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="modal-gestion-ticket-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Validar Mantenimiento</h4>
                </div>
                <div class="modal-body">

                    <div class="panel panel-default">
                        <div class="panel-heading center">
                            <span class="text-heading">Contrato</span>

                            <div style="width: 20%" class='input-group date right' id='fechaMantenimiento'>
                                <input type='text' class="form-control" ng-model="fechaMantenimiento" />
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-calendar"></span>
                                </span>
                            </div>
                            <div class="clear"></div>
                        </div>

                        <div class="panel-body">
                            <table class="table table-striped table-condensed">
                                <thead>
                                    <tr>
                                        <th>
                                            <div class="left">
                                                Código Contrato
                                            </div>
                                        </th>
                                        <th>
                                            <div class="left">
                                                Fecha Corte
                                            </div>
                                        </th>
                                        <th>
                                            <div class="left">
                                                Fecha Vencimiento
                                            </div>
                                        </th>
                                        <th>
                                            <div class="left">
                                                Horas Mensuales
                                            </div>
                                        </th>
                                        <th>
                                            <div class="left">
                                                Horas Consumidas
                                            </div>
                                        </th>
                                        <th>
                                            <div class="left">
                                                Horas Disponibles
                                            </div>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="contrato in contratosMantenimiento">
                                        <td>{{contrato.Codigo}}</td>
                                        <td>{{contrato.FechaInicio}}</td>
                                        <td>{{contrato.FechaVencimiento}}</td>
                                        <td>{{contrato.HorasMensuales}}</td>
                                        <td>{{contrato.HorasConsumidas}}</td>
                                        <td>{{contrato.HorasDisponibles}}</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="clear"></div>
                </div>
            </div>
        </div>
    </div>
</div>