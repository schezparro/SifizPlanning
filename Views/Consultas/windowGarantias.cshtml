<div id="div-consulta-garantias">
    <table id="tabla-consulta-garantias" class="table table-striped table-hover" style=" width: 100% ">
        <thead>
            <tr>
                <th class="ordenar-columna-garantias" ng-click="ordenarColumna(1)">
                    <div class="left">
                        Código del Contrato
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-garantias" ng-click="ordenarColumna(2)">
                    <div class="left">
                        Cliente
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-garantias" ng-click="ordenarColumna(3)">
                    <div class="left">
                        Descripción
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-garantias" ng-click="ordenarColumna(4)">
                    <div class="left">
                        Fecha de Producción
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-garantias" ng-click="ordenarColumna(5)">
                    <div class="left">
                        Fecha de Vencimiento
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
                <th class="ordenar-columna-garantias" ng-click="ordenarColumna(6)">
                    <div class="left">
                        Días Restantes
                    </div>
                    <div class="right">
                        <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                    </div>
                </th>
            </tr>
            <tr>
                <th><input type="text" class="form-control" ng-model="codigo" ng-keyup="filterData(1)" /></th>
                <th><input type="text" class="form-control" ng-model="cliente" ng-keyup="filterData(2)" /></th>
                <th><input type="text" class="form-control" ng-model="descripcion" ng-keyup="filterData(3)" /></th>
                <th><input type="text" class="form-control" ng-model="fechaProduccion" ng-keyup="filterData(4)" /></th>
                <th><input type="text" class="form-control" ng-model="fechaVencimiento" ng-keyup="filterData(5)" /></th>
                <th><input type="text" class="form-control" ng-model="diasRestantes" ng-keyup="filterData(6)" /></th>
            </tr>

        </thead>
        <tfoot>
            <tr>
                <th colspan="8">
                    <div>
                        <div class="left gestion-lista-ticket">
                            <div class="margin-top-3">
                                <label>Mostrar Todas:</label>
                                <input type="checkbox" ng-click="mostrarTodasLasGarantias()" ng-model="mostrarTodos" />
                            </div>
                        </div>
                        <div class="left gestion-lista-ticket form-inline">
                            <div ng-init="filtroTipo='TODOS'">
                                <label>Según Tipo: </label>
                                <select id="select-tipo-contrato" class="form-control sm" ng-model="filtroTipo" ng-change="mostrarPorTipo()">
                                    <option>TODOS</option>
                                    <option ng-repeat="tipo in tiposMotivoTrabajo">{{tipo.codigo}}</option>
                                </select>
                            </div>
                        </div>

                        <div class="clear"></div>
                    </div>

                    <div class="padding-lr-10">
                        <div class="clear"></div>
                        <div class="left">
                            <nav>
                                <ul class="pagination">
                                    <li ng-click="atrazarPagina()">
                                        <a href="#" aria-label="Previous">
                                            <span aria-hidden="true">&laquo;</span>
                                        </a>
                                    </li>
                                    <li ng-repeat="pagina in listaPaginas" ng-click="cambiarPagina(pagina)"><a href="#">{{pagina}}</a></li>
                                    <li ng-click="avanzarPagina()">
                                        <a href="#" aria-label="Next">
                                            <span aria-hidden="true">&raquo;</span>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>

                        <div class="left form-inline gestion-lista-ticket" ng-init="cantidadMostrarPorPagina = 10" style="padding: 10px 0px 0px 0px">
                            <label>Cantidad Por Página:</label>
                            <select class="form-control" ng-model="cantidadMostrarPorPagina" ng-change="actualizarCantidadMostrar()">
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>

                        <div class="right gestion-lista-ticket" style="padding: 10px 0px 0px 0px">
                            <div>
                                <label>Total de Páginas: </label>{{cantPaginas}}
                            </div>
                        </div>
                        <div class="right gestion-lista-ticket" style="padding: 10px 0px 0px 0px">
                            <div>
                                <label>Total de Garantias: </label>{{totalGarantias}}
                            </div>
                        </div>

                        <div class="clear"></div>
                    </div>
                </th>
            </tr>
        </tfoot>
        <tbody>
            <tr ng-repeat="garantia in datosGarantias" ng-dblclick="mostrarDetalleGarantia(garantia.codigo)">
                <td>{{garantia.codigo}}</td>
                <td>{{garantia.cliente}}</td>
                <td>{{garantia.descripcion}}</td>
                <td>{{garantia.fechaProduccion != '' ? (garantia.fechaProduccion ) : "NO ASIGNADA" }}</td>
                <td>{{garantia.fechaVencimiento != '' ? (garantia.fechaVencimiento ) : "NO ASIGNADA" }}</td>
                <td ng-if="garantia.diasRestantes > 30">
                    <span class="badge" style="background-color:seagreen">&nbsp;</span> &nbsp; {{garantia.diasRestantes}}
                </td>
                <td ng-if="garantia.diasRestantes > 0 && garantia.diasRestantes <=30">
                    <span class="badge" style="background-color:goldenrod">&nbsp;</span> &nbsp; {{garantia.diasRestantes}}
                </td>
                <td ng-if="garantia.diasRestantes < 0 && garantia.fechaVencimiento != ''">
                    <span class="badge" style="background-color:darkred">&nbsp;</span> &nbsp; VENCIDA
                </td>
                <td ng-if="garantia.fechaProduccion == '' && garantia.fechaVencimiento == ''">
                    <span class="badge" style="background-color:darkgray">&nbsp;</span> &nbsp; NO APLICA
                </td>
            </tr>
        </tbody>
    </table>

	    <!-- Windows Modal Consulta de Garantias -->
    <div class="modal fade" id="modal-consulta-garantias" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="modal-gestion-ticket-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Garantía de los entregables</h4>
                </div>
                <div class="modal-body">

                    <div id="" class="panel panel-default" ng-if="entregablesGarantia.length != 0">
                        <div class="panel-heading">
                            <span class="text-heading">Entregables</span>
                            <input type="text" class="form-control un-medio right" ng-model="filtroEntregable" placeholder="Filtrar..." />
                            <div class="clear"></div>
                        </div>

                        <div class="panel-body">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>
                                            <div class="left">
                                                Nombre
                                            </div>
                                        </th>
                                        <th>
                                            <div class="left">
                                                Fecha de Producción
                                            </div>
                                        </th>
                                        <th>
                                            <div class="left">
                                                Fecha de Vencimiento
                                            </div>
                                        </th>
                                        <th>
                                            <div class="left">
                                                Días Restantes
                                            </div>
                                        </th>
                                    </tr>
                                </thead>
                                <tr ng-repeat="entregable in entregablesGarantia | filter: filtroEntregable">
								    <td ng-if="entregable.Nombre!= null">{{entregable.Nombre}}</td>
									<td ng-if="entregable.Nombre== null">NO ASIGNADA</td>
                                    <td>{{entregable.FechaProduccion}}</td>
                                    <td>{{entregable.FechaVencimiento}}</td>
                                    <td>
                                        <span ng-if="entregable.DiasRestantes > 30" class="badge" style="background-color:seagreen">{{entregable.DiasRestantes}}</span>
                                        <span ng-if="entregable.DiasRestantes > 0 && entregable.DiasRestantes <=30" class="badge" style="background-color:goldenrod">{{entregable.DiasRestantes}}</span>
                                        <span ng-if="entregable.DiasRestantes < 0 || entregable.FechaProduccion == 'NO ASIGNADA' || entregable.FechaVencimiento == 'NO ASIGNADA'" class="badge">NO APLICA</span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="text-center" ng-if="entregablesGarantia.length == 0">
                        <span>NO EXISTEN ENTREGAGLES QUE MOSTRAR</span>
                    </div>

                    <div class="clear"></div>
                </div>
            </div>
        </div>
    </div>
    
</div>