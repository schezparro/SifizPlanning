<div id="div-proyectos-excel">

    <form name="proyectoForm" novalidate ng-submit="guardarProyecto()">
        <div class="form-row">
            <div class="form-group col-md-3">
                <label>Cooperativa/Institución</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.cooperativa" required />
            </div>
            <div class="form-group col-md-3">
                <label>Codificación</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.codificacion" required />
            </div>
            <div class="form-group col-md-3">
                <label>Contacto Cliente</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.contactoCliente" />
            </div>
            <div class="form-group col-md-3">
                <label>Correo contacto cliente</label>
                <input type="email" class="form-control" ng-model="proyectoFormData.correoContactoCliente" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-3">
                <label>Versión</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.version" />
            </div>
            <div class="form-group col-md-3">
                <label>Repositorio</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.repositorio" />
            </div>
            <div class="form-group col-md-3">
                <label>Adm Cod</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.admCod" />
            </div>
            <div class="form-group col-md-3">
                <label>Publicación</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.publicacion" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-3">
                <label>Solución</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.solucion" />
            </div>
            <div class="form-group col-md-3">
                <label>Líder de Proyecto</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.liderProyecto" />
            </div>
            <div class="form-group col-md-3">
                <label>Gestor de Servicio</label>
                <input type="text" class="form-control" ng-model="proyectoFormData.gestorServicio" />
            </div>
            <div class="form-group col-md-3">
                <label>Correo Gestor de Servicio</label>
                <input type="email" class="form-control" ng-model="proyectoFormData.correoGestorServicio" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-3">
                <label>Fecha Salida</label>
                <input type="date" class="form-control" ng-model="proyectoFormData.fechaSalida" />
            </div>
        </div>
        <div class="form-row">
            <button type="submit" class="btn btn-primary" ng-disabled="proyectoForm.$invalid">{{ proyectoFormData.id ? 'Actualizar' : 'Crear' }}</button>
            <button type="button" class="btn btn-secondary" ng-click="limpiarFormulario()">Limpiar</button>
        </div>
    </form>

    <hr />

    <table id="tabla-proyectos-excel" class="table table-striped table-hover table-condensed">
        <thead>
            <tr>
                <th>Cooperativa/Institución</th>
                <th>Codificación</th>
                <th>Contacto Cliente</th>
                <th>Correo contacto cliente</th>
                <th>Versión</th>
                <th>Repositorio</th>
                <th>Adm Cod</th>
                <th>Publicación</th>
                <th>Solución</th>
                <th>Líder de Proyecto</th>
                <th>Gestor de Servicio</th>
                <th>Correo Gestor de Servicio</th>
                <th>Fecha Salida</th>
                <th>Acciones</th>
            </tr>
            <tr>
                <th><input type="text" class="form-control" ng-model="filtro.cooperativa" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.codificacion" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.contactoCliente" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.correoContactoCliente" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.version" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.repositorio" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.admCod" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.publicacion" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.solucion" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.liderProyecto" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.gestorServicio" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.correoGestorServicio" ng-keyup="filtrarDatos()" /></th>
                <th><input type="text" class="form-control" ng-model="filtro.fechaSalida" ng-keyup="filtrarDatos()" /></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <tr ng-repeat="proyecto in proyectos | filter: filtro" ng-click="seleccionarProyecto(proyecto)" style="cursor:pointer;">
                <td>{{ proyecto.cooperativa }}</td>
                <td>{{ proyecto.codificacion }}</td>
                <td>{{ proyecto.contactoCliente }}</td>
                <td>{{ proyecto.correoContactoCliente }}</td>
                <td>{{ proyecto.version }}</td>
                <td>{{ proyecto.repositorio }}</td>
                <td>{{ proyecto.admCod }}</td>
                <td>{{ proyecto.publicacion }}</td>
                <td>{{ proyecto.solucion }}</td>
                <td>{{ proyecto.liderProyecto }}</td>
                <td>{{ proyecto.gestorServicio }}</td>
                <td>{{ proyecto.correoGestorServicio }}</td>
                <td>{{ proyecto.fechaSalida }}</td>
                <td>
                    <button class="btn btn-sm btn-warning" ng-click="editarProyecto(proyecto, $event)">Editar</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>
