@{
    ViewBag.Title = "Bienvenido a la Gestión de Tareas de SifizPlanning";
}

<!DOCTYPE html>

<html ng-app="task">
<head>
    <!--<meta name="viewport" content="width=device-width" />-->
    <title>@ViewBag.Title</title>
    <link href="~/Web/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Web/css/bootstrap-theme.min.css" rel="stylesheet" />
    <link href="~/Web/css/datepicker.css" rel="stylesheet" />
    <link href="~/Web/css/bootstrap-datetimepicker.css" rel="stylesheet" />
    <link href="~/Web/css/jasny-bootstrap.min.css" rel="stylesheet" />
    <link href="~/Web/css/bootstrap-datetimepicker.css" rel="stylesheet" />
    <link href="~/Web/css/bootstrap-select.min.css" rel="stylesheet" />
    <link href="~/Web/css/admin/admin.css" rel="stylesheet" />
    <link href="~/Web/css/home/home.css" rel="stylesheet" />

    <script type="text/javascript" src="~/Web/js/jquery-2.1.3.min.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.signalR-2.1.2.min.js"></script>
    <script type="text/javascript" src="~/signalr/hubs"></script>
    <script type="text/javascript" src="~/Web/js/jquery-ui.min.js"></script>
    <script type="text/javascript" src="~/Web/js/angular.min.js"></script>
</head>
<body ng-controller="mainTaskController">

    <div id="content_body">

        <div id="menu-principal">
            <ul class="nav nav-pills left">

                <li role="presentation" class="active"><a href="#" ng-click="IrInicio()">Inicio</a></li>
                <li role="presentation"><a href="#" ng-click="IrTareas()">Gestionar Tareas</a></li>
                <li role="presentation"><a href="#" ng-click="IrSolicitudes()">Solicitudes de Tareas</a></li>
                <li role="presentation"><a href="#" ng-click="IrConsolidacionTareas()">Consolidación de Tareas</a></li>
                <li role="presentation"><a href="#" ng-click="IrDisponibilidadRecursos()">Disponibilidad de Recursos</a></li>
                <li role="presentation"><a href="#" ng-click="IrIncidenciasColaboradores()">Incidencias</a></li>

            </ul>

            <div class="right">
                <a href="cerrar/sesion/" class="right btn btn-danger"><span class="glyphicon glyphicon-off"></span> Cerrar Sesión</a>
                <a href="main-menu" style="margin-right: 4px;" class="right btn btn-warning"><span class="glyphicon glyphicon-menu-hamburger"></span> Menú Principal</a>
            </div>
            <div class="clear"></div>
        </div>

        <div id="panel-principal" class="panel panel-default" ng-init="funcionalidad = 'INICIO'">
            <div class="panel-heading">
                <h3 id="titulo-panel" class="panel-title">{{ funcionalidad }}</h3>
            </div>

            <div id="funcionalidad">

                <div id="panel_home">
                    @{Html.RenderPartial("inicioTask");}
                </div>

                <div id="panel_tasks" class="invisible" ng-controller="taskController">
                    @{Html.RenderPartial("windowTask");}
                </div>

                <div id="panel_solicitudes" class="invisible" ng-controller="solicitudesController">
                    @{Html.RenderPartial("windowSolicitudes");}
                </div>

                <div id="panel_consolidacion_tareas" class="invisible" ng-controller="consolidacionController">
                    @{Html.RenderPartial("windowConsolidacionTareas");}
                </div>

                <div id="panel_disponibilidad_recursos" class="invisible" ng-controller="disponibilidadRecursosController">
                    @{Html.RenderPartial("windowDisponibilidadRecursos");}
                </div>

                <div id="panel_incidencias_colaboradores" class="invisible" ng-controller="incidenciasController">
                    @{Html.RenderPartial("windowIncidencias");}
                </div>

                <div id="loadingDiv">
                    <img src="~/Web/images/ajax-loader.gif" />
                </div>

            </div>

        </div>

    </div>

    <!-- CODIGO DEL CHAT -->
    <div id="sifiz-chat" style="display: none;">
        <div id="head-sifiz-chat" class="btns-chat">
            <div class="left nombre-usuario-local"></div>
            <div class="right"> <i class="glyphicon glyphicon-chevron-down"></i></div>
            <div class="clear"></div>
        </div>
        <div style="padding: 3px;">
            <input id="filtro-chat" type="text" class="form-control" placeholder="Filtrar..." />
        </div>
        <div id="body-sifiz-chat" style="display: block;">
            <div id="panel-usuarios-sfz">

            </div>
        </div>
    </div>

    <div id="ventanas-activas-chat">

    </div>

    <div id="div-usuario-chat">
        <div class="usuario-chat" data-id="">
            <div class="estado-usuario left active"><i class="glyphicon glyphicon-ok-sign"></i></div>
            <div class="left nombre-usuario"></div>
            <div class="clear"></div>
        </div>
    </div>
    <div id="ventana-chat-conversacion" style="display: none;">
        <div class="ventana-chat">
            <div class="heading-ventana-chat">
                <div class="left nombre-contacto">Henry Cruz</div>
                <div class="right"><i class="glyphicon glyphicon-remove"></i></div>
                <div class="clear"></div>
            </div>
            <div class="chat-text-ventana-chat">

            </div>
            <div class="text-ventana-chat">
                <textarea data-id-persona=""></textarea>
            </div>
        </div>
    </div>
    <audio id="audio-chat" controls="controls">
        <source src="~/Web/sounds/happy-ending.mp3" type="audio/mpeg" />
    </audio>
    <!-- FIN DEL CODIGO DEL CHAT -->

    <script type="text/javascript" src="~/Web/js/angular-dragdrop.min.js"></script>
    <script type="text/javascript" src="~/Web/js/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Web/js/moment.min.js"></script>
    <script type="text/javascript" src="~/Web/js/bootstrap-datepicker.js"></script>
    <script type="text/javascript" src="~/Web/js/bootstrap-datetimepicker.js"></script>
    <script type="text/javascript" src="~/Web/js/jasny-bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Web/js/highcharts.js"></script>
    <script type="text/javascript" src="~/Web/js/chat.js"></script>
    <script type="text/javascript" src="~/Web/js/waiting.js"></script>
    <script type="text/javascript" src="~/Web/js/task/task.js"></script>
    <script type="text/javascript" src="~/Web/js/task/taskController.js"></script>
    <script type="text/javascript" src="~/Web/js/task/solicitudesTarea.js"></script>
    <script type="text/javascript" src="~/Web/js/task/consolidacionTareas.js"></script>
    <script type="text/javascript" src="~/Web/js/task/disponibilidadRecursos.js"></script>
    <script type="text/javascript" src="~/Web/js/task/incidenciasColaboradores.js"></script>
    <script type="text/javascript" src="~/Web/js/angular-bootstrap-multiselect.js"></script>
</body>
</html>
