<input type="text" class="form-control right filtro" ng-model="filtroSolicitudTarea" ng-keyup="filtrarSolicitudes()" placeholder="Filtrar..."/>
<div>
    <label class="inline left">Mostrar todas:</label><input type="checkbox" class="form-control inline left" ng-model="mostrarTodas" ng-click="mostrarTodasSolicitudes()" />
</div>

<div class="clear"></div>

<div id="div-tabla-solicitud-ticket">
    <table id="tabla-solicitud-ticket" class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Solicita</th>
                <th>Fecha de solicitud</th>
                <th>Descripción</th>
                <th>Gestionó</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            <tr ng-repeat="solicitud in solicitudes" ng-click="windowGestionarSolicitudTicket(solicitud)">
                <td>{{solicitud.usuario}}</td>
                <td>{{solicitud.fecha | strDateToStrTime}}</td>
                <td>{{solicitud.descripcion}}</td>
                <td>{{solicitud.gestiono}}</td>
                <td>{{solicitud.estado}}</td>
            </tr>
        </tbody>
        <tfoot>
            <tr>
                <th colspan="5">
                    <nav>
                        <ul class="pagination">
                            <li ng-click="atrazarPagina()">
                                <a href="#" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                            <li ng-repeat="pagina in listaPaginas" ng-click="cambiarPagina(pagina)"><a href="#">{{pagina}}</a></li>
                            <li ng-click="avanzarPagina()">
                                <a href="#" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </th>
            </tr>
        </tfoot>
    </table>
</div>

<!-- Modal Descripción Solicitud -->
<div class="modal fade" id="modal-descripcion-solicitud" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">
                    <span class="glyphicon glyphicon-tasks" aria-hidden="true"></span>
                    <span id="title-new-task">Descripción de Solicitud</span>
                </h4>
            </div>
            <form method="post" id="frm-descripcion-solicitud">
                <div class="modal-body">
                    <div><label>Hora de Solicitud:</label> {{ horaPeticionTarea }}</div>
                    <div class="descripcion-solicitud-tarea">
                        {{ descripcionTarea }}
                    </div>                        
                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger left" data-dismiss="modal" ng-click="rechazarSolicitud()">Rechazar Solicitud</button>
                    
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-info" data-dismiss="modal" ng-click="aceptarSolicitud()">Aceptar Solicitud</button>
                    <button type="submit" class="btn btn-primary" ng-click="generarTarea()">Generar Tarea</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Solicitud Tarea -->
<div class="modal fade" id="modal-new-task-solicitud" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">
                    <span class="glyphicon glyphicon-tasks" aria-hidden="true"></span>
                    <span id="title-new-task">Nueva Tarea Por Solicitud</span>
                </h4>
            </div>
            <form method="post" id="frm-new-task-solicitud" ng-submit="guardarTareaSolicitud()">
                <div class="modal-body">

                    <input type="hidden" ng-model="idSolicitudTrabajador" />
                    <input type="hidden" ng-model="idTrabajador" />

                    <div class="fila">
                        <div class="left half half-padding-right">
                            <div id="data-user-tarea-solicitud">
                                <label>{{nombreColaborador}}</label>,
                                <label>{{sede}}</label>
                            </div>
                        </div>

                        <div id="fecha-solicitud-user-tarea" class="fila">
                            <div class="left half half-padding-right">
                                <label>Fecha:</label>
                                <input id="fecha-solicitud-tarea" ng-model="fechaSolicitudTarea" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left half half-padding-right">
                            <label>Cliente:</label><br />
                            <select ng-model="cliente" required="required" class="form-control" ng-required="true" ng-change="cargarMotivosTrabajo()">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="client in clientes" value="{{ client.id }}">{{ client.nombre }}</option>
                            </select>
                        </div>

                        <div class="left half half-padding-left">
                            <label>Ubicación:</label><br />
                            <select ng-model="ubicacion" required="required" class="form-control" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="lugar in lugares" value="{{ lugar.id }}">{{ lugar.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left half half-padding-right">
                            <label>Actividad:</label><br />
                            <select ng-model="actividad" required="required" class="form-control" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="act in actividades" value="{{ act.id }}">{{ act.nombre }}</option>
                            </select>
                        </div>

                        <div class="left half half-padding-left">
                            <label>Módulo:</label><br />
                            <select ng-model="modulo" required="required" class="form-control" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="mod in modulos" value="{{ mod.id }}">{{ mod.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left half half-padding-right">
                            <label>Número Horas:</label>
                            <select ng-model="numero_horas" required="required" class="form-control" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="h in [1,2,3,4,5,6,7,8]" value="{{ h }}">{{ h }}</option>
                            </select>
                        </div>
                        <div class="left half half-padding-left">
                            <label>Coordinador:</label>
                            <select ng-model="coordinador" class="form-control">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="cord in coordinadores" value="{{ cord.id }}">{{ cord.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <label>Referencia:</label>
                        <select ng-model="referencia" class="form-control">
                            <option value="0">Seleccione...</option>
                            <option ng-repeat="ref in referencias" value="{{ref.id}}">{{ref.nombre}}</option>
                        </select>
                    </div>

                    <div class="fila">
                        <label>Detalle:</label>
                        <textarea ng-model="detalle" required="required" class="form-control"></textarea>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left half half-padding-right">
                            <label>Repetir:</label>
                            <select ng-change="repetirTarea()" ng-model="tarea_repetir" class="form-control">
                                <option value="">NO REPETIR</option>
                                <option ng-repeat="n in frecuenciasRepetir" value="{{ n }}">{{ n }}</option>
                            </select>
                        </div>
                        <div class="left half half-padding-left">
                            <label>Fin de Semana:</label>
                            <select ng-model="fin_semana" class="form-control">
                                <option value="">NO INCLUIR FIN DE SEMANA</option>
                                <option value="1">INCLUIR SABADO</option>
                                <option value="2">INCLUIR DOMINGO</option>
                                <option value="3">INCLUIR SABADO Y DOMINGO</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div id="datosRepetir" class="fila">
                        <div id="tipoRepetirTareaNewSolicitud" class="left separarTipoRepetir">
                            <input type="radio" ng-click="mostrarCampoRepetir()" ng-model="repetirTipoFin" name="repetirTipoFin" value="1" /><label>:Número de Veces</label><br />
                            <input type="radio" ng-click="mostrarCampoRepetir()" ng-model="repetirTipoFin" name="repetirTipoFin" value="2" /><label>:Fecha Fin</label><br />
                        </div>
                        <div class="left camposHastaRepetir">
                            <input type="text" id="repetirNumVecesNewSolicitud" class="form-control solo-numero" ng-model="numVeces" />
                            <input type="text" id="repetirFechaHastaNewSolicitud" class="form-control" ng-model="fechaHasta" />
                        </div>
                    </div>

                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary">Grabar</button>
                </div>
            </form>
        </div>
    </div>
</div>