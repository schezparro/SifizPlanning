<!--<input type="hidden" name="fechaLunes" id="fechaLunes" ng-model="fechaLunes" />
<input type="hidden" name="esteLunes" ng-model="esteLunes" />
<input type="hidden" name="fechaHoy" ng-model="fechaHoy" />-->
<div class="task-controles">
    <div class="left">
        <button class="btn btn-primary" ng-click="filtrarTareas()"><span class="glyphicon glyphicon-filter" aria-hidden="true"></span> Aplicar Filtro</button>
        <button class="btn btn-primary" ng-click="modalAsignacionesSemana()"><span class="glyphicon glyphicon-envelope" aria-hidden="true"></span> Enviar Asignaciones</button>
        <button class="btn btn-primary" ng-click="modalNivelConocimientoColaboradores()"><span class="glyphicon glyphicon-thumbs-up"></span> Conocimientos de Colaboradores</button>
        <button class="btn btn-primary" ng-click="cargarExcel()"><span class="glyphicon glyphicon-file"></span> Agregar Tareas con archivo Excel</button>
        <button class="btn btn-primary" ng-click="modalSolicitudTFS()"><span class="glyphicon glyphicon-envelope" aria-hidden="true"></span> Enviar Solicitud Acceso</button>
    </div>

    <div id="loadingDiv">
        <img src="~/Web/images/ajax-loader.gif" />
    </div>

    <div id="control-filtrar">
        <div class="left">
            <input class="form-control filtro" placeholder="Filtrar..." ng-model="filtroTotalAsignaciones" />
        </div>
        <div class="input-append date left">
            <input type="text" class="form-control datepicker-filtro left" ng-model="fechaDiaFiltro">
            <span class="glyphicon glyphicon-th left"></span>
        </div>
        <select id="selectSemanas" ng-model="numeroSemanas" ng-change="cambiarSemanas()" class="form-control">
            <option value="1" selected="selected">1 Semana</option>
            <option value="2">2 Semanas</option>
            <option value="3">3 Semanas</option>
            <option value="4">4 Semanas</option>
        </select>
        <button class="btn btn-primary" ng-click="semanaAtras()"><span class="glyphicon glyphicon-chevron-left"></span></button>
        <button class="btn btn-success" ng-click="diaHoy()"><span class="glyphicon glyphicon-home"></span></button>
        <button class="btn btn-primary" ng-click="semanaProxima()"><span class="glyphicon glyphicon-chevron-right"></span></button>
    </div>
</div>

<div class="clear"></div>

<div id="task-container">

    <table class="table table-colaboradores">

        <thead id="thead-colaboradores-tareas">
            <tr>
                <td style="opacity: 0.0;">&nbsp;</td>
                <td class="{{dia.clase}}" ng-repeat="dia in diasCalendar" ng-right-click="mostarOpcionesFeriados($event, dia.date)">{{dia.dia}}</td>
            </tr>
        </thead>

        <tbody id="tbody-colaboradores-tareas">
            <tr ng-repeat="trab in trabajadores | filter:filtroTotalAsignaciones" ng-init="paso = $index">
                <td class="td-colaborador">
                    <div class="colaborador-panel" data-id="{{trab.trab.id}}">
                        <div>
                            {{paso+1}}
                            <span class="btn-enviar-email-asignaciones-persona right glyphicon glyphicon-envelope" ng-click="enviarAsignacionesPersona()" title="Enviar email de tareas"></span>
                            <span class="{{estiloSegunEstadoCoordinacion(trab.trab.id, paso)[0]}}" ng-click="verCoordinadosPersona(trab.trab.id)" title="{{estiloSegunEstadoCoordinacion(trab.trab.id, paso)[1]}}"></span>
                        </div>
                        <div class="img-worker-task">
                            <img ng-src="Web/images/{{trab.trab.url}}">
                        </div>
                        <div class="nombre-trabajador">{{ mySplitEmail( trab.trab.email, 0 ) }}</div>
                        <div class="sede-trabajador">{{trab.trab.sede}}</div>
                    </div>
                </td>

                <td class="td-tareas {{tareas.claseDia}}" ng-repeat="tareas in trab.tareasPorDia" style="width:{{anchoCeldaTarea}};"
                    data-drop="true"
                    data-jqyoui-options=""
                    jqyoui-droppable="{
                                        multiple: true,
                                        stack: true,
                                        onDrop: 'pegarTarea( trab.trab.id )',
                                        onOver: 'tareaEncima()',
                                        onOut: 'tareaFuera()'
                                    }">

                    <div class="bottonAddTask">
                        <span ng-click="addNewTask()" title="Adicionar Tarea">+</span>
                        <span class="right" ng-click="addNewIncidence()" title="Adicionar Incidencia">*</span>
                    </div>
                    <div data-id-tarea="{{tarea.id}}" data-tipo="{{tarea.tipo}}" class="content-tarea {{tarea.clase}}" ng-repeat="tarea in tareas.tareas" ng-click="fechaTarea()"
                         data-container="#task-container" data-toggle="popover" data-placement="right"
                         data-title="{{
                                        &quot;<div class='left'>&quot; + tarea.dCliente + &quot;</div>&quot; +
                                        &quot;<div class='right'><span class='glyphicon glyphicon-menu-hamburger hand btn-tarea-repetir-vertical' data-id-tarea='&quot; + tarea.id + &quot;'</span></div>&quot; +
                                        &quot;<div class='clear'></div>&quot;
                                     }}"
                         data-drag="true"
                         data-jqyoui-options="{revert: 'invalid'}"
                         jqyoui-draggable="{
                                             animate: true,
                                             placeholder: true,
                                             onStart: 'startDrag( tarea.id, trab.trab.id, tarea.tipo )',
                                             onDrag: 'actualizarTabla()'
                                           }"
                         data-content="{{tarea.tipo === &quot;t&quot;?
                                            &quot;Actividad:&quot; + tarea.dActividad + &quot;<br>&quot; +
                                            &quot;Módulo:&quot; + tarea.dModulo + &quot;<br>&quot; +
                                            &quot;Desarrollarse en:&quot; + tarea.dLugar + &quot;<br>&quot; +
                                            (tarea.coordinador != null?&quot;Coordinar con:&quot;+tarea.coordinador+&quot;<br/>&quot;:&quot;&quot;) +
                                            &quot;Detalles:&quot; + tarea.detalle + &quot;<br>&quot; +
                                            &quot;Hora Inicio:&quot; + tarea.finicio + &quot;<br>&quot; +
                                            &quot;Hora Fin:&quot; + tarea.ffin + &quot;<br>&quot; +
                                            &quot;<button class='btn btn-xs btn-success btn-edittask' data-id-tarea='&quot; + tarea.id + &quot;'>Editar</button>&quot; +
                                            &quot;
                                                <div class='right estado-tarea'>
                                                    <span class='glyphicon glyphicon-time btn-tarea-compensatoria' data-id-tarea='&quot; + tarea.id + &quot;' title='Compensatoria - Poner/Quitar'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-adjust btn-tarea-preasignada' data-id-tarea='&quot; + tarea.id + &quot;' title='Pre-Asignar'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-new-window btn-tarea-asignada' data-id-tarea='&quot; + tarea.id + &quot;' title='Asignar'></span>
                                                    &nbsp;
                                                     <span class='glyphicon glyphicon-remove btn-anulartask' data-id-tarea='&quot; + tarea.id + &quot;' title='Anular'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-cog btn-tarea-desarrollo' data-id-tarea='&quot; + tarea.id + &quot;' title='En desarrollo'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-pause btn-tarea-pausa' data-id-tarea='&quot; + tarea.id + &quot;' title='En pausa'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-search btn-tarea-finish' data-id-tarea='&quot; + tarea.id + &quot;' title='Ver actividades'></span>
                                                </div>
                                            &quot;
                                        :
                                            &quot;Motivo:&quot; + tarea.detalle + &quot;<br>&quot; +
                                            &quot;Hora Inicio:&quot; + tarea.finicio + &quot;<br>&quot; +
                                            &quot;Hora Fin:&quot; + tarea.ffin + &quot;<br>&quot;+
                                            &quot;
	                                            <div class='right estado-tarea'>
		                                             <span class='glyphicon glyphicon-remove btn-anularPermiso' data-id-tarea='&quot; + tarea.id + &quot;' title='Anular'></span>
		                                            &nbsp;
	                                            </div>
                                            &quot;
                                        }}"
                         data-html="true" data-trigger="manual">

                        <div class="cabecera-tarea {{tarea.compensatoria}}">
                            <div class="nombre-cliente">{{tarea.cliente}}</div>
                            <div class="lugar-tarea">{{tarea.lugar}}</div>
                            <div class="clear"></div>
                        </div>
                        <div class="body-tarea">
                            <div>
                                <div class="codigo-actividad-tarea">{{tarea.tipo === 't'?'('+tarea.actividad+')':''}}</div>
                                <div class="modulo-actividad-tarea">{{tarea.modulo}}</div>
                            </div>
                            <div class="clear"></div>
                            <div class="detalle-tarea">
                                {{tarea.sdetalle}}
                            </div>
                            <div class="horas-tarea">{{tarea.horas}}</div>
                            <div class="clear"></div>
                        </div>
                    </div>

                </td>
            </tr>
        </tbody>
    </table>
</div>

<!-- Modal Subir Archivo Excel -->
<div class="modal fade" id="modalUploadFile" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">
                    <span class="glyphicon glyphicon-file" aria-hidden="true"></span>
                    <span id="title-upload-file">Subir Archivo Excel</span>
                </h4>
            </div>

            <div class="modal-body">
                <form method="post" enctype="multipart/form-data" id="form-excel">
                    <input type="file" name="documentoExcel" id="input-excel" />
                </form>
            </div>

            <div class="modal-footer">
                <button type="submit" class="btn btn-primary right" ng-click="subirArchivo()">Subir</button>
                <button type="button" class="btn btn-danger left" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Nueva Tarea -->
<div class="modal fade" id="modalNewTask" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">
                    <span class="glyphicon glyphicon-tasks" aria-hidden="true"></span>
                    <span id="title-new-task">Nueva Tarea</span>
                </h4>
            </div>
            <form method="post" id="frm-newTask">
                <div class="modal-body">

                    <input type="hidden" ng-model="idTrabajador" />
                    <input type="hidden" ng-model="idTarea" />
                    <input type="hidden" ng-model="verificadorTarea" />

                    <div id="data-user-tarea" class="fila">
                        <div class="left">
                            <div>
                                <label>{{nombreColaborador}}</label>,
                                <label>{{sede}}</label>,
                                <label>{{fecha_tarea}}</label>
                            </div>
                        </div>
                    </div>
                    <div class="right">
                        <input ng-hide="edicionTareaExtraordinaria" style="margin-left: 5px; vertical-align: top" type="checkbox" ng-model="extraordinaria" />
                        <label ng-show="nuevaTareaExtraordinaria">
                            Extra
                        </label>
                    </div>

                    <div class="clear"></div>

                    <div id="edicion-user-edicion-tarea" style="display: none;" class="fila">
                        <div class="left">
                            <label>Colaborador:</label>
                            <select ng-model="idColaborador" class="form-control control-left">
                                <option ng-repeat="trab in trabajadores" value="{{ trab.trab.id }}">{{ trab.trab.nombre }}, {{trab.trab.sede}}</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Fecha:</label>
                            <input id="fecha-edit-tarea" ng-model="fechaEditTarea" class="form-control control-right" />
                        </div>
                    </div>

                    <div class="fila">
                        <div class="left">
                            <label>Cliente:</label><br />
                            <select ng-model="cliente" required="required" class="form-control control-left" ng-required="true" ng-change="cargarMotivosTrabajo()">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="client in clientes" value="{{ client.id }}">{{ client.nombre }}</option>
                            </select>
                        </div>

                        <div class="left">
                            <label>Ubicación:</label><br />
                            <select ng-model="ubicacion" required="required" class="form-control control-right" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="lugar in lugares" value="{{ lugar.id }}">{{ lugar.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Actividad:</label><br />
                            <select ng-model="actividad" required="required" class="form-control control-left" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="act in actividades" value="{{ act.id }}">{{ act.nombre }}</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Módulo:</label><br />
                            <select ng-model="modulo" required="required" class="form-control control-right" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="mod in modulos" value="{{ mod.id }}">{{ mod.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left" style="max-width: 45%">
                            <label>Horas y Minutos:</label>
                            <div class="clear">
                                <div class="form-inline">
                                    <select style="width: 57%" ng-model="numero_horas_horas" required="required" class="form-control control-left" ng-required="true">
                                        <option value="0">Seleccione...</option>
                                        <option ng-repeat="h in [1,2,3,4,5,6,7,8]" value="{{ h }}">{{ h }}</option>
                                    </select>
                                    <input id="numberMinutos" type="number" ng-model="numero_horas_minutos" class="form-control control-right" min="0" max="60" value="0" style="width: 35%; margin: 0px 0px 0px 0px" />
                                </div>
                            </div>
                        </div>
                        <div class="right" style="max-width: 45%">
                            <label>Estimación:</label>
                            <div class="clear">
                                <div class="form-inline">
                                    <select style="width: 57%" ng-model="numero_horas_estimadas" required="required" class="form-control control-left" ng-required="true">
                                        <option value="0">Seleccione...</option>
                                        <option ng-repeat="h in [1,2,3,4,5,6,7,8]" value="{{ h }}">{{ h }}</option>
                                    </select>
                                    <input id="numberMinutosEstimados" type="number" ng-model="numero_minutos_estimados" class="form-control control-right" min="0" max="60" value="0" style="width: 35%; margin: 0px 0px 0px 0px" />
                                </div>
                            </div>
                        </div>
                    </div>


                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Motivo Trabajo:</label>
                            <select id="referencia-trabajo-task" class="form-control control-left" ng-model="referencia">
                                <option value="0">Seleccione...</option>
                                <option ng-repeat="ref in referencias" value="{{ref.id}}">{{ref.nombre}}</option>
                            </select>
                        </div>

                        <div class="right">
                            <label>Coordinador:</label>
                            <select ng-model="coordinador" class="form-control control-right">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="cord in coordinadores | orderBy:'nombre'" value="{{ cord.id }}">{{ cord.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>
                    <div class="fila">
                        <label>Detalle:</label>
                        <textarea ng-model="detalle" required="required" class="form-control"></textarea>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Repetir:</label>
                            <select ng-change="repetirTarea()" ng-model="tarea_repetir" class="form-control control-left">
                                <option value="">NO REPETIR</option>
                                <option ng-repeat="n in frecuenciasRepetir" value="{{ n }}">{{ n }}</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Fin de Semana:</label>
                            <select ng-model="fin_semana" class="form-control control-right">
                                <option value="">NO INCLUIR FIN DE SEMANA</option>
                                <option value="1">INCLUIR SABADO</option>
                                <option value="2">INCLUIR DOMINGO</option>
                                <option value="3">INCLUIR SABADO Y DOMINGO</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div id="datosRepetir" class="fila">
                        <div id="tipoRepetirTarea" class="left separarTipoRepetir">
                            <input type="radio" ng-click="mostrarCampoRepetir()" ng-model="repetirTipoFin" name="repetirTipoFin" value="1" /><label>:Número de Veces</label><br />
                            <input type="radio" ng-click="mostrarCampoRepetir()" ng-model="repetirTipoFin" name="repetirTipoFin" value="2" /><label>:Fecha Fin</label><br />
                        </div>
                        <div class="left camposHastaRepetir">
                            <input type="text" id="repetirNumVeces" class="form-control solo-numero control-right" ng-model="numVeces" />
                            <input type="text" id="repetirFechaHasta" class="form-control control-right" ng-model=" fechahasta" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Referencia Ticket:</label>
                            <input type="text" onkeyup="this.value=this.value.replace(/[^\d]/,'')" id="secuencial-ticket" class="form-control control-left" ng-model="ticketTarea" />

                        </div>
                        <div class="left">
                            <input style="margin-top: 35px;" type="checkbox" ng-model="reproceso" ng-checked="reproceso" />
                            <label>
                                Reproceso
                            </label>
                        </div>
                        <div class="left">
                            <input style="margin-top: 35px; margin-left: 8px;" type="checkbox" ng-model="esProyecto" ng-checked="esProyecto" />
                            <label>
                                Es Proyecto
                            </label>
                        </div>
                    </div>
                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary" ng-click="guardarTarea()">Grabar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Filtro de las Tarea -->
<div class="modal fade" id="modalNewFilter" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog .filter">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">
                    <span class="glyphicon glyphicon-filter" aria-hidden="true"></span>
                    <span id="title-filter">Filtrar tareas</span>
                </h4>
            </div>
            <form method="post" id="frm-filter">
                <div class="modal-body">

                    <div class="filtro-panel">
                        <div class="left menu-tipo-filtro">
                            <div class="btn-group-vertical" role="group">
                                <button class="btn btn-default" ng-click="anadirFiltroColaboradores()">Colaboradores</button>
                                <button class="btn btn-default" ng-click="anadirFiltroClientes()">Clientes</button>
                                <button class="btn btn-default" ng-click="anadirFiltroEstadoTarea()">Estado Tarea</button>
                                <button class="btn btn-default" ng-click="anadirFiltroLugarTarea()">Lugar Tarea</button>
                                <button class="btn btn-default" ng-click="anadirFiltroModulo()">Módulo</button>
                                <button class="btn btn-default" ng-click="anadirFiltroSede()">Sede</button>
                                <button class="btn btn-default" ng-click="anadirFiltroDepartamento()">Departamento</button>
                            </div>
                        </div>

                        <div class="left descripcion-filtro">
                            <button ng-click="desmarcarTodosValores()" class="btn btn-danger btn-xs right botones-filtro">Desmarcar Todos</button>
                            <button ng-click="marcarTodosValores()" class="btn btn-primary btn-xs right botones-filtro">Marcar Todos</button>

                            <div class="panel panel-default panel-valores-filtro">
                                Por favor seleccione un campo de filtrado
                            </div>
                            <div class="panel panel-default panel-json-filtro">
                                Filtro:
                            </div>
                        </div>
                    </div>

                    <div class="clear"></div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-warning" ng-click="limpiarFiltroTareas()">Limpiar</button>
                    <button type="button" class="btn btn-success" ng-click="aplicarFiltroTareas()">Filtrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal del envío de la semana -->
<div class="modal fade" id="modalEnvioAsig" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog .filter">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modalEnvioAsigLabel">
                    <span class="glyphicon glyphicon-envelope" aria-hidden="true"></span>
                    <span id="title-filter">Envío de Asignaciones</span>
                </h4>
            </div>
            <form method="post" id="frm-envio-email">
                <div class="modal-body">
                    {{textoEnviarEmail}} {{ fechaLunes }}. <br /> Establezca la contraseña de su email de SifizSoft.com.<br />
                    <label>Contraseña:</label>
                    <input type="password" ng-model="passEmail" class="form-control" />
                    <div class="clear"></div>

                    <div id="div-adicionar-copia-email">
                        <div id="desplegar-cuadro-emails-copia">CC:...</div>
                        <div id="cuadro-emails-copia">
                            <input type="text" id="adicionar-email-copia" ng-model="emailCopiaAdd" ng-keyup="adicionarEmail($event)" />
                            <div class="clear"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-primary" ng-click="enviarAsignacionesSemana()">Enviar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Asignaciones TFS-->
<div class="modal fade" id="modalAsignacionesTFS" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title">
                    <span class="glyphicon glyphicon-envelope" aria-hidden="true"></span>
                    <span id="title-filter">Solicitud de Acceso</span>
                </h4>
            </div>
            <form method="post" ng-submit="enviarCorreoTFS()">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <label for="clientes">Cliente:</label>
