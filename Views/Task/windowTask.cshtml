<!-- Para la actualización de los td de las tareas -->
<div id="div-actualizacion-td-tareas" class="invisible">
    <div data-id-tarea="{{tarea.id}}" data-tipo="{{tarea.tipo}}" class="content-tarea {{tarea.clase}}" ng-repeat="tarea in tareasTD"
         data-container="#task-container" data-toggle="popover" data-placement="right"
         data-title="{{
                        &quot;<div class='left'>&quot; + tarea.dCliente + &quot;</div>&quot; +
                        &quot;<div class='right'><span class='glyphicon glyphicon-menu-hamburger hand btn-tarea-repetir-vertical' data-id-tarea='&quot; + tarea.id + &quot;'</span></div>&quot; +
                        &quot;<div class='clear'></div>&quot;
                     }}"
         data-drag="true"
         data-jqyoui-options="{revert: 'invalid'}"
         jqyoui-draggable="{
                                animate: true,
                                placeholder: true,
                                onStart: 'startDrag( tarea.id, tarea.idColaborador, tarea.tipo )',
                                onDrag: 'actualizarTabla()'
                           }"
         data-content="{{tarea.tipo === &quot;t&quot; ?
                                            &quot;Actividad:&quot; + tarea.dActividad + &quot;<br>&quot; +
                                            &quot;Módulo:&quot; + tarea.dModulo + &quot;<br>&quot; +
                                            &quot;Desarrollarse en:&quot; + tarea.dLugar + &quot;<br>&quot; +
                                            (tarea.coordinador != null?&quot;Coordinar con:&quot;+tarea.coordinador+&quot;<br/>&quot;:&quot;&quot;) +
                                            &quot;Detalles:&quot; + tarea.detalle + &quot;<br>&quot; +
                                            &quot;Hora Inicio:&quot; + tarea.finicio + &quot;<br>&quot; +
                                            &quot;Hora Fin:&quot; + tarea.ffin + &quot;<br>&quot; +
                                            &quot;<button class='btn btn-xs btn-success btn-edittask' data-id-tarea='&quot; + tarea.id + &quot;'>Editar</button>&quot; +
                                            &quot;
                                                <div class='right estado-tarea'>
                                                    <span class='glyphicon glyphicon-time btn-tarea-compensatoria' data-id-tarea='&quot; + tarea.id + &quot;' title='Compensatoria - Poner/Quitar'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-adjust btn-tarea-preasignada' data-id-tarea='&quot; + tarea.id + &quot;' title='Pre-Asignar'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-new-window btn-tarea-asignada' data-id-tarea='&quot; + tarea.id + &quot;' title='Asignar'></span>
                                                    &nbsp;
                                                     <span class='glyphicon glyphicon-remove btn-anulartask' data-id-tarea='&quot; + tarea.id + &quot;' title='Anular'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-cog btn-tarea-desarrollo' data-id-tarea='&quot; + tarea.id + &quot;' title='En desarrollo'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-pause btn-tarea-pausa' data-id-tarea='&quot; + tarea.id + &quot;' title='En pausa'></span>
                                                    &nbsp;
                                                    <span class='glyphicon glyphicon-search btn-tarea-finish' data-id-tarea='&quot; + tarea.id + &quot;' title='Ver actividades'></span>
                                                </div>
                                            &quot;
                                        :
                                            &quot;Motivo:&quot; + tarea.detalle + &quot;<br>&quot; +
                                            &quot;Hora Inicio:&quot; + tarea.finicio + &quot;<br>&quot; +
                                            &quot;Hora Fin:&quot; + tarea.ffin + &quot;<br>&quot;
                                        }}"
         data-html="true" data-trigger="manual">

        <div class="cabecera-tarea {{tarea.compensatoria}}">
            <div class="nombre-cliente">{{tarea.cliente}}</div>
            <div class="lugar-tarea">{{tarea.lugar}}</div>
            <div class="clear"></div>
        </div>
        <div class="body-tarea">
            <div>
                <div class="codigo-actividad-tarea">{{tarea.tipo === 't'?'('+tarea.actividad+')':''}}</div>
                <div class="modulo-actividad-tarea">{{tarea.modulo}}</div>
            </div>
            <div class="clear"></div>
            <div class="detalle-tarea">
                {{tarea.sdetalle}}
            </div>
            <div class="horas-tarea">{{tarea.horas}}</div>
            <div class="clear"></div>
        </div>
    </div>
</div>

