                            <tr>
                                <th>Seleccionar</th>
                                <th>Colaborador</th>
                                <th>Sede</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr ng-repeat="colab in datosColaboradoresLugar | filter: filtroRepetirVertical">
                                <td style="text-align: center"><input type="checkbox" class="trab-check-rep-task" value="{{colab.id}}" /></td>
                                <td>{{mySplitEmail( colab.email, 0 )}}</td>
                                <td>{{colab.sede}}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                <button type="button" ng-click="repetirTareaColaboradoresSeleccionados()" class="btn btn-primary" data-dismiss="modal">Repetir Tarea</button>
            </div>
        </div>
    </div>
</div>