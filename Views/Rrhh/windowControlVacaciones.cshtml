            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Detalles</h4>
            </div>
            <div class="modal-body" style="column-count: 3">
                <div>
                    <strong>Apellidos y Nombres:</strong>
                    <span>{{solicitudVacacionesUsuario.ApellidosNombres}}</span>
                </div>
                <div>
                    <strong>Cargo:</strong>
