<div>
    <input type="text" id="filtro-permisos" placeholder="Filtrar..." ng-model-options='{ debounce: 1000 }' ng-change="recargarVacaciones()" ng-model="filtroPermisos" class="form-control right filtro" />
</div>
<div class="left">
    <div style="display: flex; align-items: center">
        <strong>Vacaciones/Permisos</strong>
        <input type="checkbox" style="transform: scale(1); margin-left: 5px; margin-bottom: 2px" ng-model="esVacaciones" ng-init="esVacaciones=true">
    </div>
</div>
<div class="clear"></div>
<div ng-show="esVacaciones" style="height: calc(100vh - 175px); width: 100%; overflow-y: auto;">
    <table class="table table-striped table-condensed">
        <thead>
            <tr>
                <th hidden>ID</th>
                <th></th>
                <th>Acciones</th>
                <th>Estado</th>
                <th>Apellidos Nombres</th>
                <th>Cargo</th>
                <th>Cédula</th>
                <th>Fecha Ingreso Solicitud</th>
                <th>Empresa</th>
                <th>Años Servicio</th>
                <th>Dias Corresponden</th>
                <th>Dias Disfrutar</th>
                <th>Dias Pendientes</th>
                <th>Del Año</th>
                <th>Al Año</th>
                <th>Fecha Inicio Vacaciones</th>
                <th>Fecha Fin Vacaciones</th>
                <th>Fecha Presentarse Trabajar</th>
                <th>Jefe</th>
                <th>Observaciones</th>
            </tr>
        </thead>

        <tbody>
            <tr ng-repeat="solicitudVac in vacaciones">
                <td hidden>{{solicitudVac.ID}}</td>
                <td> <button type="button" class="btn btn-link" ng-click="showVacDetail(solicitudVac)">Ver</button> </td>
                <td>
                    <div style="display: flex; align-items: center">
                        <button class="btn btn-link" ng-click="aceptarVacaciones(solicitudVac)">
                            <span class="glyphicon glyphicon-ok" style="color: seagreen"></span>
                        </button>
                        <button class="btn btn-link" ng-click="rechazarSolicitudVacaciones(solicitudVac)">
                            <span class="glyphicon glyphicon-remove" style="color: darkred"></span>
                        </button>
                    </div>
                </td>
                <td ng-if="solicitudVac.Estado === 'PENDIENTE'">
                    <div style="display: flex; align-items: center">
                        <span class="badge" style="background-color: goldenrod;">&nbsp;</span>&nbsp;{{solicitudVac.Estado}}
                    </div>
                </td>
                <td ng-if="solicitudVac.Estado === 'APROBADA'">
                    <div style="display: flex; align-items: center">
                        <span class="badge" style="background-color:seagreen">&nbsp;</span>&nbsp;{{solicitudVac.Estado}}
                    </div>
                </td>
                <td ng-if="solicitudVac.Estado === 'RECHAZADA'">
                    <div style="display: flex; align-items: center">
                        <span class="badge" style="background-color:darkred">&nbsp;</span>&nbsp;{{solicitudVac.Estado}}
                    </div>
                </td>
                <td>{{solicitudVac.ApellidosNombres}}</td>
                <td>{{solicitudVac.Cargo}}</td>
                <td>{{solicitudVac.Cedula}}</td>
                <td>{{solicitudVac.FechaIngresoSolicitud | strDateToStr}}</td>
                <td>{{solicitudVac.Empresa}}</td>
                <td>{{solicitudVac.AniosServicio}}</td>
                <td>{{solicitudVac.DiasCorresponden}}</td>
                <td>{{solicitudVac.DiasDisfrutar}}</td>
                <td>{{solicitudVac.DiasPendientes}}</td>
                <td>{{solicitudVac.DelAnio}}</td>
                <td>{{solicitudVac.AlAnio}}</td>
                <td>{{solicitudVac.FechaInicioVacaciones | strDateToStr}}</td>
                <td>{{solicitudVac.FechaFinVacaciones | strDateToStr}}</td>
                <td>{{solicitudVac.FechaPresentarseTrabajar | strDateToStr}}</td>
                <td>{{solicitudVac.Jefe}}</td>
                <td>{{solicitudVac.Observaciones}}</td>
            </tr>
        </tbody>
    </table>
</div>
<div ng-show="!esVacaciones" style="height: calc(100vh - 175px); width: 100%; overflow-y: auto; overflow-x: no-display;">
