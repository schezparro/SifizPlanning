                <h5 class="modal-title"><span class="glyphicon glyphicon-comment" aria-hidden="true"></span> Rechazar Permiso</h5>
            </div>
            <div class="modal-body">
                Comentario de rechazo de permiso:
                <textarea class="form-control" ng-model="rechazoPermisoComentario" maxlength="300" rows="8" ng-required="true"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" data-dismiss="modal" ng-click="rechazarPermiso()">Enviar</button>
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

