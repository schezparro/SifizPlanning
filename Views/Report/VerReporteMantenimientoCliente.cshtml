@using ReportViewerForMvc;
<html>

<head>
    <title>Reporte Sifizplanning</title>
    <style>
        html, body {
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background-color: #f8f9fa;
        }

        .buttons-container {
            width: 100%;
            text-align: center;
            margin-top: 10px;
        }

            .buttons-container .btn {
                margin: 5px;
                padding: 10px 20px;
                font-size: 16px;
                transition: background-color 0.3s ease;
            }

        .btn-success {
            background-color: #28a745;
            color: white;
        }

            .btn-success:hover {
                background-color: #218838;
            }

        .btn-danger {
            background-color: #dc3545;
            color: white;
        }

            .btn-danger:hover {
                background-color: #c82333;
            }

        .report-container {
            width: 100%;
            height: calc(100vh - 50px); /* Ajusta la altura para dejar espacio a los botones */
            padding: 10px;
            box-sizing: border-box;
        }

        iframe {
            width: 100%;
            height: 100%;
            border: none;
        }
    </style>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet"> <!-- Inclusión de Bootstrap CSS -->
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script> <!-- Inclusión de jQuery -->
</head>

<body>
    <div class="buttons-container">
        <button class="btn btn-success btn-sm" onclick="acceptReport()">Aceptar</button>
        <button class="btn btn-danger btn-sm" onclick="rejectReport()">Rechazar</button>
    </div>
    <div class="report-container">
        @Html.ReportViewer(ViewBag.ReportViewer as Microsoft.Reporting.WebForms.ReportViewer)
    </div>
    <script>
        function acceptReport() {
            $.ajax({
                url: '@Url.Action("AcceptReport", "Report")',
                type: 'POST',
                success: function(response) {
                    alert('Reporte aceptado');
                },
                error: function() {
                    alert('Error al aceptar el reporte');
                }
            });
        }

        function rejectReport() {
            $.ajax({
                url: '@Url.Action("RejectReport", "Report")',
                type: 'POST',
                success: function(response) {
                    alert('Reporte rechazado');
                },
                error: function() {
                    alert('Error al rechazar el reporte');
                }
            });
        }
    </script>
</body>

</html>
