@using ReportViewerForMvc;
<html>

<head>
    <title>Reporte Sifizplanning</title>
    <style>
        html, body {
            width: 100%;
            height: 100%;
        }

        iframe {
            width: 100%;
            height: 100%;
        }

        <style > html, body {
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background-color: #f8f9fa;
        }

        .report-container {
            width: 100%;
            height: calc(100vh - 70px); /* Ajusta la altura para dejar espacio a los botones */
            border: 1px solid #dee2e6;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            background-color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .buttons-container {
            width: 100%;
            text-align: center;
            margin-top: 10px;
        }

            .buttons-container .btn {
                margin: 5px;
                padding: 10px 20px;
                font-size: 16px;
                transition: background-color 0.3s ease;
            }

        .btn-success {
            background-color: #28a745;
            color: white;
        }

            .btn-success:hover {
                background-color: #218838;
            }

        .btn-danger {
            background-color: #dc3545;
            color: white;
        }

            .btn-danger:hover {
                background-color: #c82333;
            }
    </style>
</head>

<body>
    <div class="buttons-container">
        <button class="btn btn-success btn-sm" onclick="acceptReport()">Aceptar</button>
        <button class="btn btn-danger btn-sm" onclick="rejectReport()">Rechazar</button>
    </div>
    <div style="width: 100%; height: 100%;">
        @Html.ReportViewer(ViewBag.ReportViewer as Microsoft.Reporting.WebForms.ReportViewer)
    </div>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>

</html>