@{
    ViewBag.Title = "Bienvenido a los Reportes de SifizPlanning";
}
@using ReportViewerForMvc;

<!DOCTYPE html>

<html ng-app="admin">
<head>
    <!--<meta name="viewport" content="width=device-width" />-->
    <title>@ViewBag.Title</title>
    <link href="~/Web/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Web/css/bootstrap-theme.min.css" rel="stylesheet" />
    <link href="~/Web/css/datepicker.css" rel="stylesheet" />
    <link href="~/Web/css/jasny-bootstrap.min.css" rel="stylesheet" />
    <link href="~/Web/css/admin/admin.css" rel="stylesheet" />
    <link href="~/Web/css/home/home.css" rel="stylesheet" />
    <link href="~/Web/css/jquery.bonsai.css" rel="stylesheet" />
    <link href="~/Web/css/font-awesome.css" rel="stylesheet" />

    <script type="text/javascript" src="~/Web/js/jquery-2.1.3.min.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.signalR-2.1.2.min.js"></script>
    <script type="text/javascript" src="~/signalr/hubs"></script>
    <script type="text/javascript" src="~/Web/js/angular.min.js"></script>
    <script type="text/javascript" src="~/Web/js/dirPagination.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.bonsai.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.qubit.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.json-list.js"></script>
</head>
<body ng-controller="adminController">
    <div id="panel-modulo" class="panel panel-primary">
        <div class="panel-heading">
            <div class="row">
                <div class="col-md-6">
                    <h3 class="left panel-title">Reportes de SifizPlanning</h3>
                </div>
                <div class="col-md-6">
                    <a href="cerrar/sesion/" class="pull-right btn btn-default"><span class="glyphicon glyphicon-off"></span> Cerrar Sesión</a>
                    <a href="main-menu" style="margin-right: 4px;" class="pull-right btn btn-warning"><span class="glyphicon glyphicon-menu-hamburger"></span> Menú Principal</a>
                </div>
            </div>
        </div>
        <div class="panel-body">

            <div id="div-select">
                <span style="float:left; margin:5px 0px 0px 0px; padding:0px 20px 0px 0px">MODULO:</span>
                <select id="select-modulos" class="form-control" style="width:300px; float:left;" ng-mouseenter="CargarModulos()" ng-click="CargarNombreReportes()">
                    <option>Seleccione...</option>
                    <option ng-repeat="modulo in modulosReportes">{{modulo}}</option>
                </select>

                <span style="float:left; margin:5px 0px 0px 0px; padding:0px 20px 0px 0px">&nbsp &nbsp &nbsp REPORTE:</span>
                <select id="select-nombre-reporte" class="form-control" style="width:300px; float:left;">
                    <option>Seleccione...</option>
                    <option ng-repeat="reporte in reportesText">{{reporte.nombre}}</option>
                </select>

                <span style="float:left">&nbsp &nbsp &nbsp</span>

                <input type="button" style="float:left;" value="Ver Reporte" class="btn btn-primary" ng-click="VisualizarReporte()" />

                <a id="ver-reporte" href="" target="_blank"></a>

            </div>

            <br /><br />

            @*<span> @Url.Action("VerReporte", "Report", new { modulo = "Clientes", reporte = "Cliente por Modulo" }) </span>

            <div id="vista-reporte" style="width: 1470px; height: 600px;">

            </div>*@

        </div>
    </div>

    <script type="text/javascript" src="~/Web/js/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Web/js/bootstrap-datepicker.js"></script>
    <script type="text/javascript" src="~/Web/js/jasny-bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Web/js/chat.js"></script>
    <script type="text/javascript" src="~/Web/js/waiting.js"></script>
    <script type="text/javascript" src="~/Web/js/admin/admin.js"></script>
</body>
</html>