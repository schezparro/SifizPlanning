<div>
    <button id="btn-new-worker" type="button" class="btn btn-primary" data-toggle="modal" data-target="#modalNewWorker">
        <span class="glyphicon glyphicon-plus" aria-hidden="true"></span> Nuevo Colaborador
    </button>
    <button type="button" class="btn btn-primary" ng-click="modalEditarTrabajador()">
        <span class="glyphicon glyphicon-user" aria-hidden="true"></span> Gestión de Acceso
    </button>
    <!--<button type="button" class="btn btn-primary" ng-click="modalFuncionesTrabajador()">
        <span class="glyphicon glyphicon-wrench" aria-hidden="true"></span> Gestión de Funciones
    </button>-->
    <button type="button" class="btn btn-primary" ng-click="modalNivelEnModulos()">
        <span class="glyphicon glyphicon-wrench" aria-hidden="true"></span> Nivel en Módulos
    </button>
    <!--<button type="button" class="btn btn-primary" ng-click="modalCompetenciasGenerales()">
        <span class="glyphicon glyphicon-wrench" aria-hidden="true"></span> Competencias Generales
    </button>-->
    <button type="button" class="btn btn-primary" ng-click="modalNivelEnTecnologias()">
        <span class="glyphicon glyphicon-wrench" aria-hidden="true"></span> Nivel en Tecnologias y Procesos
    </button>
    <div class="right">
        <input class="form-control form-control-sm" ng-model="filtroColaboradores" ng-keyup="filtrarColaboradores()" placeholder="Filtrar..." />
    </div>
</div>

<div style="height: calc(100% - 40px); overflow-y: scroll; margin-top: 5px;">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th style="text-align: center;">Foto</th>
                <th>Nombre</th>
                <th>Email</th>
                <th>Departamento</th>
                <th>Cargo</th>
                <th>Sede</th>
                <th>Publicaciones DosCinco</th>
                <th style="text-align: center;">Usuario Activo</th>
                <th>Editar</th>
                <th>Eliminar</th>
            </tr>
            <tr>
                <th></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control form-control-sm" ng-model="nombreFiltro" ng-change="filterData(1)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control form-control-sm" ng-model="emailFiltro" ng-change="filterData(2)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control form-control-sm" ng-model="departamentoFiltro" ng-change="filterData(3)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control form-control-sm" ng-model="cargoFiltro" ng-change="filterData(4)" /></th>
                <th><input ng-model-options='{ debounce: 1000 }' type="text" class="form-control form-control-sm" ng-model="sedeFiltro" ng-change="filterData(5)" /></th>
                <th>
                    <select id="select-publicaciones-doscinco" class="form-control form-control-sm">
                        <option>Seleccione...</option>
                        <option>SI</option>
                        <option>NO</option>
                    </select>
                </th>
                <th>
                    <select id="select-usuario-activo" class="form-control form-control-sm">
                        <option>Seleccione...</option>
                        <option>SI</option>
                        <option>NO</option>
                    </select>
                </th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <tr ng-repeat="trab in trabajadores" data-id="{{ trab.idtrabajador }}" ng-click="selectTrabajador()">
                <td><img class="img-worker" ng-src="{{rutaImages}}{{trab.url}}" /></td>
                <td>{{ trab.nombre }}</td>
                <td>{{ trab.email }}</td>
                <td>{{ trab.departamento }}</td>
                <td>{{ trab.cargo }}</td>
                <td>{{ trab.sede }}</td>
                <td style="text-align: center;">{{ trab.publicacionesDosCinco }}</td>
                <td style="text-align: center;">{{ trab.userAct }}</td>
                <td> <a class="editar-option" href="#" ng-click="editarTrabajador()"> Editar </a> </td>
                <td> <a class="eliminar-option" href="#"> Eliminar </a> </td>
            </tr>
        </tbody>
    </table>
</div>

<!-- Modal Nuevo Trabajador-->
<div class="modal fade" id="modalNewWorker" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">
                    <span class="glyphicon glyphicon-user" aria-hidden="true"></span>
                    <span id="title-new-worker">Nuevo Colaborador</span>
                </h4>
            </div>
            <form method="post" id="frm-newWorker">
                <div class="modal-body">

                    <div class="fila">
                        <div class="left">
                            <label>Primer Nombre:</label><br />
                            <input type="text" required="required" ng-model="nombre1" class="form-control form-control-sm" />
                        </div>

                        <div class="left">
                            <label>Segundo Nombre:</label><br />
                            <input type="text" ng-model="nombre2" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Primer Apellido:</label><br />
                            <input type="text" required="required" ng-model="apellido1" class="form-control form-control-sm" />
                        </div>
                        <div class="left">
                            <label>Segundo Apellido:</label><br />
                            <input type="text" ng-model="apellido2" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Sexo:</label>
                            <select required="required" ng-model="sexo" class="form-control form-control-sm">
                                <option value="">Seleccione...</option>
                                <option value="M">Masculio</option>
                                <option value="F">Femenino</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Fecha Nacimiento:</label>
                            <input type="text" required="required" class="form-control form-control-sm" id="dtpk-fecha_nac" ng-model="fecha_nac" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Nacionalidad:</label>
                            <select ng-model="nacionalidad" required="required" class="form-control form-control-sm" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="pais in paises" value="{{ pais.id }}">{{ pais.nombre }}</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Correo Electrónico:</label><br />
                            <input type="email" required="required" ng-model="email" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Cargo:</label>
                            <select ng-model="cargo" required="required" class="form-control form-control-sm" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="cargo in cargos" value="{{ cargo.id }}">{{ cargo.nombre }}</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Sede:</label>
                            <select ng-model="sede" required="required" class="form-control form-control-sm" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="sede in sedes" value="{{ sede.id }}">{{ sede.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <div><label>Foto:</label></div>
                            <div class="fileinput fileinput-new" data-provides="fileinput">
                                <div class="fileinput-preview thumbnail" data-trigger="fileinput" style="width: 180px; height: 150px;"></div>
                                <div>
                                    <span class="btn btn-default btn-file"><span class="fileinput-new">Buscar Imagen</span><span class="fileinput-exists">Cambiar</span><input type="file" name="file" id="file-foto"></span>
                                    <a href="#" class="btn btn-default fileinput-exists" id="button-borrar-foto" data-dismiss="fileinput">Borrar</a>
                                </div>
                            </div>
                        </div>
                        <div class="left">
                            <label>Departamento:</label>
                            <select ng-model="departamento" required="required" class="form-control form-control-sm" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="dep in departamentos" value="{{ dep.id }}">{{ dep.nombre }}</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Fecha de Ingreso:</label>
                            <input type="text" required="required" class="form-control form-control-sm" id="dtpk-fecha_ing" ng-model="fechaIngreso" />
                        </div>
                        <div style="vertical-align: middle; justify-content: space-between">
                            <label>Publicaciones Dos-Cinco:</label>
                            <input ng-model="publicacionesDosCinco" type="checkbox" />
                        </div>
                    </div>

                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary" ng-click="guardarTrabajador()">Grabar</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Modal Gestion Usuario -->
<div class="modal fade" id="modalEditUser" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel"><span class="glyphicon glyphicon-user" aria-hidden="true"></span> Gestión de Acceso</h4>
            </div>
            <form method="post" id="frm-editUser">
                <div class="modal-body">
                    <div>
                        <label>Colaborador:</label> {{nombreTrabajador}}
                    </div>
                    <div class="fila">
                        <div class="left">
                            <label>Contraseña:</label><br />
                            <input type="password" ng-model="passw1" class="form-control form-control-sm" />
                        </div>

                        <div class="left">
                            <label>Repita la Contraseña:</label><br />
                            <input type="password" ng-model="passw2" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Activado:</label>
                            <select required="required" ng-model="usuarioActivo" class="form-control form-control-sm">
                                <option value="">Seleccione...</option>
                                <option value="1">SI</option>
                                <option value="0">NO</option>
                            </select>
                        </div>

                        <div class="left">
                            <label>Usuario TFS:</label>
                            <input type="text" class="form-control form-control-sm" ng-model="usuarioTFS" />
                        </div>

                        <div class="clear"></div>
                    </div>

                    <div id="div-roles-colaboradores">
                        <div><label>Roles:</label></div>

                        <!--
                            <div style="display: inline;"><input name="roles" ng-model="rol" type="checkbox" value="312"/>:kasjdaksdjasd</div>
                            <div style="display: inline;" ng-repeat="rol in roles"><input name="roles" ng-model="rol" type="checkbox" value="rol.id"/>:rol.nombre&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
                        -->
                    </div>
                    <div class="clear"></div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary" ng-click="guardarUsuario()">Grabar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Gestion de Funciones -->
