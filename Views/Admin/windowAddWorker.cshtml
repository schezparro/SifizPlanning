                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel"><span class="glyphicon glyphicon-user" aria-hidden="true"></span> Gestión de Funciones</h4>
            </div>
            <form method="post" id="frm-editFunciones">
                <div class="modal-body">

                    <div>
                        <label>Colaborador:</label> {{nombreTrabajador}}
                    </div>

                    <div class="fila">
                        <div class="left">
                            <label>Jefe Inmediato:</label><br />
                            <select id="selectJefeInmediato" ng-model="jefeInmediato" class="form-control form-control-sm">
                                <option value="">Seleccione...</option>
