                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Gestión del Nivel de Conocimientos sobre Modulos -->
<div class="modal fade" id="modal-edit-nivel-modulo" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="label-modal-edit-nivel-modulo"><span class="glyphicon glyphicon-user" aria-hidden="true"></span> Nivel del Colaborador en Módulos</h4>
            </div>
            <form method="post" id="frm-edit-nivel-modulo">
                <div class="modal-body">

                    <div>
                        <label>Colaborador:</label> {{nombreTrabajador}}
                    </div>

                    <div class="fila">
                        <div id="tabla-nivel-colaborador-modulo">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Módulo</th>
                                        <th>Nivel de Conocimiento</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="mod in nivelModulos">
                                        <td>{{mod.modulo}}</td>
                                        <td class="nivel-star-colaborador" data-id-modulo="{{mod.idModulo}}" data-nivel="{{mod.nivel}}">
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                        </td>
                                        <td><span class="level-star-eliminar glyphicon glyphicon-remove" title="Poner el nivel en 0 para este módulo"></span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Gestión del Nivel de Conocimientos sobre Tecnologias y Procesos-->
<div class="modal fade" id="modal-edit-nivel-tecnologia" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="label-modal-edit-nivel-tecnologia"><span class="glyphicon glyphicon-user" aria-hidden="true"></span> Nivel del Colaborador en Tecnologias</h4>
            </div>
            <form method="post" id="frm-edit-nivel-tecnologia">
                <div class="modal-body">

                    <div>
                        <label>Colaborador:</label> {{nombreTrabajador}}
                    </div>

                    <div class="fila">
                        <div id="tabla-nivel-colaborador-tecnologia">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Tecnologia</th>
                                        <th>Nivel de Conocimiento</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="tec in nivelTecnologias">
