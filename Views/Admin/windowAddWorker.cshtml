                                            <span class="level-star glyphicon glyphicon-star"></span>
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                        </td>
                                        <td><span class="level-star-eliminar glyphicon glyphicon-remove" title="Poner el nivel en 0 para este módulo"></span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Gestión de competencias en desarrollo de software -->
<div class="modal fade" id="modal-edit-competencias-software" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="label-modal-edit-competencias-software"><span class="glyphicon glyphicon-user" aria-hidden="true"></span> Competencias Software</h4>
            </div>
            <form method="post" id="frm-edit-competencias-software">
                <div class="modal-body">
                    <div>
                        <label>Colaborador:</label> {{nombreTrabajador}}
                    </div>

                    <div class="fila">
                        <div class="left un-tercio half-padding-right">
                            <label>Categoría:</label>
                            <select class="form-control form-control-sm" ng-model="categoriaSoftware" ng-change="modalCompetenciasGenerales(1)">
                                <option value="">Todos...</option>
                                <option ng-repeat="categ in categoriasSoft" value="{{categ.id}}">{{categ.codigo}}</option>
                            </select>
                        </div>
                        <div class="left un-tercio half-padding-left">
                            <label>Sub-Categoría:</label>
                            <select class="form-control form-control-sm" ng-model="subCategoriaSoftware" ng-change="modalCompetenciasGenerales()">
                                <option value="">Todos...</option>
                                <option ng-repeat="subCateg in subCategoriasSoft" value="{{subCateg.id}}">{{subCateg.codigo}}</option>
                            </select>
                        </div>
                        <div class="clear"></div>
                    </div>

                    <div class="fila">
                        <div id="tabla-nivel-competencias-software">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Categoría</th>
                                        <th>Sub-Categoría</th>
                                        <th>Competencia</th>
                                        <th>Nivel</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="competencia in competenciasSoft">
                                        <td>{{competencia.codigoCategoria}}</td>
                                        <td>{{competencia.codigoSubCategoria}}</td>
                                        <td>{{competencia.codigoCompetencia}}</td>
                                        <td class="nivel-star-competencia-colaborador" data-id-competencia="{{competencia.idCompetencia}}" data-nivel="{{competencia.nivel}}">
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                            <span class="level-star glyphicon glyphicon-star"></span>
                                        </td>
                                        <td><span class="level-star-eliminar glyphicon glyphicon-remove" title="Poner el nivel en 0 para esta competencia"></span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>
