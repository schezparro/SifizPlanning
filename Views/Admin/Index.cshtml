@{
    ViewBag.Title = "Bienvenido a la Administración de SifizPlanning";
}

<!DOCTYPE html>

<html ng-app="admin">
<head>
    <!--<meta name="viewport" content="width=device-width" />-->
    <title>@ViewBag.Title</title>
    <link href="~/Web/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Web/css/bootstrap-theme.min.css" rel="stylesheet" />
    <link href="~/Web/css/datepicker.css" rel="stylesheet" />
    <link href="~/Web/css/jasny-bootstrap.min.css" rel="stylesheet" />
    <link href="~/Web/css/admin/admin.css" rel="stylesheet" />
    <link href="~/Web/css/jquery.bonsai.css" rel="stylesheet" /> 
    <link href="~/Web/css/font-awesome.css" rel="stylesheet" /> 

    <script type="text/javascript" src="~/Web/js/jquery-2.1.3.min.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.signalR-2.1.2.min.js"></script>
    <script type="text/javascript" src="~/signalr/hubs"></script>
    <script type="text/javascript" src="~/Web/js/angular.min.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.bonsai.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.qubit.js"></script>
    <script type="text/javascript" src="~/Web/js/jquery.json-list.js"></script>

</head>
<body ng-controller="adminController">

    <div id="content_body">

        <div id="menu-principal">
            <ul class="nav nav-pills">
                                
                <li role="presentation" class="active"><a href="#" ng-click="IrTrabajador()">Gestionar Colaboradores</a></li>
                <li class="dropdown" role="presentation">
                    <a class="dropdown-toggle" data-toggle="dropdown" href="#" role="button" aria-expanded="false">Gestionar Clientes <span class="caret"></span></a>
                    <ul class="dropdown-menu" role="menu">
                        <li>
                            <a href="#" ng-click="IrClientes()">Usuarios Clientes</a>
                        </li>
                        <li>
                            <a href="#" ng-click="IrContratosClientes()">Contratos Clientes</a>
                        </li>
                    </ul>
                </li>
                <li role="presentation"><a href="#" ng-click="IrCatalogos()">Gestionar Catálogos</a></li>
                <li role="presentation"><a href="#" ng-click="IrCorreosNoEnviados()">Gestionar Correos No Enviados</a></li>
                
                <a href="cerrar/sesion/" class="right btn btn-danger"><span class="glyphicon glyphicon-off"></span> Cerrar Sesión</a>
                <a href="main-menu" style="margin-right: 4px;" class="right btn btn-warning"><span class="glyphicon glyphicon-menu-hamburger"></span> Menú Principal</a>
            </ul>            
        </div>

        <div id="panel-principal" class="panel panel-default" ng-init="funcionalidad = 'COLABORADORES'">
            <div class="panel-heading">
                <h3 class="panel-title">{{ funcionalidad }}</h3>
            </div>

            <div id="funcionalidad">                

                <div id="panel_workers" ng-controller="workerController">
                    @{Html.RenderPartial("windowAddWorker");}
                </div>

                <div id="panel_user_clientes" class="invisible" ng-controller="clientController">
                    @{Html.RenderPartial("windowAddAdminClientes");}
                </div>

                <div id="panel_contratos_clientes" class="invisible" ng-controller="clientController">
                    @{Html.RenderPartial("windowAddContratoClientes");}
                </div>

                <div id="panel_catalogos" class="invisible" ng-controller="catalogosController">                    
                    @{Html.RenderPartial("windowAddCatalogos");}
                </div>

                <div id="panel_correosNoEnviados" class="invisible" ng-controller="correosNoEnviadosController">
                    @{Html.RenderPartial("windowAddCorreosNoEnviados");}
                </div>

                <div id="loadingDiv">
                    <img src="~/Web/images/ajax-loader.gif" />
                </div>

            </div>

        </div>

    </div> 
    
    <!-- CODIGO DEL CHAT -->
    <div id="sifiz-chat" style="display: none;">
        <div id="head-sifiz-chat" class="btns-chat">
            <div class="left nombre-usuario-local"></div>
            <div class="right"> <i class="glyphicon glyphicon-chevron-down"></i></div>
            <div class="clear"></div>
        </div>
        <div style="padding: 3px;">
            <input id="filtro-chat" type="text" class="form-control" placeholder="Filtrar..." />
        </div>
        <div id="body-sifiz-chat" style="display: block;">
            <div id="panel-usuarios-sfz">

            </div>
        </div>
    </div>

    <div id="ventanas-activas-chat">

    </div>

    <div id="div-usuario-chat">
        <div class="usuario-chat" data-id="">
            <div class="estado-usuario left active"><i class="glyphicon glyphicon-ok-sign"></i></div>
            <div class="left nombre-usuario"></div>
            <div class="clear"></div>
        </div>
    </div>
    <div id="ventana-chat-conversacion" style="display: none;">
        <div class="ventana-chat">
            <div class="heading-ventana-chat">
                <div class="left nombre-contacto">Henry Cruz</div>
                <div class="right"><i class="glyphicon glyphicon-remove"></i></div>
                <div class="clear"></div>
            </div>
            <div class="chat-text-ventana-chat">

            </div>
            <div class="text-ventana-chat">
                <textarea data-id-persona=""></textarea>
            </div>
        </div>
    </div>
    <audio id="audio-chat" controls="controls">
        <source src="~/Web/sounds/happy-ending.mp3" type="audio/mpeg" />
    </audio>
    <!-- FIN DEL CODIGO DEL CHAT -->   
        
    <script type="text/javascript" src="~/Web/js/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Web/js/bootstrap-datepicker.js"></script>
    <script type="text/javascript" src="~/Web/js/jasny-bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Web/js/highcharts.js"></script>
    <script type="text/javascript" src="~/Web/js/chat.js"></script>
    <script type="text/javascript" src="~/Web/js/waiting.js"></script>
    <script type="text/javascript" src="~/Web/js/admin/admin.js"></script>
    <script type="text/javascript" src="~/Web/js/admin/workerController.js"></script>
    <script type="text/javascript" src="~/Web/js/admin/clientController.js"></script>
    <script type="text/javascript" src="~/Web/js/admin/catalogosController.js"></script>
    <script type="text/javascript" src="~/Web/js/admin/correosNoEnviadosController.js"></script>
</body>
</html>
