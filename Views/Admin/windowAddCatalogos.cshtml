<!-- Windows Modal Gestion de Catálogos -->
<div class="modal fade" id="modalEditCatalogos" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modalCatalogoLabel"><span class="glyphicon glyphicon-user" aria-hidden="true"></span> Gestión Tabla X</h4>
            </div>
            <form method="post" id="frm-editCatalogos">
                <div class="modal-body">
                    <div id="data-campos-catalogos">

                    </div>
                    <input type="hidden" name="idTuplaCatalogo" ng-model="idTuplaCatalogo" />
                    <input type="hidden" name="numVerificadorCatalogo" ng-model="numVerificadorCatalogo" />
                    <div id="label-actividad" style="padding: 10px 0px 0px 0px">

                    </div>
                    <div id="data-actividades-realizadas" style="padding:5px 0px 0px 0px;">

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary" ng-click="guardarCatalogo()">Grabar</button>
                </div>
            </form>
        </div>
    </div>
</div>