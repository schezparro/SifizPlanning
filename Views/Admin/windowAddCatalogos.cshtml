<div id="lista-catalogos" class="left">
    <input type="text" ng-keyup="filtrarCatalogos()" ng-model="filtroCatalogos" class="form-control" placeholder="Filtrar catalogos..." />
    <div id="lista-tabla-catalogo" class="panel panel-default separar-arriba">
        <div class="panel-body">
            <div class="tabla-catalogo separar-arriba" ng-click="seleccionarCatalogo()" data-idtabla="{{tabla.id}}" ng-repeat="tabla in tablasCatalogos">
                {{ tabla.nombre }}
            </div>
        </div>
    </div>
</div>

<div id="edicion-catalogos">
    <div id="cabecera-edicion-catalogos">
        <button class="btn btn-primary" ng-click="adicionarTuplaCatalogo()"><span class="glyphicon glyphicon-plus"></span> Adicionar</button>
        <button class="btn btn-success" ng-click="editarTuplaCatalogo()"><span class="glyphicon glyphicon-pencil"></span> Editar</button>
        <button class="btn btn-danger" ng-click="eliminarTuplaCatalogo()"><span class="glyphicon glyphicon-remove"></span> Eliminar</button>

        <div id="divFilterCatalogos">
            <input type="text" id="campoFiltroCatalogo" ng-keyup="actualizarDataFiltro()" ng-model="campoFiltroCatalogo" class="form-control" placeholder="Filtrar..." />
        </div>
    </div>
    <div class="clear"></div>
    <div id="divMsgSuccess" class="alert alert-success" role="alert"></div>
    <div id="divMsgDanger" class="alert alert-danger" role="alert"></div>
    <div class="clear"></div>
    <div class="panel panel-primary separar-arriba">
        <div class="panel-heading">
            <h3 class="panel-title">Datos</h3>
        </div>
        <div class="panel-body">
            <div id="data-tabla-catalogos">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th ng-repeat="campo in campos">{{campo.nombre}}</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr data-id="{{data.d1}}" ng-click="seleccionarTuplaTabla()" ng-repeat="data in datosTabla">
                            <td ng-repeat="(key,value) in data |orderBy:'$index'">{{value}}</td>
                        </tr>
                    </tbody>

                </table>
                <div id="paginadorCatalogos"></div>
            </div>
        </div>
    </div>

</div>

