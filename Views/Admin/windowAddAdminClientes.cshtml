<div>
    <button id="btn-new-worker" type="button" class="btn btn-primary" data-toggle="modal" data-target="#modalNewClient">
        <span class="glyphicon glyphicon-plus glyphicon-user" aria-hidden="true"></span> Nuevo Usuario de Cliente
    </button>
    
    <div class="right">
        <input class="form-control" ng-model="filtroClientes" ng-keyup="filtrarUsuariosClientes()" placeholder="Filtrar..." />
    </div>
</div>

<div id="div-tabla-clientes">
    <table class="table table-striped">
        <thead id="thead-usuariosclientes">
            <tr>
                <th style="width: 28%;">Nombre</th>
                <th style="width: 14%;">Email</th>
                <th style="width: 14%;">Cliente</th>
                <th style="width: 14%;">Teléfono</th>
                <th style="width: 14%; text-align: center;">Usuario Activo</th>
                <th style="width: 9%;">Editar</th>
                <th style="width: 8%;">Eliminar</th>
            </tr>
        </thead>

        <tbody id="tbody-usuariosclientes">
            <tr class="table-tr" ng-repeat="client in usuariosClientes" data-id="{{ client.idUserClient }}" ng-click="selectUsuarioCliente()">
                <td style="width: 28%;">{{ client.nombre }}</td>
                <td style="width: 14%;">{{ client.email }}</td>
                <td style="width: 10%;">{{ client.cliente }}</td>
                <td style="width: 10%;">{{ client.telefono }}</td>
                <td style="width: 10%;  text-align: center;">{{ client.userAct }}</td>
                <td style="width: 9%;"> <a class="editar-option-client" href="#" ng-click="editarUsuarioClient()"> Editar </a> </td>
                <td style="width: 8%;"> <a class="eliminar-option-client" href="#" ng-click="eliminarUsuarioClient()"> Eliminar </a> </td>
            </tr>
        </tbody>
    </table>
</div>

<!-- Modal Nuevo Usuario Cliente -->
<div class="modal fade" id="modalNewClient" tabindex="-1" role="dialog" aria-labelledby="myModalLabelClient" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabelClient">
                    <span class="glyphicon glyphicon-user" aria-hidden="true"></span>
                    <span id="title-new-worker">Nuevo Usuario de Cliente</span>
                </h4>
            </div>
            <form method="post" id="frm-newClient" ng-submit="guardarUsuarioClient()">
                <div class="modal-body">

                    <div class="fila">
                        <div class="left">
                            <label>Primer Nombre:</label><br />
                            <input type="text" required="required" ng-model="clientNombre1" class="form-control" />
                        </div>

                        <div class="left">
                            <label>Segundo Nombre:</label><br />
                            <input type="text" ng-model="clientNombre2" class="form-control" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Primer Apellido:</label><br />
                            <input type="text" required="required" ng-model="clientApellido1" class="form-control" />
                        </div>
                        <div class="left">
                            <label>Segundo Apellido:</label><br />
                            <input type="text" ng-model="clientApellido2" class="form-control" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Sexo:</label>
                            <select required="required" ng-model="clientSexo" class="form-control">
                                <option value="">Seleccione...</option>
                                <option value="M">Masculio</option>
                                <option value="F">Femenino</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Fecha Nacimiento:</label>
                            <input type="text" required="required" class="form-control" id="dtpk-fecha_nac-client" ng-model="clientFecha_nac" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Nacionalidad:</label>
                            <select ng-model="clientNacionalidad" required="required" class="form-control" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="pais in paises" value="{{ pais.id }}">{{ pais.nombre }}</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Correo Electrónico:</label><br />
                            <input type="email" required="required" ng-model="clientEmail" class="form-control" />
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Cliente:</label>
                            <select ng-model="clientCliente" required="required" class="form-control" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="client in clientes" value="{{ client.id }}">{{ client.nombre }}</option>
                            </select>
                        </div>
                        <div class="left">
                            <label>Usuario Activo:</label><br />
                            <select required="required" ng-model="clientActivo" class="form-control">
                                <option value="1">SI</option>
                                <option value="0">NO</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Teléfono:</label>
                            <input type="text" ng-required="true" class="form-control" ng-model="clientTelefono"/>
                        </div>
                        <div class="left">
                            
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left">
                            <label>Contraseña:</label>
                            <input type="password" class="form-control" ng-model="clientPassw1" />
                        </div>
                        <div class="left">
                            <label>Repita la Contraseña:</label>
                            <input type="password" class="form-control" ng-model="clientPassw2" />
                        </div>
                    </div>

                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary">Grabar</button>
                </div>
            </form>
        </div>
    </div>
</div>