<input type="text" class="filtro form-control right" ng-model="filtroCotizacion" placeholder="Filtrar..." ng-keyup="filtrarCotizacionesTickets()" />
<div class="clear"></div>
<table id="tabla-cotizar-ticket" class="table table-striped tabla-hover">
    <thead>
        <tr>
            <th>No. Ticket</th>
            <th>Cliente</th>
            <th>Email Cliente</th>
            <th>Fecha</th>
            <th>Prioridad</th>
            <th>Categoría</th>
        </tr>
    </thead>
    <tbody ng-init="$parent.ticketsCotizables = []">
        <tr ng-repeat="ticket in $parent.ticketsCotizables" ng-dblclick="mostrarCotizacionTicket(ticket.idCotizacion, ticket.idTicket)">
            <td>{{ ticket.idTicket | rellenarIzq:0 }}</td>
            <td>{{ ticket.cliente }}</td>
            <td>{{ ticket.email }}</td>
            <td>{{ ticket.fecha | strDateToStr }}</td>
            <td>{{ ticket.prioridad }}</td>
            <td>{{ ticket.categoria }}</td>
        </tr>
    </tbody>
</table>

<!-- Windows Modal Cotizar Ticket -->
<div class="modal fade" id="modal-cotizar-ticket" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-cotizar-ticket-label"><span class="glyphicon glyphicon-usd" aria-hidden="true"></span> Cotización de Ticket</h4>
            </div>
            <form method="post" ng-submit="ofertarCotizacionTicket()">
                <div class="modal-body">
                    <div class="fila">
                        <button type="button" class="btn btn-default btn-xs" ng-click="informacionTicket()">Información del Ticket</button>
                        <button type="button" class="btn btn-default btn-xs" ng-click="ticketNoCerradosCliente()">Ticket no Cerrados</button>
                        <button type="button" class="btn btn-default btn-xs" ng-click="cotizacionesDelCliente()">Cotizaciones del Cliente</button>
                        <button type="button" class="btn btn-default btn-xs disabled">Facturaciones Pendientes</button>
                    </div>

                    <div class="fila">
                        <div id="panel-principal-cotizacion" class="left">
                            <div class="panel panel-default">
                                <div id="panel-totales-cotizacion" class="panel-body">
                                    <div class="fila">
                                        <label>Total Estimado:</label><input type="text" class="form-control solo-numero" ng-model="totalEstimadoTicket" ng-keyup="calcularTotalHoras()" ng-required="true" />
                                        <label>+ %Incremento:</label><input type="text" class="form-control solo-numero" ng-model="totalIncrementoTicket" ng-keyup="calcularTotalHoras()" ng-required="true" />
                                        <label>= Total Horas:</label><input type="text" class="form-control solo-numero" ng-model="totalHorasCotizacionTicket" ng-keyup="calcularTotalIncremento()" ng-required="true" />
                                    </div>
                                    <div class="fila">
                                        <label>Precio x Hora:</label><input type="text" class="form-control solo-numero" ng-model="precioHoraCotizacion" ng-keyup="calcularPrecioTotal()" ng-required="true" />
                                        <label>= Precio Total:</label><input type="text" class="form-control solo-numero" ng-model="totalPrecioCotizacion" ng-keyup="calcularPrecioXHoras()" ng-required="true" />

                                        <label> Fecha Límite:</label><input type="text" id="fecha-limite-aceptacion" class="form-control" ng-model="fechaLimiteAceptacion" ng-required="true" />
                                    </div>
                                </div>
                            </div>

                            <div class="panel panel-default">
                                <div class="panel-body">

                                    <div id="panel-estimaciones-cotizacion">
                                        <div class="cotizacion-estimacion-colaborador" ng-repeat="estimacion in estimacionesAceptadasTicket">
                                            <div>
                                                {{estimacion.nombreColaborador}} / <b>{{estimacion.catalogada}}</b> : {{estimacion.horas}} horas
                                            </div>

                                            <label>Actividades a desarrollar:</label>
                                            <div class="estimacion-actividades" ng-repeat="actividad in estimacion.detalles">
                                                <textarea class="left form-control text-estimacion-cotizacion">{{actividad.detalle}}</textarea>
                                                <div class="left tiempo-estimacion-cotizacion">{{actividad.tiempo}} horas</div>
                                                <div class="left nivel-estimacion-cotizacion">{{actividad.nivel}}</div>
                                                <div class="clear"></div>
                                            </div>

                                            <label>Entregables:</label>
                                            <textarea class="estimacion-text entregables form-control">{{estimacion.entregables}}</textarea>
                                            <label>Información Complementaria:</label>
                                            <textarea class="estimacion-text inf-complementaria form-control">{{estimacion.informacionComplementaria}}</textarea>
                                        </div>
                                    </div>

                                    <div id="texto-cotizacion">

                                        <div class="btn-toolbar" data-role="editor-toolbar" data-target="#editor-texto-cotizacion">
                                            <div class="btn-group">
                                                <a class="btn dropdown-toggle" data-toggle="dropdown" title="Font Size"><i class="glyphicon glyphicon-text-height"></i>&nbsp;<b class="caret"></b></a>
                                                <ul class="dropdown-menu">
                                                    <li><a data-edit="fontSize 5"><font size="5">Grande</font></a></li>
                                                    <li><a data-edit="fontSize 2"><font size="2">Normal</font></a></li>
                                                    <li><a data-edit="fontSize 1"><font size="1">Pequeña</font></a></li>
                                                </ul>
                                            </div>
                                            <div class="btn-group">
                                                <a class="btn" data-edit="bold" title="Bold (Ctrl/Cmd+B)"><i class="glyphicon glyphicon-bold"></i></a>
                                                <a class="btn" data-edit="italic" title="Italic (Ctrl/Cmd+I)"><i class="glyphicon glyphicon-italic"></i></a>
                                            </div>
                                            <div class="btn-group">
                                                <a class="btn" data-edit="insertunorderedlist" title="Bullet list"><i class="glyphicon glyphicon-list"></i></a>
                                                <a class="btn" data-edit="outdent" title="Reduce indent (Shift+Tab)"><i class="glyphicon glyphicon-indent-left"></i></a>
                                                <a class="btn" data-edit="indent" title="Indent (Tab)"><i class="glyphicon glyphicon-indent-right"></i></a>
                                            </div>
                                            <div class="btn-group">
                                                <a class="btn" data-edit="justifyleft" title="Align Left (Ctrl/Cmd+L)"><i class="glyphicon glyphicon-align-left"></i></a>
                                                <a class="btn" data-edit="justifycenter" title="Center (Ctrl/Cmd+E)"><i class="glyphicon glyphicon-align-center"></i></a>
                                                <a class="btn" data-edit="justifyright" title="Align Right (Ctrl/Cmd+R)"><i class="glyphicon glyphicon-align-right"></i></a>
                                                <a class="btn" data-edit="justifyfull" title="Justify (Ctrl/Cmd+J)"><i class="glyphicon glyphicon-align-justify"></i></a>
                                            </div>
                                        </div>

                                        <div id="editor-texto-cotizacion"></div>

                                    </div>

                                </div>
                            </div>

                        </div>
                        <div id="panel-colaboradores-cotizacion" class="left">
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                    <span class="text-heading">Colaboradores</span>
                                    <input type="text" class="form-control un-medio right" ng-model="filtroColaboradorCotizacion" placeholder="Filtrar..." />
                                    <div class="clear"></div>
                                </div>
                                <div class="panel-body">
                                    <table class="table table-striped table-hover">
                                        <tr ng-repeat="colaborador in colaboradoresAsignaciones | filter:filtroColaboradorCotizacion">
                                            <td>{{colaborador.nombre}}</td>
                                            <td style="text-align: center;" ng-click="verAsignacionesColaborador(colaborador.id)"><a href="#">Asignaciones</a></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="clear"></div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button id="boton-consolidar" type="button" class="btn btn-success left" ng-click="consolidarDatos()">Consolidar</button>
                    <button id="boton-desconsolidar" type="button" class="btn btn-success left" ng-click="desConsolidarDatos()">Ver Estimaciones</button>
                    <button id="boton-adjuntar" type="button" class="btn btn-info left" ng-click="windowAdjuntar()">Adjuntos</button>
                    <div id="div-oferta-renegociable" class="left">
                        <input type="checkbox" checked="checked" ng-model="ofertaRenegociable" class="form-control" />
                        <label>:Oferta Renegociable</label>
                    </div>

                    <button type="button" class="btn btn-primary" ng-click="$parent.verHistoricoTicket()">Histórico</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary">Enviar Cotización de Ticket</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Windows Modal Asignaciones de Colaboradores -->
<div class="modal fade" id="modal-asignacion-colaboradores2" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body">

                <div class="mes-popup">
                    <div class="cabecera-mes-popup">
                        <div class="mes-cambiar left" ng-click="irMesAtras()"><span class="glyphicon glyphicon-chevron-left"></span></div>
                        <div class="mes-cambiar right" ng-click="irMesAlante()"><span class="glyphicon glyphicon-chevron-right"></span></div>
                        <div class="mes-nombre center">{{mesCalendar}}</div>
                        <div class="clear"></div>
                    </div>

                    <div class="dias-semana">
                        <div class="dia-semana left">Lunes</div>
                        <div class="dia-semana left">Martes</div>
                        <div class="dia-semana left">Miércoles</div>
                        <div class="dia-semana left">Jueves</div>
                        <div class="dia-semana left">Viernes</div>
                        <div class="dia-semana left">Sábado</div>
                        <div class="dia-semana left">Domingo</div>
                        <div class="clear"></div>
                    </div>

                    <div class="semana-asignacion" ng-repeat="semana in semanasAsignaciones">
                        <div class="dia-semana left {{dia.mostrar}}" ng-repeat="dia in semana">
                            <div class="dia-cabecera">
                                <div class="numero-dia left">{{dia.dia}}</div>
                                <div class="clear"></div>
                            </div>
                            <div class="body-asignacion">
                                <div ng-repeat="asig in dia.asignaciones">
                                    <div class="asignacion-{{asig.clase}}">
                                        {{asig.cliente}} - {{asig.horas}} (h)
                                    </div>
                                </div>
                            </div>
                            <div class="horas-disponibles">
                                {{dia.horasDisponibles}}
                            </div>
                        </div>

                        <div class="clear"></div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Windows Modal Vista de Tickets -->
<div class="modal fade" id="modal-vista-ticket" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-vista-ticket-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Datos del Ticket</h4>
            </div>

            <div class="modal-body">
                <input type="hidden" ng-model="idTicketCliente" />
                <input type="hidden" ng-model="verificador" />
                <div class="panel panel-default">
                    <div class="panel-body">
                        <div class="left half">
                            <label class="label-data-ticket">Fecha: </label><span>{{fechaTicket | strDateToStr}}</span><br />
                            <label class="label-data-ticket">Empresa: </label><span>{{nombreCliente}}</span><br />
                            <label class="label-data-ticket">Usuario: </label><span>{{usuarioCliente}}</span><br />
                            <label class="label-data-ticket">Teléfono: </label><span>{{usuarioTelefono}}</span><br />
                            <label class="label-data-ticket">Estado: </label><span>{{estadoTicket}}</span><br />
                        </div>

                        <div class="left half">
                            <label class="label-data-ticket">Prioridad: </label><span>{{prioridadTicket}}</span><br />
                            <label class="label-data-ticket">Categoría: </label><span>{{categoriaTicket}}</span><br />
                            <label class="label-data-ticket">Teléfono(s): </label><span>{{telefonoCliente}}</span><br />
                            <label class="label-data-ticket">Reportó: </label><span>{{clienteReporta}}</span><br />
                            <label class="label-data-ticket">Reputación: </label><span>{{reputacionCliente}}%</span><br />
                        </div>
                    </div>
                </div>

                <div id="panel-vista-detalle-ticket" class="panel panel-default">
                    <div class="left half half-padding-right">
                        <div><label>Detalle del ticket:</label></div>
                        <div class="panel panel-default">
                            {{detalleTicket}}
                        </div>
                    </div>

                    <div id="panel-vista-adjuntos-ticket" class="left info-ticket">
                        <div ng-repeat="adj in adjuntosTicket" class="left">
                            <a href="Web{{adj.Url}}" target="_blank" class="btn btn-success btn-xs"><span class="glyphicon glyphicon-download"></span> Adjunto {{$index+1}}</a>
                        </div>
                    </div>
                    <div class="clear"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" ng-click="$parent.verHistoricoTicket()">Histórico</button>
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>

        </div>
    </div>
</div>

<!-- Windows Modal Tickets no Cerrados-->
<div class="modal fade" id="modal-ticket-no-cerrados" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-ticket-no-cerrados-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Tickets No Cerrados</h4>
            </div>

            <div class="modal-body">
                <table class="table table-striped tabla-hover">
                    <thead>
                        <tr>
                            <th>Ticket</th>
                            <th>Cliente</th>
                            <th>Fecha de Ticket</th>
                            <th>Estado de Ticket</th>
                            <th>Prioridad</th>
                            <th>Categoría</th>
                            <th>Detalle</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="ticket in ticketNoCerrados">
                            <td>{{ticket.id | rellenarIzq : 0}}</td>
                            <td>{{ticket.cliente}}</td>
                            <td>{{ticket.fecha | strDateToStr}}</td>
                            <td>{{ticket.estado}}</td>
                            <td>{{ticket.prioridad}}</td>
                            <td>{{ticket.categoria}}</td>
                            <td>{{ticket.detalle}}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Windows Modal Cotizaciones Clientes -->
<div class="modal fade" id="modal-cotizaciones-clientes" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-cotizaciones-clientes-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Cotizaciones de Cliente</h4>
            </div>

            <div class="modal-body">
                <table class="table table-striped tabla-hover">
                    <thead>
                        <tr>
                            <th>Ticket</th>
                            <th>Cliente</th>
                            <th>Fecha de Ticket</th>
                            <th>Prioridad</th>
                            <th>Categoría</th>
                            <th>Cantidad Ofertas</th>
                            <th>Cotización Aceptada</th>
                            <th>Último Precio</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="ticket in ticketCotizados">
                            <td>{{ticket.id | rellenarIzq : 0}}</td>
                            <td>{{ticket.cliente}}</td>
                            <td>{{ticket.fecha | strDateToStr}}</td>
                            <td>{{ticket.prioridad}}</td>
                            <td>{{ticket.categoria}}</td>
                            <td>{{ticket.cantOfertas}}</td>
                            <td>{{ticket.cotizacionAceptada}}</td>
                            <td>{{ticket.ultimoPrecio}}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Windows Adjuntos Cotización-->
<div class="modal fade" id="modal-cotizaciones-adjuntos" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-cotizaciones-adjuntos-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Adjuntos </h4>
            </div>

            <div class="modal-body">
                <label>Adjuntos:</label>
                <div id="div-ficheros-cotizacion" class="panel panel-default">
                    <div class="panel-body"></div>
                </div>

                <div class="fila">
                    <button class="btn btn-primary" ng-click="adicionarAdjuntoCotizacion()">Adicionar Adjunto</button>
                    <button class="btn btn-danger" ng-click="eliminarAdjuntoCotizacion()">Eliminar Adjunto</button>
                </div>

                <div id="div-add-ficheros-cotizacion" class="separar-arriba"></div>
