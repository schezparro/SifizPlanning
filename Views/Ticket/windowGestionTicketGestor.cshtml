                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-comentarios-ticket-label"><span class="glyphicon glyphicon-wrench" aria-hidden="true"></span> Se debe cambiar la próxima actividad </h4>
            </div>
            <form ng-submit="cambiarProximaActividadTicket()">
                <div class="modal-body">
                    <div>
                        {{mensajeNoConcuerda}}
                    </div>
                    <label>Próxima Actividad:</label>
                    <select class="form-control" ng-model="changeProximaActividad">
