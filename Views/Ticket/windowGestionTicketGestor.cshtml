<table id="tabla-gestion-ticket" class="table table-striped table-condensed">
    <thead>
        <tr>
            <th class="ordenar-columna" ng-click="ordenarColumna(1)">
                <div class="left">
                    No. Ticket
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(2)">
                <div class="left">
                    Cliente
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(3)">
                <div class="left">
                    Fecha
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(4)">
                <div class="left">
                    Asunto
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(5)">
                <div class="left">
                    Asignado A
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(6)">
                <div class="left">
                    Prioridad
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(7)">
                <div class="left">
                    Categoría
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(8)">
                <div class="left">
                    Estado
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(9)">
                <div class="left">
                    Próxima Actividad
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
            <th class="ordenar-columna" ng-click="ordenarColumna(10)">
                <div class="left">
                    Aplica A
                </div>
                <div class="right">
                    <i class="icon-sort-table glyphicon glyphicon-chevron-up invisible"></i>
                </div>
            </th>
        </tr>
        <tr>
            <th><input type="text" class="form-control" ng-model="numero" ng-keyup="filterData(1)" /></th>
            <th><input type="text" class="form-control" ng-model="cliente" ng-keyup="filterData(2)" /></th>
            <th><input type="text" class="form-control" ng-model="fecha" ng-keyup="filterData(3)" /></th>
            <th><input type="text" class="form-control" ng-model="asunto" ng-keyup="filterData(4)" /></th>
            <th><input type="text" class="form-control" ng-model="asignado" ng-keyup="filterData(5)" /></th>
            <th>
                <!--<input type="text" class="form-control" ng-model="prioridad" ng-keyup="filterData(6)" />-->
                <select id="select-prioridad-ticket" class="selectpicker" multiple>
                    <option ng-repeat="prio in prioridades | orderBy:'name'" value="{{prio.name}}">{{prio.name}}</option>
                </select>
            </th>
            <th>
                <!--<input type="text" class="form-control" ng-model="categoria" ng-keyup="filterData(7)" />-->
                <select id="select-categoria-ticket" class="selectpicker" multiple>
                    <option ng-repeat="cat in categorias | orderBy:'name'" value="{{cat.name}}">{{cat.name}}</option>
                </select>
            </th>
            <th>
                <!--<input type="text" class="form-control" ng-model="estado" ng-keyup="filterData(8)" />-->
                <select id="select-estado-ticket" class="selectpicker" multiple>
                    <option ng-repeat="estado in estadosTickets | orderBy:'nombre'" value="{{estado.nombre}}">{{estado.nombre}}</option>
                </select>
            </th>
            <th>
                <!--<input type="text" class="form-control" ng-model="estado" ng-keyup="filterData(9)" />-->
                <select id="select-proxima-actividad" class="selectpicker" multiple>
                    <option ng-repeat="proximaActividadFilter in proximasActividadesFilter" value="{{proximaActividadFilter}}">{{proximaActividadFilter}}</option>
                </select>
            </th>

            <th>
                <!--<input type="text" class="form-control" ng-model="ticketVersionCliente" ng-keyup="filterData(10)" />-->
                <select id="select-ticketVersionCliente" class="selectpicker" multiple>
                    <option value="NO ASIGNADO">NO ASIGNADO</option>
                    <option ng-repeat="ticketVersionCliente in ticketVersionClientes" value="{{ticketVersionCliente.nombre}}">{{ticketVersionCliente.nombre}}</option>
                </select>
            </th>
        </tr>
    </thead>
    <tfoot>
        <tr>
            <th colspan="8">
                <div>
                    <div class="left gestion-lista-ticket">
                        <div class="margin-top-3">
                            <label>Mostrar Todos:</label>
                            <input type="checkbox" ng-click="mostrarTodosLosTickets()" ng-model="mostrarTodos" />
                        </div>
                    </div>
                    <div class="left gestion-lista-ticket form-inline">
                        <div ng-init="filtroFacturacion='t'">
                            <label>Según Facturación: </label>
                            <select class="form-control sm" ng-model="filtroFacturacion" ng-change="mostrarPorFacturados()">
                                <option value="t">TODOS</option>
                                <option value="F">FACTURABLES</option>
                                <option value="FF">FACTURABLES - FACTURADOS</option>
                                <option value="FNF">FACTURABLES - NO FACTURADOS</option>
                                <option value="SF">SIN FACTURABLES</option>
                            </select>
                        </div>
                    </div>
                    <div class="clear"></div>
                </div>

                <div class="padding-lr-10">
                    <div class="clear"></div>
                    <div class="left">
                        <nav>
                            <ul class="pagination">
                                <li ng-click="atrazarPagina()">
                                    <a href="#" aria-label="Previous">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                </li>
                                <li ng-repeat="pagina in listaPaginas" ng-click="cambiarPagina(pagina)"><a href="#">{{pagina}}</a></li>
                                <li ng-click="avanzarPagina()">
                                    <a href="#" aria-label="Next">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>

                    <div class="left form-inline gestion-lista-ticket" ng-init="cantidadMostrarPorPagina = 10">
                        <label>Cantidad Por Página:</label>
                        <select class="form-control" ng-model="cantidadMostrarPorPagina" ng-change="actualizarCantidadMostrar()">
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>

                    <div class="right gestion-lista-ticket">
                        <div>
                            <label>Total de Páginas: </label>{{cantPaginas}}
                        </div>
                    </div>
                    <div class="right gestion-lista-ticket">
                        <div>
                            <label>Total de Ticket: </label>{{totalTickets}}
                        </div>
                    </div>

                    <div class="clear"></div>
                </div>

            </th>

        </tr>
    </tfoot>
    <tbody>
        <tr class="{{ticket.clase}}" ng-repeat="ticket in tickets" ng-dblclick="mostrarDetalleTicket(ticket.numero)" ng-click="mostrarInformacionTicket(ticket.numero)">
            <td>{{ ticket.numero | rellenarIzq:0 }}</td>
            <td>{{ ticket.cliente }}</td>
            <td>{{ ticket.fecha | strDateToStr }} ({{ticket.dias}})</td>
            <td>{{ ticket.asunto }}</td>
            <td>{{ ticket.asignado }}</td>
            <td>{{ ticket.prioridad }}</td>
            <td>{{ ticket.categoria }}</td>
            <td>{{ ticket.estado }}</td>
            <td>{{ ticket.proximaActividad }}</td>
            <td>{{ ticket.ticketVersionCliente }}</td>
        </tr>
    </tbody>
</table>

<!-- Windows Modal Gestion de Tickets -->
<div class="modal fade" id="modal-gestion-ticket" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-gestion-ticket-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Gestión de Ticket</h4>
            </div>
            <form method="post" id="frm-edit-tickets" ng-submit="guardarTicket()">
                <div class="modal-body">
                    <div class="panel panel-default panel-superior">
                        <div class="panel-body" id="panel-info-ticket-general">
                            <div class="left info-ticket">
                                <label class="label-data-ticket">N° Ticket: </label><span>{{idTicketCliente | rellenarIzq:0}}</span><br />
                                <label class="label-data-ticket">Fecha: </label><span>{{fechaTicket | strDateToStr}}</span><br />
                                <label class="label-data-ticket">Empresa: </label><span>{{nombreCliente}}</span><br />
                                <label class="label-data-ticket">Usuario: </label><span>{{usuarioCliente}}</span><br />
                                <label class="label-data-ticket">Reportó: </label><span>{{clienteReporta}}</span><br />
                                <label class="label-data-ticket">Teléfono: </label><span>{{usuarioTelefono}} / {{telefonoCliente}}</span><br />
                                <label class="label-data-ticket">Asunto: </label><span>{{asuntoTicket}}</span><br />
                                <label class="label-data-ticket">Estado: </label><span>{{estadoTicket}}</span>
                            </div>

                            <div class="left info-ticket">
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Prioridad: </label><span style="margin-left: 5px;">{{prioridadTicket}}</span>
                                </div>
                                <div class="div-info-ticket form-inline" style="vertical-align: middle;" ng-hide="justificacionPrioridad == ''">
                                    <label style="vertical-align: middle;" class="label-data-ticket">Justificación Prioridad: </label><textarea class="form-control" style="margin-left: 5px; height: 50px; width: 66%; margin-bottom: 2px; resize: none" readonly>{{justificacionPrioridad}}</textarea>
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">P.Revisada: </label>
                                    <select class="form-control" id="prioridad-ticket" ng-model="prioridad">
                                        <option ng-repeat="priori in prioridades" value="{{priori.id}}">{{priori.name}}</option>
                                    </select>
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Categoría: </label><span style="margin-left: 5px;">{{categoriaTicket}}</span>
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">C.Revisada: </label>
                                    <select class="form-control" id="categoria-ticket" ng-required="true" ng-model="categoria">
                                        <option value=""></option>
                                        <option ng-repeat="categ in categorias" value="{{categ.id}}">{{categ.name}}</option>
                                    </select>
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Estimación:</label>
                                    <input id="campo-horas-ticket" class="form-control solo-numero" ng-model="estimacionTicket" /> (horas)
                                </div>

                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Recurso:</label>
                                    <select class="form-control" id="tipo-recurso-ticket" ng-model="tipoRecurso">
                                        <option ng-repeat="tipo in tiposRecursos" value="{{tipo.id}}">{{tipo.nombre}}</option>
                                    </select>
                                </div>

                                <div>
                                    <label class="label-data-ticket">Aplica A: </label>
                                    <select class="form-control" id="ticket-version-cliente" ng-model="ticketVC" ng-required="true">
                                        <option ng-repeat="ticketVC in ticketVersionClientes" value="{{ticketVC.id}}">{{ticketVC.nombre}}</option>
                                    </select>
                                </div>
                            </div>

                            <div id="datos-reputacion" class="left info-ticket">
                                <div hidden class="div-info-ticket">
                                    <label class="label-data-ticket">Teléfono(s): </label><span>{{telefonoCliente}}</span><br />
                                </div>
                                <div hidden class="div-info-ticket">
                                    <label class="label-data-ticket">Reportó: </label><span>{{clienteReporta}}</span><br />
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Se Factura:</label>
                                    <input type="checkbox" ng-model="seFactura" />
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Facturado:</label>
                                    <input type="checkbox" ng-model="facturado" />
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Error:</label>
                                    <input type="checkbox" ng-model="error" />
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Reputación Cliente: </label><span>{{reputacionCliente}}%</span><br />
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Reputación Ticket: </label>
                                    <select ng-model="reputacionTicket" class="form-control">
                                        <option value="1">1</option>
                                        <option value="2">2</option>
                                        <option value="3">3</option>
                                        <option value="4">4</option>
                                        <option value="5">5</option>
                                    </select>
                                </div>
                                <div hidden class="div-info-ticket">
                                    <label class="label-data-ticket">Reprocesos: </label>
                                    <input type="text" class="form-control solo-numero" id="reprocesos-ticket" ng-model="reprocesos">
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Ingreso Interno:</label>
                                    <input type="checkbox" ng-model="ingresoInterno" />
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Actividad Próxima:</label>
                                    <select class="form-control" id="actividad-proxima-ticket" ng-model="actividadProxima">
                                        <option ng-repeat="actividad in proximasActividades" value="{{actividad.id}}">{{actividad.nombre}}</option>
                                    </select>
                                </div>
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Requiere Testing:</label>
                                    <input type="checkbox" ng-model="requiereTesting" />
                                </div>
                            </div>
                            <div id="datos-reputacion" class="left info-ticket" ng-hide="categoriaTicket != 'MANTENIMIENTO'">
                                <div class="div-info-ticket">
                                    <button type="button" class="btn btn-warning btn-xs" ng-click="validarContratos()"><span class="glyphicon glyphicon-alert"></span>Validar Mantenimiento</button>
                                </div>
                            </div>
                            <div id="datos-reputacion" class="left info-ticket">
                                <div class="div-info-ticket">
                                    <label class="label-data-ticket">Fecha Revisado:</label>
                                    <input id="fechaRevisado" name="fechaRevisado" ng-model="fechaRevisado" class="form-control inline" style="width: 40%" autocomplete="off" />
                                </div>
                            </div>
                            <div class="div-info-ticket" ng-show="motivoTrabajo != null">
                                <label class="label-data-ticket">M.Trabajo: </label><span>{{motivoTrabajo.codigo}} - {{motivoTrabajo.descripcion}}.</span>
                            </div>
                            <div id="panel-adjuntos-ticket" class="left info-ticket">
                                <div ng-repeat="adj in adjuntosTicket" class="left">
                                    <a href="Web{{adj.Url}}" target="_blank" class="btn btn-default btn-xs"><span class="glyphicon glyphicon-paperclip"></span> Adjunto {{$index+1}}</a>
                                </div>
                            </div>
                            @*<input id="adjuntoAddTicket" class="form-control" type="file">*@
                        </div>
                    </div>

                    <div id="panel-funcionalidades-ticket" class="panel panel-default left">
                        <div class="panel-heading">
                            Detalle de Ticket
                        </div>
                        <div class="panel-body">
                            {{detalleTicket}}
                        </div>
                    </div>

                    <div id="panel-colaboradores-ticket" class="panel panel-default left">
                        <div class="panel-heading">
                            <span class="text-heading">Colaboradores</span>
                            <input type="text" class="form-control un-medio right" ng-model="filtroColaborador" placeholder="Filtrar..." />
                            <div class="clear"></div>
                        </div>

                        <div class="panel-body">
                            <table class="table table-striped">
                                <tr ng-repeat="colab in colaboradores | filter:filtroColaborador">
                                    <td>{{colab.nombre}}</td>
                                    <td><a ng-click="verAsignacionesColaborador(colab.id, colab.sede)" href="#">Asignaciones</a></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div id="panel-asignaciones-ticket" class="left">
                        <div class="panel panel-default left" style="width:100%!important; height:50%!important; margin-bottom: 2px !important">
                            <div class="panel-heading">
                                Técnico Sugerido y Resolución
                            </div>

                            <div class="panel-body">
                                <div>
                                    <div class="left">
                                        <label class="label-data-ticket">Técnico:</label>
                                        <select class="form-control" id="tecnico-sugerido" ng-model="tecnicoSugerido">
                                            <option ng-repeat="colab in colaboradores" value="{{colab.id}}">{{colab.nombre}}</option>
                                        </select>
                                    </div>
                                    <div class="right margin-top-10">
                                        <button type="button" class="btn btn-danger" ng-click="mostrarPantallaDesacuerdo()"><span class="glyphicon glyphicon-thumbs-down"></span> Desacuerdo</button>
                                    </div>
                                    <div class="clear"></div>
                                </div>
                                <div class="">
                                    <label class="label-data-ticket">Resolución:</label>
                                    <textarea class="form-control" style="width:560px!important;height:50px!important" ng-model="observaciones"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="clear"></div>
                        <div class="panel panel-default left" style="width:100%!important; height:50%!important">
                            <div class="panel-heading">
                                Asignaciones
                            </div>

                            <div class="panel-body">
                                <button type="button" class="btn btn-primary btn-xs" ng-click="adicionarTareaAsignacion()"><span class="glyphicon glyphicon-plus"></span> Adicionar</button>
                                <div class="right">
                                    <label>Total de Horas: </label>{{totalHorasAsignadas}}
                                </div>

                                <div class="clear"></div>

                                <div id="tabla-asignaciones-ticket">
                                    <table class="table table-striped tabla-hover">
                                        <thead>
                                            <tr>
                                                <th>Fecha</th>
                                                <th>Colaborador</th>
                                                <th>Horas</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="asignacion in asignaciones">
                                                <td ng-click="verTareaAsignacion(asignacion.id)">{{asignacion.fecha}}</td>
                                                <td ng-click="verTareaAsignacion(asignacion.id)">{{asignacion.colaborador}}</td>
                                                <td ng-click="verTareaAsignacion(asignacion.id)">{{asignacion.numeroHoras}}</td>
                                                <td ng-click="eliminarTareaAsignacion(asignacion.id)"><span class="glyphicon glyphicon-remove"></span></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" ng-model="idTicketCliente" />
                    <input type="hidden" ng-model="verificador" />
                    <div class="clear"></div>
                </div>
                <div class="modal-footer">
                    <input type="file" onchange="angular.element(this).scope().resetearAdjunto()" id="selectedFile" style="display: none;" />
                    <button ng-init="botones = [];" ng-repeat="boton in botones" type="button" data-id-btn="{{boton.funcion}}" class="btn {{boton.clase}} left"><span class="glyphicon {{boton.icono}}"></span> {{boton.texto}}</button>
                    <!--<button type="button" class="btn btn-success left" data-dismiss="modal"><span class="glyphicon glyphicon-usd"></span> Cotizar</button>
                    <button type="button" class="btn btn-warning left" data-dismiss="modal"><span class="glyphicon glyphicon-trash"></span> Anular</button>-->
                    <button type="submit" class="btn btn-primary left"><span class="glyphicon glyphicon-save"></span> Grabar</button>
                    <button type="button" class="btn btn-info left" ng-click="$parent.verHistoricoTicket()"><span class="glyphicon glyphicon-calendar"></span> Histórico</button>
                    <button type="button" class="btn btn-warning left" ng-click="verComentarioTicket()"><span class="glyphicon glyphicon-comment"></span> Comentarios</button>
                    <button type="button" id="buttonAdjunto" class="btn btn-success left" onclick="document.getElementById('selectedFile').click();"><span class="glyphicon glyphicon-paperclip"></span> Adjuntar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal"><span class="glyphicon glyphicon-remove"></span> Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Windows Modal Contratos por Cliente-->
<div class="modal fade" id="modal-contratos-cliente" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog" style="width: 50%">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-gestion-ticket-label"><span class="glyphicon glyphicon-tag" aria-hidden="true"></span> Validar Mantenimiento</h4>
            </div>
            <div class="modal-body">

                <div class="panel panel-default">
                    <div class="panel-heading center">
                        <span class="text-heading">Contrato</span>

                        <div style="width: 20%" class='input-group date right' id='fechaMantenimiento'>
                            <input type='text' class="form-control" ng-model="fechaMantenimiento" />
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-calendar"></span>
                            </span>
                        </div>
                        <div class="clear"></div>
                    </div>

                    <div class="panel-body">
                        <table class="table table-striped table-condensed">
                            <thead>
                                <tr>
                                    <th>
                                        <div class="left">
                                            Código Contrato
                                        </div>
                                    </th>
                                    <th>
                                        <div class="left">
                                            Fecha Corte
                                        </div>
                                    </th>
                                    <th>
                                        <div class="left">
                                            Fecha Vencimiento
                                        </div>
                                    </th>
                                    <th>
                                        <div class="left">
                                            Horas Mensuales
                                        </div>
                                    </th>
                                    <th>
                                        <div class="left">
                                            Horas Consumidas
                                        </div>
                                    </th>
                                    <th>
                                        <div class="left">
                                            Horas Disponibles
                                        </div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="contrato in contratosMantenimiento">
                                    <td>{{contrato.Codigo}}</td>
                                    <td>{{contrato.FechaInicio}}</td>
                                    <td>{{contrato.FechaVencimiento}}</td>
                                    <td>{{contrato.HorasMensuales}}</td>
                                    <td>{{contrato.HorasConsumidas}}</td>
                                    <td>{{contrato.HorasDisponibles}}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

