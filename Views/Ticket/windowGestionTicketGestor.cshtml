                                <option value="">Seleccione...</option>
                                <option ng-repeat="act in actividades" value="{{ act.id }}">{{ act.nombre }}</option>
                            </select>
                        </div>

                        <div class="left half half-padding-left">
                            <label>Módulo:</label><br />
                            <select ng-model="moduloAsignacion" required="required" class="form-control" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="mod in modulos" value="{{ mod.id }}">{{ mod.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left half half-padding-right">
                            <label>Número Horas:</label>
                            <select ng-model="numeroHorasAsignacion" required="required" class="form-control" ng-required="true" ng-change="calcularRepetir()">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="h in [1,2,3,4,5,6,7,8]" value="{{ h }}">{{ h }}</option>
                            </select>
                        </div>
                        <div class="left half half-padding-left">
                            <label>Coordinador:</label>
                            <select ng-model="coordinadorAsignacion" class="form-control">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="cord in coordinadores" value="{{ cord.id }}">{{ cord.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <label>Detalle:</label>
                        <textarea ng-model="detalleAsignacion" required="required" class="form-control"></textarea>
                    </div>

                    <div class="clear"></div>

                    <div class="fila">
                        <div class="left half half-padding-right" ng-init="vecesRepetirAsignacion = 1">
