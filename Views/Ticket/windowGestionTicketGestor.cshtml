                            <select ng-model="ubicacionAsignacion" required="required" class="form-control" ng-required="true">
                                <option value="">Seleccione...</option>
                                <option ng-repeat="lugar in lugares" value="{{ lugar.id }}">{{ lugar.nombre }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="clear"></div>

